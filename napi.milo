// ── classes and native state ──

// napi_property_descriptor, verified against js_native_api_types.h with the real
// compiler (sizeof 64):
//   0 utf8name  8 name  16 method  24 getter  32 setter  40 value  48 attributes  56 data
let NAPI_PD_SIZE: i64 = 64
let NAPI_PD_UTF8NAME: i64 = 0
let NAPI_PD_METHOD: i64 = 16
let NAPI_PD_VALUE: i64 = 40
// napi_static — a static member lives on the constructor, not the prototype
let NAPI_STATIC: i32 = 1024
let NAPI_PD_ATTRIBUTES: i64 = 48

fn napiLoadI64(p: *u8): i64 {
    unsafe {
        var b: [i64; 1] = [0; 1]
        memcpy(b as *u8, p, 8)
        return b[0]
    }
}

fn napiLoadI32(p: *u8): i32 {
    unsafe {
        var b: [i32; 1] = [0; 1]
        memcpy(b as *u8, p, 4)
        return b[0]
    }
}

// Register a callback and return the milojs object that dispatches to it.
fn napiMakeFn(cb: i64, data: i64): i64 {
    gNapi.fns.push(NapiFn {
        fnPtr: cb, data: data
    }
    )
    let o = newObject(gInterp)
    let _en = ensureExtra(gInterp, o)
    gInterp.objExtras[gInterp.objects[o].extra].napiFn = gNapi.fns.len() - 1
    gInterp.objects[o].isFunctionLike = true
    return o
}

// napi_define_class(env, utf8name, length, constructor, data, property_count,
//                   properties, result)
//
// Produces a constructor object plus a prototype carrying the instance methods.
// `new Ctor()` links the instance's proto here, so method lookup finds them.
@export
fn napi_define_class(_env: *u8, _utf8name: *u8, _length: i64, constructor: i64, data: i64, propertyCount: i64, properties: *u8, result: *u8): i32 {
    if constructor == 0 {
        return NAPI_INVALID_ARG
    }
    let ctor = napiMakeFn(constructor, data)
    let proto = newObject(gInterp)
    var i: i64 = 0
    unsafe {
        while i < propertyCount {
            let base = (properties as i64) + i * NAPI_PD_SIZE
            let namePtr = napiLoadI64((base + NAPI_PD_UTF8NAME) as *u8)
            if namePtr != 0 {
                let pname = napiReadStr(namePtr as *u8, -1)
                let method = napiLoadI64((base + NAPI_PD_METHOD) as *u8)
                let attrs = napiLoadI32((base + NAPI_PD_ATTRIBUTES) as *u8)
                // static members hang off the constructor; everything else off the prototype
                var target = proto
                if (attrs & NAPI_STATIC) != 0 {
                    target = ctor
                }
                if method != 0 {
                    let m = napiMakeFn(method, napiLoadI64((base + 56) as *u8))
                    objSet(gInterp, target, pname, JSValue.Obj(m))
                } else {
                    let vh = napiLoadI64((base + NAPI_PD_VALUE) as *u8)
                    objSet(gInterp, target, pname, napiValueOf(vh))
                }
            }
            i = i + 1
        }
    }
    objSet(gInterp, ctor, "prototype", JSValue.Obj(proto))
    napiWriteHandle(result, napiHandle(JSValue.Obj(ctor)))
    return NAPI_OK
}

// napi_wrap(env, js_object, native_object, finalize_cb, finalize_hint, result)
//
// The finalizer is accepted but never invoked yet: milojs's collector has no
// finalizer hook, so a wrapped native allocation outlives its JS object.
@export
fn napi_wrap(_env: *u8, jsObject: i64, nativeObject: i64, _finalizeCb: i64, _finalizeHint: i64, _result: *u8): i32 {
    match napiValueOf(jsObject) {
        JSValue.Obj(o) => {
            let _ew = ensureExtra(gInterp, o)
            gInterp.objExtras[gInterp.objects[o].extra].napiWrap = nativeObject
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

@export
fn napi_unwrap(_env: *u8, jsObject: i64, result: *u8): i32 {
    match napiValueOf(jsObject) {
        JSValue.Obj(o) => {
            napiWriteHandle(result, gInterp.objExtras[gInterp.objects[o].extra].napiWrap)
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

// ── remaining mechanical surface ──

@export

// index is uint32_t, NOT size_t. Declaring it i64 reads the undefined upper half
// of the 32-bit argument slot on AArch64, so the index came through as garbage and
// every element resolved to undefined.
fn napi_get_element(_env: *u8, object: i64, index32: i32, result: *u8): i32 {
    let index = index32 as i64
    match napiValueOf(object) {
        JSValue.Obj(o) => {
            if index >= 0 && index < gInterp.objects[o].elems.len() {
                napiWriteHandle(result, napiHandle(cloneValue(gInterp.objects[o].elems[index])))
            } else {
                napiWriteHandle(result, napiHandle(JSValue.Undefined))
            }
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

@export
fn napi_set_element(_env: *u8, object: i64, index32: i32, value: i64): i32 {
    let index = index32 as i64
    match napiValueOf(object) {
        JSValue.Obj(o) => {
            while gInterp.objects[o].elems.len() <= index {
                gInterp.objects[o].elems.push(JSValue.Undefined)
            }
            gInterp.objects[o].elems[index] = napiValueOf(value)
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

@export
fn napi_has_named_property(_env: *u8, object: i64, utf8name: *u8, result: *u8): i32 {
    match napiValueOf(object) {
        JSValue.Obj(o) => {
            let key = napiReadStr(utf8name, -1)
            var found = false
            var i: i64 = 0
            while i < gInterp.objects[o].props.len() {
                if gInterp.objects[o].props[i].key == key {
                    found = true
                }
                i = i + 1
            }
            napiWriteBool(result, found)
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

@export
fn napi_get_value_uint32(_env: *u8, value: i64, result: *u8): i32 {
    napiWriteI32(result, toNum(napiValueOf(value)) as i32)
    return NAPI_OK
}

// napi_get_value_string_utf8(env, value, buf, bufsize, result)
// A NULL buf means "just tell me the length", which is how addons size their
// allocation before the real call.
@export
fn napi_get_value_string_utf8(_env: *u8, value: i64, buf: *u8, bufsize: i64, result: *u8): i32 {
    let s = toStr(napiValueOf(value))
    unsafe {
        if (buf as i64) == 0 {
            if (result as i64) != 0 {
                napiWriteHandle(result, s.len())
            }
            return NAPI_OK
        }
        var n = s.len()
        if n > bufsize - 1 {
            n = bufsize - 1
        }
        var i: i64 = 0
        while i < n {
            var one: [u8; 1] = [s[i]; 1]
            memcpy(((buf as i64) + i) as *u8, one as *u8, 1)
            i = i + 1
        }
        var z: [u8; 1] = [0 as u8; 1]
        memcpy(((buf as i64) + n) as *u8, z as *u8, 1)
        if (result as i64) != 0 {
            napiWriteHandle(result, n)
        }
    }
    return NAPI_OK
}

@export
fn napi_coerce_to_string(_env: *u8, value: i64, result: *u8): i32 {
    napiWriteHandle(result, napiHandle(JSValue.Str(toStr(napiValueOf(value)))))
    return NAPI_OK
}

// ── errors and globals ──

// napi_get_property(env, object, key, result) — key is a napi_value, not a C string
@export
fn napi_get_property(_env: *u8, object: i64, key: i64, result: *u8): i32 {
    match napiValueOf(object) {
        JSValue.Obj(o) => {
            let v = objGet(gInterp, o, toStr(napiValueOf(key)))
            napiWriteHandle(result, napiHandle(v))
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

@export
fn napi_get_global(_env: *u8, result: *u8): i32 {
    // scope 0 is the global scope; addons use this to reach globalThis
    let o = newObject(gInterp)
    gInterp.objects[o].isGlobal = true
    napiWriteHandle(result, napiHandle(JSValue.Obj(o)))
    return NAPI_OK
}

fn napiMakeError(msgVal: JSValue): i64 {
    let o = newObject(gInterp)
    gInterp.objects[o].isError = true
    objSet(gInterp, o, "name", JSValue.Str("Error"))
    objSet(gInterp, o, "message", JSValue.Str(toStr(msgVal)))
    return o
}

@export
fn napi_create_error(_env: *u8, _code: i64, msg: i64, result: *u8): i32 {
    let o = napiMakeError(napiValueOf(msg))
    napiWriteHandle(result, napiHandle(JSValue.Obj(o)))
    return NAPI_OK
}

// Raise a JS exception. The addon returns to us immediately afterwards, and the
// pending throw is what callers observe.
@export
fn napi_throw(_env: *u8, error: i64): i32 {
    gInterp.throwing = true
    gInterp.thrownValue = napiValueOf(error)
    return NAPI_OK
}

@export
fn napi_throw_error(_env: *u8, _code: *u8, msg: *u8): i32 {
    let o = napiMakeError(JSValue.Str(napiReadStr(msg, -1)))
    gInterp.throwing = true
    gInterp.thrownValue = JSValue.Obj(o)
    return NAPI_OK
}

// napi_get_property_names(env, object, result) — own enumerable string keys, as an
// array. napi-rs's serde deserializer walks this to build a struct, so a stub that
// returns napi_ok without writing anything leaves it reading an uninitialized
// handle off its own stack.
@export
fn napi_get_property_names(_env: *u8, object: i64, result: *u8): i32 {
    match napiValueOf(object) {
        JSValue.Obj(o) => {
            let arr = newArray(gInterp)
            var i: i64 = 0
            while i < gInterp.objects[o].props.len() {
                let k = gInterp.objects[o].props[i].key.clone()
                gInterp.objects[arr].elems.push(JSValue.Str(k))
                i = i + 1
            }
            napiWriteHandle(result, napiHandle(JSValue.Obj(arr)))
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

// ── buffers and references ──

// Every predicate MUST write its out-param. Returning napi_ok without doing so
// leaves the caller reading an uninitialized bool off its own stack — napi-rs then
// took a plain string for a Buffer and the whole deserialize failed with a bare
// InvalidArg and no reason string.
@export
fn napi_is_buffer(_env: *u8, value: i64, result: *u8): i32 {
    match napiValueOf(value) {
        JSValue.Obj(o) => {
            napiWriteBool(result, gInterp.objects[o].isArrayBuffer)
        }
        _ => {
            napiWriteBool(result, false)
        }
    }
    return NAPI_OK
}

// References keep a value alive across calls. There is no finalizer hook in the
// collector yet, so a reference is simply a handle that is never released — it
// over-retains rather than freeing something the addon still points at.
@export
fn napi_create_reference(_env: *u8, value: i64, _initialRefcount: i32, result: *u8): i32 {
    napiWriteHandle(result, napiHandle(napiValueOf(value)))
    return NAPI_OK
}

@export
fn napi_get_reference_value(_env: *u8, ref: i64, result: *u8): i32 {
    napiWriteHandle(result, napiHandle(napiValueOf(ref)))
    return NAPI_OK
}

@export
fn napi_delete_reference(_env: *u8, _ref: i64): i32 {
    return NAPI_OK
}

@export
fn napi_reference_unref(_env: *u8, _ref: i64, result: *u8): i32 {
    unsafe {
        if (result as i64) != 0 {
            napiWriteI32(result, 0)
        }
    }
    return NAPI_OK
}

// ── promises ──

// napi_create_promise(env, deferred, promise)
//
// The deferred and the promise are the same underlying object here, handed out as
// two handles: milojs settles a promise in place, so there is no separate resolver
// state to track.
fn napiSettle(p: i64, state: i64, value: JSValue) {
    if gNapi.liveDeferred > 0 {
        gNapi.liveDeferred = gNapi.liveDeferred - 1
    }
    gNapi.pending.push(NapiPending {
        promise: p, state: state, value: value
    }
    )
}

// True while an addon owes us a settlement. Keeps the event loop from exiting
// before a worker thread replies.
fn napiHasPendingWork(): bool {
    // A live threadsafe function counts: napi-rs resolves an async call by
    // invoking one from a tokio worker, without ever creating a deferred here,
    // so a registered tsfn means a settlement can still arrive from off-thread.
    // Node keeps its loop alive for a ref'd tsfn for the same reason.
    if gNapi.liveDeferred > 0 || gNapi.pending.len() > 0 {
        return true
    }
    var i: i64 = 0
    while i < gNapi.tsfns.len() {
        if gNapi.tsfns[i].refs > 0 && !gNapi.tsfns[i].unrefed {
            return true
        }
        i = i + 1
    }
    return false
}

// Whether a settlement can still arrive from an addon's own threads. Unlike
// napiHasPendingWork this ignores unref'd-ness: napi-rs unrefs its threadsafe
// functions (so they must not keep the process alive), yet they are exactly how
// a query result comes back, so a blocked await still has to wait on them.
// The await's own deadline is the backstop if the addon never answers.
fn napiMayDeliver(): bool {
    if gNapi.liveDeferred > 0 || gNapi.pending.len() > 0 {
        return true
    }
    var i: i64 = 0
    while i < gNapi.tsfns.len() {
        if gNapi.tsfns[i].refs > 0 {
            return true
        }
        i = i + 1
    }
    return false
}

// Drained by the interpreter after any call into an addon.
fn napiTakePending(): Vec<NapiPending> {
    var out: Vec<NapiPending> = Vec.new()
    while gNapi.pending.len() > 0 {
        out.push(gNapi.pending.remove(0))
    }
    return out
}

@export
fn napi_create_promise(_env: *u8, deferred: *u8, promise: *u8): i32 {
    let p = newPromise(gInterp, 0, JSValue.Undefined)
    gNapi.liveDeferred = gNapi.liveDeferred + 1
    napiWriteHandle(deferred, napiHandle(JSValue.Obj(p)))
    napiWriteHandle(promise, napiHandle(JSValue.Obj(p)))
    return NAPI_OK
}

@export
fn napi_resolve_deferred(_env: *u8, deferred: i64, resolution: i64): i32 {
    match napiValueOf(deferred) {
        JSValue.Obj(p) => {
            napiSettle(p, 1, napiValueOf(resolution))
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

@export
fn napi_reject_deferred(_env: *u8, deferred: i64, rejection: i64): i32 {
    match napiValueOf(deferred) {
        JSValue.Obj(p) => {
            napiSettle(p, 2, napiValueOf(rejection))
            return NAPI_OK
        }
        _ => {
            return NAPI_INVALID_ARG
        }
    }
}

// ── threadsafe functions ──
//
// Prisma runs a tokio worker pool and settles its promises from those threads.
// A worker must never touch the interpreter, so napi_call_threadsafe_function does
// exactly one thing: write the queued call into a self-pipe. The event loop drains
// it on the main thread, where calling into JS is safe.
//
// No mutex is needed. A write of <= PIPE_BUF is atomic, so concurrent workers cannot
// interleave within a record.

fn napiEnsurePipe() {
    if gNapi.tsfnR >= 0 {
        return
    }
    unsafe {
        var fds: [i32; 2] = [0; 2]
        if pipe(fds as *u8) != 0 {
            return
        }
        // fd 0/1 would mean pipe() never wrote the array: reading stdin returns EOF
        // and writing "succeeds" straight to the terminal, so the queue silently
        // never delivers. Refuse rather than run in that state.
        if fds[0] <= 2 || fds[1] <= 2 {
            return
        }
        // the loop polls; a blocking read would stall the whole interpreter
        let _r = setNonblocking(fds[0])
        gNapi.tsfnR = fds[0]
        gNapi.tsfnW = fds[1]
    }
}

@export
fn napi_create_threadsafe_function(_env: *u8, func: i64, _asyncResource: i64, _asyncResourceName: i64, _maxQueueSize: i64, _initialThreadCount: i64, _threadFinalizeData: i64, _threadFinalizeCb: i64, context: i64, callJsCb: i64, result: *u8): i32 {
    napiEnsurePipe()
    var initialRefs = _initialThreadCount
    if initialRefs < 1 {
        initialRefs = 1
    }
    gNapi.tsfns.push(NapiTsfn {
        jsFunc: napiValueOf(func), callJsCb: callJsCb, context: context, refs: initialRefs, unrefed: false
    }
    )
    // the opaque handle is 1-based so a valid tsfn is never a null pointer
    napiWriteHandle(result, gNapi.tsfns.len())
    return NAPI_OK
}

// CALLED FROM A FOREIGN THREAD. Touch nothing but the pipe fd, which is read-only
// after setup.
@export
fn napi_call_threadsafe_function(func: i64, data: i64, _isBlocking: i32): i32 {
    unsafe {
        if gNapi.tsfnW < 0 {
            return NAPI_INVALID_ARG
        }
        var rec: [i64; 2] = [func; 2]
        rec[1] = data
        let n = write(gNapi.tsfnW, rec as *u8, 16)
        if n != 16 {
            return NAPI_INVALID_ARG
        }
    }
    return NAPI_OK
}

@export
fn napi_get_threadsafe_function_context(func: i64, result: *u8): i32 {
    let i = func - 1
    if i < 0 || i >= gNapi.tsfns.len() {
        return NAPI_INVALID_ARG
    }
    napiWriteHandle(result, gNapi.tsfns[i].context)
    return NAPI_OK
}

@export
fn napi_acquire_threadsafe_function(_func: i64): i32 {
    let i = _func - 1
    if i >= 0 && i < gNapi.tsfns.len() {
        gNapi.tsfns[i].refs = gNapi.tsfns[i].refs + 1
    }
    return NAPI_OK
}

@export
fn napi_release_threadsafe_function(_func: i64, _mode: i32): i32 {
    let i = _func - 1
    if i >= 0 && i < gNapi.tsfns.len() {
        // mode 1 is napi_tsfn_abort: drop every outstanding reference at once
        if _mode == 1 {
            gNapi.tsfns[i].refs = 0
        } else if gNapi.tsfns[i].refs > 0 {
            gNapi.tsfns[i].refs = gNapi.tsfns[i].refs - 1
        }
    }
    return NAPI_OK
}

@export
fn napi_unref_threadsafe_function(_env: *u8, _func: i64): i32 {
    let i = _func - 1
    if i >= 0 && i < gNapi.tsfns.len() {
        gNapi.tsfns[i].unrefed = true
    }
    return NAPI_OK
}

@export
fn napi_ref_threadsafe_function(_env: *u8, _func: i64): i32 {
    let i = _func - 1
    if i >= 0 && i < gNapi.tsfns.len() {
        gNapi.tsfns[i].unrefed = false
    }
    return NAPI_OK
}

// One queued threadsafe call, taken off the pipe on the main thread.
struct NapiTsfnCall {
    tsfn: i64,
    data: i64,
}

// Non-blocking drain. Returns the calls that were waiting.
fn napiPollTsfn(): Vec<NapiTsfnCall> {
    var out: Vec<NapiTsfnCall> = Vec.new()
    if gNapi.tsfnR < 0 {
        return out
    }
    unsafe {
        var going = true
        while going {
            var rec: [i64; 2] = [0; 2]
            let n = read(gNapi.tsfnR, rec as *u8, 16)
            if n == 16 {
                out.push(NapiTsfnCall {
                    tsfn: rec[0], data: rec[1]
                }
                )
            } else {
                going = false
            }
        }
    }
    return out
}

// Run one queued call on the main thread. When the addon supplied a call_js_cb it
// owns the dispatch entirely (that is where it converts `data` into JS values);
// otherwise the spec says to invoke the JS function with no arguments.
fn napiRunTsfnCall(c: &NapiTsfnCall): JSValue {
    let i = c.tsfn - 1
    if i < 0 || i >= gNapi.tsfns.len() {
        return JSValue.Undefined
    }
    let cb = gNapi.tsfns[i].callJsCb
    if cb != 0 {
        let jsh = napiHandle(cloneValue(gNapi.tsfns[i].jsFunc))
        unsafe {
            let f = (cb as *u8) as extern (*u8, i64, i64, i64) => void
            f(0 as *u8, jsh, gNapi.tsfns[i].context, c.data)
        }
        return JSValue.Undefined
    }
    return cloneValue(gNapi.tsfns[i].jsFunc)
}

extern fn usleep(_usec: u32): i32

// Yield the CPU while waiting on an addon's worker thread. Polling flat out would
// burn a core for the whole duration of a query.
fn napiWaitBriefly() {
    unsafe {
        let _r = usleep(200 as u32)
    }
}

fn napiHasTsfn(): bool {
    return gNapi.tsfns.len() > 0
}
