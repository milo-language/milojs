// The tree-walking evaluator: walks the AST (by index into Prog) and produces
// JSValues, driving the runtime's scopes, object heap, and GC. Statement
// execution returns a Flow so `return` can unwind out of nested blocks.

from "./ast" import {
    Prog, gProg
}
from "./value" import {
    JSValue, i64ToStr, daysFromCivil
}
from "./runtime" import {
    Interp, Timer, Microtask, Reaction, PendingFetch, NATIVE_RESOLVER_BASE, collect, linkProtoConstructor, objHasInChain
}
from "./builtins" import {
    stringMethod, jsCharAt, mjStringifyVal, mjJsonParse, mjJsonOmitted
}
from "./bigint" import {
    bigNormalizeDec, bnAdd, bnSub, bnMul, bnDiv, bnMod, bnPow, bnNeg, bnCmp, bnFromF64, bnToRadix, bnFromRadix, isDecimalIntStr
}
from "./regex" import {
    regexCompile, regexExec
}
from "std/io" import {
    readFile
}
from "./modules" import {
    dirOf, resolveSpec, findModule, reportUnresolved
}
from "std/os" import {
    exit
}
from "std/env" import {
    getEnv
}
from "std/runtime" import {
    _spawnOsThreadDetached, schedulerCurrent, schedulerPark, schedulerUnpark, schedulerYield, Task
}
