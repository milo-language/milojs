}
from "std/fs" import {
    currentDir, writeFile, appendFile, readDir, removeFile, makeDir, removeDir, renameFile, isDir
}
from "./napi" import {
    napiInvoke, napiLoadAddon, napiTakePending, napiPollTsfn, napiRunTsfnCall, napiHasTsfn, napiHasPendingWork, napiMayDeliver, napiWaitBriefly
}
from "std/math" import {
    mathMod, mathPow
}

enum Flow {
    Normal,
    Ret(JSValue),
    // loop control; these never escape a function boundary. The string is the
    // target label, "" when unlabeled. A loop consumes an unlabeled signal or
    // one naming its own label, and re-propagates any other so an outer labeled
    // loop can catch it.
    Break(string),
    Continue(string),
}

fn evalBin(op: &string, a: &JSValue, b: &JSValue): JSValue {
    if op == "+" {
        if isStr(a) || isStr(b) {
            return JSValue.Str(toStr(a) + toStr(b))
        }
        return JSValue.Number(toNum(a) + toNum(b))
    }
    if op == "-" {
        return JSValue.Number(toNum(a) - toNum(b))
    }
    if op == "*" {
        return JSValue.Number(toNum(a) * toNum(b))
    }
    if op == "/" {
        return JSValue.Number(toNum(a) / toNum(b))
    }
    if op == "%" {
        return JSValue.Number(mathMod(toNum(a), toNum(b)))
    }
    if op == "**" {
        return JSValue.Number(mathPow(toNum(a), toNum(b)))
    }
    if op == "&" {
        return JSValue.Number((toInt32(a) & toInt32(b)) as f64)
    }
    if op == "|" {
        return JSValue.Number((toInt32(a) | toInt32(b)) as f64)
    }
    if op == "^" {
        return JSValue.Number((toInt32(a) ^ toInt32(b)) as f64)
    }
    if op == "<<" || op == ">>" || op == ">>>" {
        // JS masks the shift count to 5 bits; >>> is the only unsigned one
        let sh = toUint32(b) & 31
        if op == ">>>" {
            return JSValue.Number((toUint32(a) >> sh) as f64)
        }
        let lhs = toInt32(a)
        if op == ">>" {
            return JSValue.Number((lhs >> sh) as f64)
        }
        var r = (lhs << sh) & 4294967295
        if r >= 2147483648 {
            r = r - 4294967296
        }
        return JSValue.Number(r as f64)
    }
    if op == "==" {
        return JSValue.Bool(jsEquals(a, b))
    }
    if op == "!=" {
        return JSValue.Bool(!jsEquals(a, b))
    }
    if op == "===" {
        return JSValue.Bool(jsStrictEquals(a, b))
    }
    if op == "!==" {
        return JSValue.Bool(!jsStrictEquals(a, b))
    }
    // relational: string<string is lexicographic, else numeric (NaN → false)
    if isStr(a) && isStr(b) {
        let sa = toStr(a)
        let sb = toStr(b)
        if op == "<" {
            return JSValue.Bool(strLess(sa, sb))
        }
        if op == ">" {
            return JSValue.Bool(strLess(sb, sa))
        }
        if op == "<=" {
            return JSValue.Bool(!strLess(sb, sa))
        }
        if op == ">=" {
            return JSValue.Bool(!strLess(sa, sb))
        }
    }
    let x = toNum(a)
    let y = toNum(b)
    if op == "<" {
        return JSValue.Bool(x < y)
    }
    if op == ">" {
        return JSValue.Bool(x > y)
    }
    if op == "<=" {
        return JSValue.Bool(x <= y)
    }
    if op == ">=" {
        return JSValue.Bool(x >= y)
    }
    return JSValue.Undefined
}

// Property read that understands arrays: `length` and integer indices hit the
// element vector, everything else the string-keyed props.
// Getter for `key` on `o` or anywhere up its prototype chain, else Undefined.
// Kept separate from getMember because invoking a getter needs the program and a
// mutable interpreter, which the plain reader does not have.
fn findGetter(st: &Interp, o: i64, key: &string): JSValue {
    var cur = o
    while cur >= 0 {
        let idx = objOwnIndex(st, cur, key)
        if idx >= 0 {
            if st.objects[cur].props[idx].isAccessor {
                return cloneValue(st.objects[cur].props[idx].getter)
            }
            return JSValue.Undefined
        }
        cur = st.objects[cur].proto
    }
    return JSValue.Undefined
}

fn findSetter(st: &Interp, o: i64, key: &string): JSValue {
    var cur = o
    while cur >= 0 {
        let idx = objOwnIndex(st, cur, key)
        if idx >= 0 {
            if st.objects[cur].props[idx].isAccessor {
                return cloneValue(st.objects[cur].props[idx].setter)
            }
            return JSValue.Undefined
        }
        cur = st.objects[cur].proto
    }
    return JSValue.Undefined
}

// Property read that honours accessors; `this` inside the getter is the object.
// Array.prototype.join / toString, prog-free so string-coercion paths (which have
// no Prog) can reuse it. Nested arrays join recursively; null/undefined render
// empty; every other element goes through toStr (plain objects -> [object Object]).
fn joinArray(st: &mut Interp, o: i64, sep: &string): string {
    var out = ""
    var i: i64 = 0
    let n = arrLen(st, o)
    while i < n {
        if i > 0 {
            out = out + sep
        }
        let e = arrGet(st, o, i)
        match e {
            JSValue.Null => {
            }
            JSValue.Undefined => {
            }
            _ => {
                let eh = objHandle(e)
                if eh >= 0 && st.objects[eh].isArray {
                    out = out + joinArray(st, eh, sep)
                } else {
                    out = out + toStr(e)
                }
            }
        }
        i = i + 1
    }
    return out
}

// JS ToPrimitive with the "default" hint (used by `+`): try valueOf, then
// toString, taking the first that yields a primitive. Arrays and plain objects
// valueOf to themselves, so toString decides — arrays join, plain objects give
// "[object Object]". A non-object value is already primitive.
// ToPrimitive with the NUMBER hint (used by arithmetic/relational operators).
// The only object whose number-hint result differs from the default here is a
// Date: default hint (used by `+`) stringifies it, number hint yields its epoch
// milliseconds. Everything else follows the same valueOf-then-toString path.
// A user-defined [Symbol.toPrimitive](hint) takes precedence over valueOf/
// toString. Returns Option.Some(primitive) when the method exists, else None so
// the caller falls through to the ordinary coercion.
fn trySymToPrimitive(prog: &Prog, h: i64, hint: &string, st: &mut Interp): Option<JSValue> {
    let m = getMemberDyn(prog, h, symToPrimitiveKey(), st)
    if isCallableIn(st, m) {
        pushTemp(st, JSValue.Obj(h))
        var args: Vec<JSValue> = Vec.new()
        args.push(JSValue.Str(hint.clone()))
        let r = callValue(prog, m, args, JSValue.Obj(h), st)
        popTemp(st)
        return Option.Some(r)
    }
    return Option.None
}

fn toPrimitiveNumber(prog: &Prog, v: &JSValue, st: &mut Interp): JSValue {
    let h = objHandle(v)
    if h >= 0 {
        match trySymToPrimitive(prog, h, "number", st) {
            Option.Some(r) => {
                return r
            }
            Option.None => {
            }
        }
        if st.objects[h].isDate {
            return JSValue.Number(st.objExtras[st.objects[h].extra].dateMs)
        }
    }
    return toPrimitiveDefault(prog, v, st)
}

fn toPrimitiveDefault(prog: &Prog, v: &JSValue, st: &mut Interp): JSValue {
    let h = objHandle(v)
    if h < 0 {
        return cloneValue(v)
    }
    match trySymToPrimitive(prog, h, "default", st) {
        Option.Some(r) => {
            return r
        }
        Option.None => {
        }
    }
    // arrays join directly — reading their toString as a bound value does not
    // route back to the join, so short-circuit here
    if st.objects[h].isArray {
        return JSValue.Str(joinArray(st, h, ","))
    }
    pushTemp(st, JSValue.Obj(h))
    let vf = getMemberDyn(prog, h, "valueOf", st)
    if isCallableIn(st, vf) {
        var noA: Vec<JSValue> = Vec.new()
        let r = callValue(prog, vf, noA, JSValue.Obj(h), st)
        if objHandle(r) < 0 && funcHandle(r) < 0 {
            popTemp(st)
            return r
        }
    }
    let tf = getMemberDyn(prog, h, "toString", st)
    if isCallableIn(st, tf) {
        var noB: Vec<JSValue> = Vec.new()
        let r2 = callValue(prog, tf, noB, JSValue.Obj(h), st)
        if objHandle(r2) < 0 && funcHandle(r2) < 0 {
            popTemp(st)
            return r2
        }
    }
    popTemp(st)
    return JSValue.Str("[object Object]")
}

fn getMemberDyn(prog: &Prog, o: i64, key: &string, st: &mut Interp): JSValue {
    if st.objects[o].isProxy {
        let trap = proxyTrap(st, o, "get")
        let target = cloneValue(st.objExtras[st.objects[o].extra].proxyTarget)
        if isCallableIn(st, trap) {
            var args: Vec<JSValue> = Vec.new()
            args.push(cloneValue(target))
            args.push(JSValue.Str(key.clone()))
            args.push(JSValue.Obj(o))
            return callValue(prog, trap, args, cloneValue(st.objExtras[st.objects[o].extra].proxyHandler), st)
        }
        // no trap: forward to the target
        let th = objHandle(target)
        if th >= 0 {
            return getMemberDyn(prog, th, key, st)
        }
        return JSValue.Undefined
    }
    // promise.then/catch/finally dispatch natively, so reading them as VALUES
    // returned undefined. The standard thenable test every library uses is
    // `typeof x.then === "function"`, which that silently failed — hand back a
    // bound method instead.
    if objOwnIndex(st, o, key) < 0 {
        // obj.__proto__ mirrors Object.getPrototypeOf (a Object.prototype accessor
        // in the spec); resolve it through the same type-based helper
        if key == "__proto__" {
            let pp = protoOfHandle(st, o)
            if pp >= 0 {
                return JSValue.Obj(pp)
            }
            return JSValue.Null
        }
        // builtin methods are dispatched by name, not stored as properties, so
        // reading one as a value needs a bound method synthesised here
        if st.objects[o].promiseState >= 0 && (key == "then" || key == "catch" || key == "finally") {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if (st.objects[o].isMap || st.objects[o].isSet) && isMapSetMethodName(key) {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objExtras[st.objects[o].extra].regexId >= 0 && isRegexMethodName(key) {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objects[o].isArrayBuffer && (key == "slice" || key == "resize" || key == "transfer") {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objects[o].isDataView && isDataViewMethodName(key) {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objects[o].isGenerator && (key == "next" || key == symIteratorKey()) {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objExtras[st.objects[o].extra].taBuf >= 0 && isTypedArrayMethodName(key) {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objects[o].isArray && isArrayMethod(key) {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        // every object inherits these from Object.prototype, including the
        // built-in constructors — `Object.hasOwnProperty.call(x, k)` is a common
        // way to borrow the method, and it read as undefined before
        if key == "hasOwnProperty" || key == "isPrototypeOf" || key == "propertyIsEnumerable" {
            if !objHasInChain(st, o, key) {
                return makeBoundMethod(st, JSValue.Obj(o), key.clone())
            }
        }
        if st.objects[o].isError && (key == "toString" || key == "valueOf") {
            return makeBoundMethod(st, JSValue.Obj(o), key.clone())
        }
        if st.objects[o].isDate {
            for dn in dateProtoMethodNames() {
                if dn == key {
                    return makeBoundMethod(st, JSValue.Obj(o), key.clone())
                }
            }
        }
    }
    // arr[Symbol.iterator] — a bound `values`, so arr[Symbol.iterator]() yields
    // the same iterator for-of drives. Lives here rather than in getMember
    // because building the bound method allocates and getMember is immutable.
    if st.objects[o].isArray && key == symIteratorKey() && objOwnIndex(st, o, key) < 0 {
        return makeBoundMethod(st, JSValue.Obj(o), "values")
    }
    // globalThis.x reads the global binding, so it stays in step with bare `x`
    if st.objects[o].isGlobal && objOwnIndex(st, o, key) < 0 {
        if scopeHasOwn(st, 0, key) {
            return scopeLookup(st, 0, key)
        }
    }
    if st.objects[o].isEnv && objOwnIndex(st, o, key) < 0 {
        match getEnv(key.clone()) {
            Option.Some(v) => {
                let val = JSValue.Str(v)
                objSet(st, o, key.clone(), cloneValue(val))
                return val
            }
            Option.None => {
                return JSValue.Undefined
            }
        }
    }
    if (st.objects[o].isMap || st.objects[o].isSet) && key == "size" {
        return JSValue.Number(st.objExtras[st.objects[o].extra].mapKeys.len() as f64)
    }
    let g = findGetter(st, o, key)
    if isCallable(g) {
        var noArgs: Vec<JSValue> = Vec.new()
        return callValue(prog, g, noArgs, JSValue.Obj(o), st)
    }
    let direct = getMember(st, o, key)
    // Builtin methods are dispatched by name at the call site, so they have no
    // value form. Reading one (var slice = [].slice) hands back a bound-method
    // object that remembers the receiver, so .call/.apply still work.
    if isUndefinedValue(direct) && st.objects[o].isArray && isArrayMethod(key) {
        return makeBoundMethod(st, JSValue.Obj(o), key.clone())
    }
    // `constructor` fallback for builtins whose faked prototype chain has none.
    // Only when the chain gave nothing, so a user constructor is never shadowed.
    if isUndefinedValue(direct) && key == "constructor" {
        let c = builtinConstructorOf(st, o)
        if !isUndefinedValue(c) {
            return c
        }
    }
    return direct
}

fn isUndefinedValue(v: &JSValue): bool {
    match v {
        JSValue.Undefined => {
            return true
        }
        _ => {
            return false
        }
    }
}

fn makeBoundMethod(st: &mut Interp, recv: JSValue, name: string): JSValue {
    let bo = newObject(st)
    st.objects[bo].isBound = true
    let ex = ensureExtra(st, bo)
    st.objExtras[ex].boundThis = recv
    st.objExtras[ex].boundMethod = name
    return JSValue.Obj(bo)
}

// An array iterator: a plain object holding the source array plus a cursor, with
// `next` and `[Symbol.iterator]` as bound builtin methods. Built this way because
// a native has no per-instance state and JSValue has nowhere to carry a cursor.
// kind: 0 values, 1 keys, 2 entries.
fn makeArrayIterator(st: &mut Interp, arr: i64, kind: i64): JSValue {
    let it = newObject(st)
    pushTemp(st, JSValue.Obj(it))
    objSet(st, it, "__ai_arr", JSValue.Obj(arr))
    objSet(st, it, "__ai_i", JSValue.Number(0.0))
    objSet(st, it, "__ai_kind", JSValue.Number(kind as f64))
    let nextFn = makeBoundMethod(st, JSValue.Obj(it), "__arrayIterNext")
    objSet(st, it, "next", nextFn)
    let selfFn = makeBoundMethod(st, JSValue.Obj(it), "__arrayIterSelf")
    objSet(st, it, symIteratorKey(), selfFn)
    if st.iterProtoObj >= 0 {
        st.objects[it].proto = st.iterProtoObj
    }
    popTemp(st)
    return JSValue.Obj(it)
}

fn arrayIterNext(st: &mut Interp, it: i64): JSValue {
    let arrV = getMember(st, it, "__ai_arr")
    let arr = objHandle(arrV)
    let i = toNum(getMember(st, it, "__ai_i")) as i64
    let kind = toNum(getMember(st, it, "__ai_kind")) as i64
    let res = newObject(st)
    pushTemp(st, JSValue.Obj(res))
    if arr < 0 || i >= arrLen(st, arr) {
        objSet(st, res, "done", JSValue.Bool(true))
        objSet(st, res, "value", JSValue.Undefined)
    } else {
        objSet(st, it, "__ai_i", JSValue.Number((i + 1) as f64))
        var v = arrGet(st, arr, i)
        if kind == 1 {
            v = JSValue.Number(i as f64)
        } else if kind == 2 {
            let pair = newArray(st)
            pushTemp(st, JSValue.Obj(pair))
            arrPush(st, pair, JSValue.Number(i as f64))
            arrPush(st, pair, arrGet(st, arr, i))
            popTemp(st)
            v = JSValue.Obj(pair)
        }
        objSet(st, res, "value", v)
        objSet(st, res, "done", JSValue.Bool(false))
    }
    popTemp(st)
    return JSValue.Obj(res)
}

// new <T>Array(n | buffer | array) — allocates its own buffer except when handed
// an existing ArrayBuffer, which it views in place (mutations are shared).
fn makeTypedArray(st: &mut Interp, kind: i64, args: &Vec<JSValue>): JSValue {
    let w = taWidth(kind)
    var bufH: i64 = -1
    var viewOffset: i64 = 0
    var len: i64 = 0
    var seed: Vec<f64> = Vec.new()
    if args.len() > 0 {
        let h = objHandle(args[0])
        if h >= 0 && st.objects[h].isArrayBuffer {
            bufH = h
            // new T(buffer, byteOffset, length) — a window into the buffer, not
            // necessarily the whole thing
            var boff: i64 = 0
            if args.len() > 1 {
                boff = toNum(args[1]) as i64
                if boff < 0 {
                    boff = 0
                }
            }
            let avail = st.objExtras[st.objects[h].extra].bytes.len() - boff
            var count = avail / w
            if count < 0 {
                count = 0
            }
            if args.len() > 2 {
                let want = toNum(args[2]) as i64
                if want >= 0 && want < count {
                    count = want
                }
            }
            viewOffset = boff
            len = count
        } else if h >= 0 && st.objects[h].isArray {
            var i: i64 = 0
            while i < arrLen(st, h) {
                seed.push(toNum(arrGet(st, h, i)))
                i = i + 1
            }
            len = seed.len()
        } else if h >= 0 && st.objExtras[st.objects[h].extra].taBuf >= 0 {
            // from another typed array: copy the element values
            var i: i64 = 0
            while i < st.objExtras[st.objects[h].extra].taLen {
                seed.push(taElem(st, h, i))
                i = i + 1
            }
            len = seed.len()
        } else {
            len = toNum(args[0]) as i64
            if len < 0 {
                len = 0
            }
        }
    }
    if bufH < 0 {
        let nb = newObject(st)
        st.objects[nb].isArrayBuffer = true
        let _e = ensureExtra(st, nb)
        var b: Vec<u8> = Vec.new()
        var i: i64 = 0
        while i < len * w {
            b.push(0 as u8)
            i = i + 1
        }
        st.objExtras[st.objects[nb].extra].bytes = b
        bufH = nb
    }
    let view = newObject(st)
    let _ev = ensureExtra(st, view)
    st.objExtras[st.objects[view].extra].taBuf = bufH
    st.objExtras[st.objects[view].extra].taKind = kind
    st.objExtras[st.objects[view].extra].taOffset = viewOffset
    st.objExtras[st.objects[view].extra].taLen = len
    var k: i64 = 0
    while k < seed.len() {
        taSetElem(st, view, k, seed[k])
        k = k + 1
    }
    return JSValue.Obj(view)
}

fn taElem(st: &Interp, view: i64, i: i64): f64 {
    let buf = st.objExtras[st.objects[view].extra].taBuf
    if buf < 0 || i < 0 || i >= st.objExtras[st.objects[view].extra].taLen {
        return 0.0
    }
    let w = taWidth(st.objExtras[st.objects[view].extra].taKind)
    let at = st.objExtras[st.objects[view].extra].taOffset + i * w
    // the backing buffer may have been resized/detached under this view (a sort
    // comparator or a length getter can do it) — out-of-range reads yield 0
    if at < 0 || at + w > st.objExtras[st.objects[buf].extra].bytes.len() {
        return 0.0
    }
    return taLoad(st.objExtras[st.objects[buf].extra].bytes, st.objExtras[st.objects[view].extra].taKind, at)
}

fn taSetElem(st: &mut Interp, view: i64, i: i64, v: f64) {
    let buf = st.objExtras[st.objects[view].extra].taBuf
    if buf < 0 || i < 0 || i >= st.objExtras[st.objects[view].extra].taLen {
        return
    }
    let kind = st.objExtras[st.objects[view].extra].taKind
    let w = taWidth(kind)
    let at = st.objExtras[st.objects[view].extra].taOffset + i * w
    // a resized/detached buffer drops the write rather than overflowing its bytes
    if at < 0 || at + w > st.objExtras[st.objects[buf].extra].bytes.len() {
        return
    }
    taStore(st.objExtras[st.objects[buf].extra].bytes, kind, at, v)
}

// Invoke a builtin method by name against an already-evaluated receiver+args.
fn callBuiltinByName(prog: &Prog, recv: &JSValue, name: &string, args: Vec<JSValue>, st: &mut Interp): JSValue {
    // Object.prototype.toString applied to ANY receiver, ignoring overrides
    if name == "@@objProtoToString" {
        let o = objHandle(recv)
        if o >= 0 {
            // a user [Symbol.toStringTag] (a plain string, possibly via a getter)
            // wins over the built-in tag: class { get [Symbol.toStringTag](){…} }
            let tag = getMemberDyn(prog, o, symToStringTagKey(), st)
            match tag {
                JSValue.Str(ts) => {
                    if !isSymbolStr(ts) {
                        return JSValue.Str("[object " + ts + "]")
                    }
                }
                _ => {
                }
            }
            return JSValue.Str("[object " + objectTag(st, o) + "]")
        }
        return JSValue.Str("[object " + objectTypeTag(recv) + "]")
    }
    match recv {
        JSValue.Str(sv) => {
            if isSymbolStr(sv) && name == "toString" {
                return JSValue.Str(symbolDisplay(sv))
            }
            return stringMethod(name, sv, args, st)
        }
        JSValue.Obj(o) => {
            // array iterator steps: state lives in properties on the iterator
            // object itself, which is also the bound receiver
            if name == "__arrayIterNext" {
                return arrayIterNext(st, o)
            }
            if name == "__arrayIterSelf" {
                return JSValue.Obj(o)
            }
            if st.objects[o].isArrayBuffer {
                if name == "resize" {
                    var to: i64 = 0
                    if args.len() > 0 {
                        to = toNum(args[0]) as i64
                    }
                    // only a buffer created with {maxByteLength} may resize, and
                    // only within [0, cap]
                    if st.objExtras[st.objects[o].extra].abMaxLen < 0 || to < 0 || to > st.objExtras[st.objects[o].extra].abMaxLen {
                        st.throwing = true
                        st.thrownValue = makeError(st, "RangeError", "ArrayBuffer.prototype.resize: invalid length")
                        return JSValue.Undefined
                    }
                    var b: Vec<u8> = Vec.new()
                    var ci: i64 = 0
                    while ci < to {
                        if ci < st.objExtras[st.objects[o].extra].bytes.len() {
                            b.push(st.objExtras[st.objects[o].extra].bytes[ci])
                        } else {
                            b.push(0 as u8)
                        }
                        ci = ci + 1
                    }
                    st.objExtras[st.objects[o].extra].bytes = b
                    return JSValue.Undefined
                }
                if name == "transfer" {
                    let nb = newObject(st)
                    st.objects[nb].isArrayBuffer = true
                    let _e = ensureExtra(st, nb)
                    var tb: Vec<u8> = Vec.new()
                    var ti: i64 = 0
                    while ti < st.objExtras[st.objects[o].extra].bytes.len() {
                        tb.push(st.objExtras[st.objects[o].extra].bytes[ti])
                        ti = ti + 1
                    }
                    st.objExtras[st.objects[nb].extra].bytes = tb
                    st.objExtras[st.objects[nb].extra].abMaxLen = st.objExtras[st.objects[o].extra].abMaxLen
                    st.objExtras[st.objects[o].extra].bytes = Vec.new()
                    st.objects[o].abDetached = true
                    return JSValue.Obj(nb)
                }
                if name == "slice" {
                    let n = st.objExtras[st.objects[o].extra].bytes.len()
                    var a: i64 = 0
                    if args.len() > 0 {
                        a = toNum(args[0]) as i64
                    }
                    if a < 0 {
                        a = n + a
                    }
                    var e = n
                    if args.len() > 1 {
                        e = toNum(args[1]) as i64
                        if e < 0 {
                            e = n + e
                        }
                    }
                    if a < 0 {
                        a = 0
                    }
                    if e > n {
                        e = n
                    }
                    let nb = newObject(st)
                    st.objects[nb].isArrayBuffer = true
                    let _e = ensureExtra(st, nb)
                    var b: Vec<u8> = Vec.new()
                    var i = a
                    while i < e {
                        b.push(st.objExtras[st.objects[o].extra].bytes[i])
                        i = i + 1
                    }
                    st.objExtras[st.objects[nb].extra].bytes = b
                    return JSValue.Obj(nb)
                }
            }
            // Date-specific methods dispatch here (Date.prototype.toISOString.call);
            // toString/valueOf are left to the Object.prototype type-tag logic
            // below, so Object.prototype.toString.call(date) stays [object Date]
            if st.objects[o].isDate && name != "toString" && name != "valueOf" {
                return dateMethod(st, o, name, args)
            }
            if st.objects[o].isMap || st.objects[o].isSet {
                return mapMethod(prog, o, name, args, st)
            }
            // a bound regex/buffer/typed-array method re-dispatches through here,
            // so these must be reachable or an extracted method silently does
            // nothing (no throw, no result — the process just unwinds)
            if st.objExtras[st.objects[o].extra].regexId >= 0 && isRegexMethodName(name) {
                return regexMethod(st, o, name, args)
            }
            if st.objects[o].isDataView && isDataViewMethodName(name) {
                return dataViewMethod(o, name, args, st)
            }
            if st.objects[o].isGenerator {
                if name == "next" {
                    return genNext(o, args, st)
                }
                // a generator is its own iterator: gen[Symbol.iterator]() === gen
                if name == symIteratorKey() {
                    return JSValue.Obj(o)
                }
            }
            if st.objExtras[st.objects[o].extra].taBuf >= 0 && isTypedArrayMethodName(name) {
                return typedArrayMethod(prog, o, name, args, st)
            }

            if name == "hasOwnProperty" {
                var key = ""
                if args.len() > 0 {
                    key = toStr(args[0])
                }
                return JSValue.Bool(objOwnIndex(st, o, key) >= 0 || (st.objects[o].isArray && asArrayIndex(key) >= 0 && asArrayIndex(key) < arrLen(st, o) && !arrIsHole(st, o, asArrayIndex(key))))
            }
            if name == "toString" {
                if st.objects[o].isArray {
                    return JSValue.Str("[object Array]")
                }
                if st.objects[o].isError {
                    return JSValue.Str("[object Error]")
                }
                if st.objects[o].isDate {
                    return JSValue.Str("[object Date]")
                }
                return JSValue.Str("[object Object]")
            }
            if name == "valueOf" {
                return JSValue.Obj(o)
            }
            if name == "isPrototypeOf" {
                if args.len() == 0 {
                    return JSValue.Bool(false)
                }
                let other = objHandle(args[0])
                if other < 0 {
                    return JSValue.Bool(false)
                }
                var pcur = st.objects[other].proto
                while pcur >= 0 {
                    if pcur == o {
                        return JSValue.Bool(true)
                    }
                    pcur = st.objects[pcur].proto
                }
                return JSValue.Bool(false)
            }
            if name == "propertyIsEnumerable" {
                var key = ""
                if args.len() > 0 {
                    key = toStr(args[0])
                }
                // own AND enumerable — a non-enumerable own prop is still `false`
                let pi = objOwnIndex(st, o, key)
                return JSValue.Bool(pi >= 0 && st.objects[o].props[pi].enumerable)
            }
            if st.objects[o].isArray && isArrayMethod(name) {
                return arrayMethod(prog, o, name, args, st)
            }
            let m = getMemberDyn(prog, o, name, st)
            return callValue(prog, m, args, JSValue.Obj(o), st)
        }
        JSValue.Func(bf, benv) => {
            if name == "toString" {
                let fname = prog.funcs[bf].name.clone()
                return JSValue.Str("function " + fname + "() { [native code] }")
            }
            if name == "hasOwnProperty" {
                var key = ""
                if args.len() > 0 {
                    key = toStr(args[0])
                }
                let statics = getFuncStatics(st, bf, benv)
                return JSValue.Bool(objOwnIndex(st, statics, key) >= 0)
            }
            // Function.prototype.apply.call(fn, thisArg, args) lands here with
            // recv = fn: re-dispatch against the function itself
            if name == "call" || name == "apply" {
                var thisArg = JSValue.Undefined
                if args.len() > 0 {
                    thisArg = cloneValue(args[0])
                }
                var rest: Vec<JSValue> = Vec.new()
                if name == "apply" {
                    if args.len() > 1 {
                        let ah = objHandle(args[1])
                        if ah >= 0 && st.objects[ah].isArray {
                            var ai: i64 = 0
                            while ai < arrLen(st, ah) {
                                rest.push(arrGet(st, ah, ai))
                                ai = ai + 1
                            }
                        }
                    }
                } else {
                    var ai: i64 = 1
                    while ai < args.len() {
                        rest.push(cloneValue(args[ai]))
                        ai = ai + 1
                    }
                }
                return callFunction(prog, bf, benv, rest, thisArg, st)
            }
            if name == "bind" {
                let bo = newObject(st)
                st.objects[bo].isBound = true
                var extra: Vec<JSValue> = Vec.new()
                var bi: i64 = 1
                while bi < args.len() {
                    extra.push(cloneValue(args[bi]))
                    bi = bi + 1
                }
                let ex = ensureExtra(st, bo)
                st.objExtras[ex].boundTarget = JSValue.Func(bf, benv)
                if args.len() > 0 {
                    st.objExtras[ex].boundThis = cloneValue(args[0])
                }
                st.objExtras[ex].boundArgs = extra
                return JSValue.Obj(bo)
            }
            let statics = getFuncStatics(st, bf, benv)
            let m = getMember(st, statics, name)
            if isCallable(m) {
                return callValue(prog, m, args, JSValue.Func(bf, benv), st)
            }
            return JSValue.Undefined
        }
        _ => {
            // .apply / .call / .bind on a native function (Math.max.apply, …).
            // recv is the function; re-dispatch it through callValue, which
            // routes a Native to callNative.
            if name == "apply" || name == "call" {
                var thisArg = JSValue.Undefined
                if args.len() > 0 {
                    thisArg = cloneValue(args[0])
                }
                var rest: Vec<JSValue> = Vec.new()
                if name == "apply" {
                    if args.len() > 1 {
                        let ah = objHandle(args[1])
                        if ah >= 0 && st.objects[ah].isArray {
                            var ai: i64 = 0
                            while ai < arrLen(st, ah) {
                                rest.push(arrGet(st, ah, ai))
                                ai = ai + 1
                            }
                        }
                    }
                } else {
                    var ai: i64 = 1
                    while ai < args.len() {
                        rest.push(cloneValue(args[ai]))
                        ai = ai + 1
                    }
                }
                return callValue(prog, recv, rest, thisArg, st)
            }
            if name == "bind" {
                let bo = newObject(st)
                st.objects[bo].isBound = true
                var extra: Vec<JSValue> = Vec.new()
                var bi: i64 = 1
                while bi < args.len() {
                    extra.push(cloneValue(args[bi]))
                    bi = bi + 1
                }
                let ex = ensureExtra(st, bo)
                st.objExtras[ex].boundTarget = cloneValue(recv)
                if args.len() > 0 {
                    st.objExtras[ex].boundThis = cloneValue(args[0])
                }
                st.objExtras[ex].boundArgs = extra
                return JSValue.Obj(bo)
            }
            if name == "toString" {
                return JSValue.Str("[object " + objectTypeTag(recv) + "]")
            }
            if name == "valueOf" {
                return cloneValue(recv)
            }
            return primitiveMethod(name, recv, args)
        }
    }
}

// The tag Object.prototype.toString uses for a heap-object receiver.
fn objectTag(st: &Interp, o: i64): string {
    if st.objects[o].isArray {
        return "Array"
    }
    if st.objects[o].isError {
        return "Error"
    }
    if st.objects[o].isDate {
        return "Date"
    }
    if st.objExtras[st.objects[o].extra].regexId >= 0 {
        return "RegExp"
    }
    if st.objects[o].isMap {
        return "Map"
    }
    if st.objects[o].isSet {
        return "Set"
    }
    if st.objects[o].promiseState >= 0 {
        return "Promise"
    }
    if st.objects[o].isBound || st.objects[o].isFunctionLike {
        return "Function"
    }
    return "Object"
}

// The tag Object.prototype.toString uses for a primitive receiver.
fn objectTypeTag(v: &JSValue): string {
    match v {
        JSValue.Undefined => {
            return "Undefined"
        }
        JSValue.Null => {
            return "Null"
        }
        JSValue.Bool(_b) => {
            return "Boolean"
        }
        JSValue.Number(_n) => {
            return "Number"
        }
        JSValue.Str(s) => {
            // symbols are interned strings in this engine, so the tag has to come
            // from the marker rather than the value kind
            if isSymbolStr(s) {
                return "Symbol"
            }
            return "String"
        }
        JSValue.Func(_f, _e) => {
            return "Function"
        }
        JSValue.Native(_n) => {
            return "Function"
        }
        _ => {
            return "Object"
        }
    }
}

fn setMemberDyn(prog: &Prog, o: i64, key: string, v: JSValue, st: &mut Interp) {
    if st.objects[o].isProxy {
        let trap = proxyTrap(st, o, "set")
        let target = cloneValue(st.objExtras[st.objects[o].extra].proxyTarget)
        if isCallableIn(st, trap) {
            var args: Vec<JSValue> = Vec.new()
            args.push(cloneValue(target))
            args.push(JSValue.Str(key.clone()))
            args.push(cloneValue(v))
            args.push(JSValue.Obj(o))
            let _r = callValue(prog, trap, args, cloneValue(st.objExtras[st.objects[o].extra].proxyHandler), st)
            return
        }
        let th = objHandle(target)
        if th >= 0 {
            setMemberDyn(prog, th, key, v, st)
        }
        return
    }
    let sfn = findSetter(st, o, key)
    if isCallable(sfn) {
        var args: Vec<JSValue> = Vec.new()
        args.push(v)
        let _ = callValue(prog, sfn, args, JSValue.Obj(o), st)
        return
    }
    // a getter with no setter: writing is a silent no-op in sloppy mode, and
    // must not replace the accessor with a plain data property
    let own = objOwnIndex(st, o, key)
    if own >= 0 && st.objects[o].props[own].isAccessor {
        return
    }
    setMember(st, o, key, v)
}

fn getMember(st: &Interp, o: i64, key: &string): JSValue {
    // A DataView shares taBuf/taOffset/taLen with typed arrays but is not
    // index-accessible and its byteLength is already in bytes. Handle its props
    // here and skip the typed-array element path below.
    if st.objects[o].isDataView {
        if key == "byteLength" {
            return JSValue.Number(st.objExtras[st.objects[o].extra].taLen as f64)
        }
        if key == "byteOffset" {
            return JSValue.Number(st.objExtras[st.objects[o].extra].taOffset as f64)
        }
        if key == "buffer" {
            return JSValue.Obj(st.objExtras[st.objects[o].extra].taBuf)
        }
    }
    if st.objExtras[st.objects[o].extra].taBuf >= 0 && !st.objects[o].isDataView {
        if key == "length" {
            return JSValue.Number(st.objExtras[st.objects[o].extra].taLen as f64)
        }
        if key == "byteLength" {
            return JSValue.Number((st.objExtras[st.objects[o].extra].taLen * taWidth(st.objExtras[st.objects[o].extra].taKind)) as f64)
        }
        if key == "byteOffset" {
            return JSValue.Number(st.objExtras[st.objects[o].extra].taOffset as f64)
        }
        if key == "BYTES_PER_ELEMENT" {
            return JSValue.Number(taWidth(st.objExtras[st.objects[o].extra].taKind) as f64)
        }
        if key == "buffer" {
            return JSValue.Obj(st.objExtras[st.objects[o].extra].taBuf)
        }
        let ti = asArrayIndex(key)
        if ti >= 0 {
            if ti >= st.objExtras[st.objects[o].extra].taLen {
                return JSValue.Undefined
            }
            return JSValue.Number(taElem(st, o, ti))
        }
    }
    if st.objects[o].isArrayBuffer {
        if key == "byteLength" {
            return JSValue.Number(st.objExtras[st.objects[o].extra].bytes.len() as f64)
        }
        if key == "maxByteLength" {
            if st.objExtras[st.objects[o].extra].abMaxLen >= 0 {
                return JSValue.Number(st.objExtras[st.objects[o].extra].abMaxLen as f64)
            }
            return JSValue.Number(st.objExtras[st.objects[o].extra].bytes.len() as f64)
        }
        if key == "resizable" {
            return JSValue.Bool(st.objExtras[st.objects[o].extra].abMaxLen >= 0)
        }
        if key == "detached" {
            return JSValue.Bool(st.objects[o].abDetached)
        }
    }
    if st.objects[o].isArray {
        if key == "length" {
            return JSValue.Number(arrLen(st, o) as f64)
        }
        let ai = asArrayIndex(key)
        if ai >= 0 {
            return arrGet(st, o, ai)
        }
    }
    // own property first, then walk the prototype chain
    var cur = o
    while cur >= 0 {
        if objHas(st, cur, key) {
            return objGet(st, cur, key)
        }
        cur = st.objects[cur].proto
    }
    return JSValue.Undefined
}

fn setMember(st: &mut Interp, o: i64, key: string, value: JSValue) {
    // sloppy mode drops writes to a frozen object rather than throwing
    if st.objects[o].frozen {
        return
    }
    // non-extensible: existing properties stay writable, new ones are refused
    if st.objects[o].noExtend && objOwnIndex(st, o, key) < 0 && !st.objects[o].isArray {
        return
    }
    // a non-writable data property silently ignores assignment in sloppy mode
    let own = objOwnIndex(st, o, key)
    if own >= 0 && !st.objects[o].props[own].isAccessor && !st.objects[o].props[own].writable {
        return
    }
    if st.objExtras[st.objects[o].extra].taBuf >= 0 && !st.objects[o].isDataView {
        let ti = asArrayIndex(key)
        if ti >= 0 {
            taSetElem(st, o, ti, toNum(value))
            return
        }
    }
    // globalThis.x = v defines/updates the global binding, not a detached property
    if st.objects[o].isGlobal {
        scopeDefine(st, 0, key, value)
        return
    }
    if st.objects[o].isArray {
        let ai = asArrayIndex(key)
        if ai >= 0 {
            arrSet(st, o, ai, value)
            return
        }
        if key == "length" {
            setArrayLength(st, o, toNum(value) as i64)
            return
        }
    }
    objSet(st, o, key, value)
}

// One element of a value being destructured: `value[i]`. Arrays/array-likes go
// through getMember by index; a string yields its i-th character.
fn destructElement(_prog: &Prog, value: &JSValue, i: i64, st: &mut Interp): JSValue {
    let vh = objHandle(value)
    if vh >= 0 {
        return getMember(st, vh, i64ToStr(i))
    }
    match value {
        JSValue.Str(s) => {
            // s[i] indexes UTF-16 code units like charAt, not raw UTF-8 bytes —
            // "café"[3] is "é", not the first byte of its 2-byte encoding
            if i >= 0 && i < utf16Length(s) {
                return JSValue.Str(utf16Slice(s, i, i + 1))
            }
        }
        _ => {
        }
    }
    return JSValue.Undefined
}

// Assign `value` to a single destructuring target: a nested pattern recurses; a
// `name = default` element applies the default when value is undefined; otherwise
// the target is an ordinary lvalue (identifier / member / index).
fn assignTarget(prog: &Prog, targetIdx: i64, value: JSValue, st: &mut Interp, scope: i64) {
    match prog.exprs[targetIdx] {
        Expr.ArrLit(_li) => {
            assignPattern(prog, targetIdx, value, st, scope)
        }
        Expr.ObjLit(_li) => {
            assignPattern(prog, targetIdx, value, st, scope)
        }
        Expr.Assign(name, defaultIdx) => {
            var v = cloneValue(value)
            if isUndefinedValue(value) {
                v = evalExpr(prog, defaultIdx, st, scope)
            }
            scopeAssign(st, scope, name.clone(), cloneValue(v))
        }
        _ => {
            writeLValue(prog, targetIdx, st, scope, cloneValue(value))
        }
    }
}

// Destructure `value` into a pattern (ArrLit / ObjLit) of existing lvalue
// targets. Handles nesting, holes, `...rest`, and `= default` elements.
fn assignPattern(prog: &Prog, patIdx: i64, value: JSValue, st: &mut Interp, scope: i64) {
    match prog.exprs[patIdx] {
        Expr.ArrLit(litIdx) => {
            pushTemp(st, cloneValue(value))
            var i: i64 = 0
            while i < prog.arrLits[litIdx].len() {
                let e = prog.arrLits[litIdx][i]
                if e < 0 {
                    // elision: skip this position
                    i = i + 1
                    continue
                }
                match prog.exprs[e] {
                    Expr.Spread(target) => {
                        // ...rest — the remaining elements as a fresh array
                        let rest = newArray(st)
                        pushTemp(st, JSValue.Obj(rest))
                        let vh = objHandle(value)
                        if vh >= 0 {
                            let vn = arrLen(st, vh)
                            var j = i
                            while j < vn {
                                arrPush(st, rest, arrGet(st, vh, j))
                                j = j + 1
                            }
                        }
                        popTemp(st)
                        assignTarget(prog, target, JSValue.Obj(rest), st, scope)
                    }
                    _ => {
                        let ev = destructElement(prog, value, i, st)
                        assignTarget(prog, e, ev, st, scope)
                    }
                }
                i = i + 1
            }
            popTemp(st)
        }
        Expr.ObjLit(litIdx) => {
            pushTemp(st, cloneValue(value))
            let vh = objHandle(value)
            var i: i64 = 0
            while i < prog.objLits[litIdx].len() {
                let key = prog.objLits[litIdx][i].key.clone()
                let target = prog.objLits[litIdx][i].val
                var pv = JSValue.Undefined
                if vh >= 0 {
                    pv = getMemberDyn(prog, vh, key, st)
                }
                assignTarget(prog, target, pv, st, scope)
                i = i + 1
            }
            popTemp(st)
        }
        _ => {
            assignTarget(prog, patIdx, value, st, scope)
        }
    }
}

// Read an assignable target (identifier / member / computed index) as a value.
// Backs ++/-- and compound assignment; the base object of a member target is
// evaluated here and again by writeLValue (harmless unless the base has side
// effects, which is rare).
fn readLValue(prog: &Prog, targetIdx: i64, st: &mut Interp, scope: i64): JSValue {
    match prog.exprs[targetIdx] {
        Expr.Ident(name) => {
            match scopeTryLookup(st, scope, name) {
                Option.Some(v) => {
                    return v
                }
                Option.None => {
                    // reading an undeclared identifier is a ReferenceError in JS;
                    // without this a typo just evaluates to undefined and the
                    // failure surfaces somewhere else entirely
                    st.throwing = true
                    st.thrownValue = makeError(st, "ReferenceError", name.clone() + " is not defined")
                    return JSValue.Undefined
                }
            }
        }
        Expr.Member(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            match ov {
                JSValue.Obj(o) => {
                    return getMember(st, o, name)
                }
                JSValue.Func(fIdx, fe) => {
                    // a class static read as an lvalue (C.count++)
                    let statics = getFuncStatics(st, fIdx, fe)
                    return getMember(st, statics, name)
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        Expr.Index(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            // the key expression can run user code and collect the base
            pushTemp(st, cloneValue(ov))
            let kv = evalExpr(prog, keyIdx, st, scope)
            popTemp(st)
            let key = toStr(kv)
            match ov {
                JSValue.Obj(o) => {
                    return getMember(st, o, key)
                }
                JSValue.Func(fIdx, fe) => {
                    let statics = getFuncStatics(st, fIdx, fe)
                    return getMember(st, statics, key)
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        _ => {
            return JSValue.Undefined
        }
    }
}

fn writeLValue(prog: &Prog, targetIdx: i64, st: &mut Interp, scope: i64, value: JSValue) {
    match prog.exprs[targetIdx] {
        Expr.Ident(name) => {
            scopeAssign(st, scope, name.clone(), value)
        }
        Expr.Member(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            match ov {
                JSValue.Obj(o) => {
                    setMember(st, o, name.clone(), value)
                }
                JSValue.Func(fIdx, fe) => {
                    // a class static written as an lvalue (C.count++)
                    let statics = getFuncStatics(st, fIdx, fe)
                    setMember(st, statics, name.clone(), value)
                }
                _ => {
                }
            }
        }
        Expr.Index(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            // the key expression can run user code and collect the base
            pushTemp(st, cloneValue(ov))
            let kv = evalExpr(prog, keyIdx, st, scope)
            popTemp(st)
            let key = toStr(kv)
            match ov {
                JSValue.Obj(o) => {
                    setMember(st, o, key, value)
                }
                JSValue.Func(fIdx, fe) => {
                    let statics = getFuncStatics(st, fIdx, fe)
                    setMember(st, statics, key, value)
                }
                _ => {
                }
            }
        }
        _ => {
        }
    }
}

// Built-in function/constructor ids. The Error family shares one path; the
// specific kind is carried in the object's `name` property.
let NATIVE_ERROR: i64 = 0
let NATIVE_TYPE_ERROR: i64 = 1
let NATIVE_RANGE_ERROR: i64 = 2
let NATIVE_SYNTAX_ERROR: i64 = 3
let NATIVE_REFERENCE_ERROR: i64 = 4
let NATIVE_JSON_STRINGIFY: i64 = 5
let NATIVE_JSON_PARSE: i64 = 6
let NATIVE_MATH_FLOOR: i64 = 7
let NATIVE_MATH_CEIL: i64 = 8
let NATIVE_MATH_ROUND: i64 = 9
let NATIVE_MATH_TRUNC: i64 = 10
let NATIVE_MATH_ABS: i64 = 11
let NATIVE_MATH_SIGN: i64 = 12
let NATIVE_MATH_LOG2: i64 = 98
let NATIVE_MATH_LOG10: i64 = 99
let NATIVE_MATH_EXP: i64 = 89
let NATIVE_MATH_LOG: i64 = 90
let NATIVE_MATH_SIN: i64 = 91
let NATIVE_MATH_COS: i64 = 92
let NATIVE_MATH_TAN: i64 = 93
let NATIVE_MATH_ASIN: i64 = 94
let NATIVE_MATH_ACOS: i64 = 95
let NATIVE_MATH_ATAN: i64 = 96
let NATIVE_MATH_ATAN2: i64 = 97
let NATIVE_MATH_SQRT: i64 = 13
let NATIVE_MATH_POW: i64 = 14
let NATIVE_MATH_MIN: i64 = 15
let NATIVE_MATH_MAX: i64 = 16
let NATIVE_MATH_RANDOM: i64 = 17
let NATIVE_REGEXP: i64 = 18
let NATIVE_OBJECT_DEFINEPROPERTY: i64 = 19
let NATIVE_OBJECT_KEYS: i64 = 20
let NATIVE_OBJECT_ASSIGN: i64 = 21
let NATIVE_NUMBER: i64 = 22
let NATIVE_STRING: i64 = 23
let NATIVE_BOOLEAN: i64 = 24
let NATIVE_READ_FILE_SYNC: i64 = 25
let NATIVE_FILE_EXISTS: i64 = 26
let NATIVE_OBJECT_VALUES: i64 = 27
let NATIVE_OBJECT_ENTRIES: i64 = 28
let NATIVE_OBJECT_FREEZE: i64 = 29
let NATIVE_PROMISE_RESOLVE: i64 = 30
let NATIVE_PROMISE_REJECT: i64 = 31
// 32/33/34 were Promise.all/allSettled/race. They are self-hosted in the prelude
// now: the native took a synchronous snapshot of each input's state instead of
// subscribing to it, and could not adopt a thenable at all (calling user .then
// needs the program, which a native does not have). Ids left retired rather than
// reused so an old id in a serialized form can never mean something new.
// `new Promise(cb)` hands its executor a resolve/reject pair bound to one
// specific promise. Natives are identified by a bare id, so the promise handle
// is encoded into the id itself: base + handle*2 + (0 resolve | 1 reject).
let NATIVE_PROMISE: i64 = 35
let NATIVE_IS_NAN: i64 = 36
let NATIVE_IS_FINITE: i64 = 37
let NATIVE_ARRAY_ISARRAY: i64 = 38
let NATIVE_OBJECT_CREATE: i64 = 39
let NATIVE_OBJECT_GETPROTO: i64 = 40
let NATIVE_OBJECT_SETPROTO: i64 = 41
let NATIVE_OBJECT_GETOWNPROPDESC: i64 = 42
let NATIVE_PARSE_INT: i64 = 43
let NATIVE_PARSE_FLOAT: i64 = 44
let NATIVE_SYMBOL: i64 = 45
let NATIVE_OBJECT_DEFINEPROPERTIES: i64 = 46
let NATIVE_MAP: i64 = 47
let NATIVE_SET: i64 = 48
let NATIVE_OBJECT_GETOWNPROPNAMES: i64 = 49
let NATIVE_ARRAY_FROM: i64 = 50
let NATIVE_PROCESS_EXIT: i64 = 51
let NATIVE_NOOP: i64 = 52
let NATIVE_PROCESS_HRTIME: i64 = 53
let NATIVE_PROCESS_CWD: i64 = 54
let NATIVE_STRING_FROMCHARCODE: i64 = 55
let NATIVE_DATE: i64 = 56
let NATIVE_DATE_NOW: i64 = 57
// Date.UTC(year, month[, day, hours, minutes, seconds, ms]) — the fields are
// interpreted as UTC and out-of-range values roll over (month 12 is January of
// the next year), which falls out of doing the arithmetic in days and seconds
// rather than validating each field.
let NATIVE_DATE_UTC: i64 = 110
// The Object constructor itself. Registering the global as a plain object made
// `typeof Object` report "object" and `new Object()` fail outright — both used
// constantly, and by three of the QuickJS builtin tests.
let NATIVE_OBJECT_CTOR: i64 = 111
let NATIVE_ENCODE_URI_COMPONENT: i64 = 58
let NATIVE_DECODE_URI_COMPONENT: i64 = 59
let NATIVE_ENCODE_URI: i64 = 60
let NATIVE_DECODE_URI: i64 = 61
let NATIVE_SET_TIMEOUT: i64 = 62
let NATIVE_SET_INTERVAL: i64 = 63
let NATIVE_CLEAR_TIMER: i64 = 64
let NATIVE_SET_IMMEDIATE: i64 = 65
let NATIVE_QUEUE_MICROTASK: i64 = 66
// queueMicrotask has its own native (distinct from process.nextTick, which
// shares NATIVE_QUEUE_MICROTASK) so it can call the callback with zero
// arguments per spec while nextTick's behaviour is left untouched.
let NATIVE_QUEUE_MICROTASK_JS: i64 = 112
let NATIVE_DATAVIEW: i64 = 113
let NATIVE_OBJECT_HASOWN: i64 = 114
let NATIVE_STRING_RAW: i64 = 115
let NATIVE_STRING_FROMCODEPOINT: i64 = 116
let NATIVE_DATE_PARSE: i64 = 117
let NATIVE_MKDIR: i64 = 118
let NATIVE_READDIR: i64 = 119
let NATIVE_UNLINK: i64 = 120
let NATIVE_RMDIR: i64 = 121
let NATIVE_RENAME: i64 = 122
let NATIVE_IS_DIR: i64 = 123
let NATIVE_BIGINT: i64 = 124
let NATIVE_OBJECT_GETOWNPROPSYMBOLS: i64 = 125
let NATIVE_OBJECT_GETOWNPROPDESCS: i64 = 126
let NATIVE_ARRAY_CTOR: i64 = 67
let NATIVE_TCP_LISTEN: i64 = 68
let NATIVE_TCP_ACCEPT: i64 = 69
let NATIVE_TCP_RECV: i64 = 70
let NATIVE_TCP_SEND: i64 = 71
let NATIVE_TCP_CLOSE: i64 = 72
let NATIVE_HTTP_REGISTER: i64 = 73
let NATIVE_HTTP_UNREGISTER: i64 = 74
let NATIVE_WRITE_FILE: i64 = 75
let NATIVE_GC: i64 = 76
let NATIVE_OBJECT_ISFROZEN: i64 = 77
let NATIVE_OBJECT_PREVENTEXT: i64 = 100
let NATIVE_OBJECT_ISEXT: i64 = 101
let NATIVE_OBJECT_SEAL: i64 = 102
let NATIVE_OBJECT_ISSEALED: i64 = 103
// __byteLength(s): the raw UTF-8 byte count of an engine string. JS `.length`
// decodes to code points and charCodeAt is lossy on bytes that aren't valid
// UTF-8, so neither can measure file content read as a string. Content-Length
// must come from here or binary responses (fonts, images) get truncated.
let NATIVE_BYTE_LENGTH: i64 = 104
// __napiLoad(path): dlopen a .node addon, run napi_register_module_v1, return its
// exports. This is what require() resolves a .node file to.
let NATIVE_NAPI_LOAD: i64 = 105
// console.* as real functions. The identifier fast path above handles the common
// `console.log(x)` call shape, but code that passes the method around — prisma's
// runtime does `console.debug || console.log` — needs `console` to be a real
// object whose properties are callable values.
let NATIVE_CONSOLE_LOG: i64 = 106
// new Proxy(target, handler)
let NATIVE_PROXY: i64 = 107
// Object.is — SameValue: like ===, except NaN equals itself and +0 differs
// from -0. ts-pattern (bundled into prisma's runtime) matches literals with it.
let NATIVE_OBJECT_IS: i64 = 108
// __httpFetchAsync(method, url, headersJson, body): runs the request on a worker
// OS thread and returns a promise the event loop settles with the raw response.
let NATIVE_HTTP_FETCH_ASYNC: i64 = 109
let NATIVE_ARRAYBUFFER: i64 = 78
// the typed-array constructors occupy a contiguous block so the element kind is
// just (id - NATIVE_TA_BASE); keep in step with the TA_* order in runtime.milo
let NATIVE_TA_BASE: i64 = 79
// __httpFetch(method, url, headersJson, body): synchronous outbound HTTP/HTTPS.
// Above the TA block (79..87). node-fetch is built on this.
let NATIVE_HTTP_FETCH: i64 = 88

// The `.name` of a native constructor (Object.name === "Object" etc), so
// `err.constructor.name` and similar resolve. Empty for natives that are not
// named constructors.
fn nativeCtorName(id: i64): string {
    if id >= NATIVE_ERROR && id <= NATIVE_REFERENCE_ERROR {
        return nativeErrorName(id)
    }
    if id == NATIVE_OBJECT_CTOR {
        return "Object"
    }
    if id == NATIVE_NUMBER {
        return "Number"
    }
    if id == NATIVE_BIGINT {
        return "BigInt"
    }
    if id == NATIVE_STRING {
        return "String"
    }
    if id == NATIVE_BOOLEAN {
        return "Boolean"
    }
    return ""
}

fn nativeErrorName(id: i64): string {
    if id == NATIVE_TYPE_ERROR {
        return "TypeError"
    }
    if id == NATIVE_RANGE_ERROR {
        return "RangeError"
    }
    if id == NATIVE_SYNTAX_ERROR {
        return "SyntaxError"
    }
    if id == NATIVE_REFERENCE_ERROR {
        return "ReferenceError"
    }
    return "Error"
}

fn isErrorCtor(id: i64): bool {
    return id >= NATIVE_ERROR && id <= NATIVE_REFERENCE_ERROR
}

// Invoke a native function/constructor. Error(msg) and new Error(msg) behave the
// same (both mint an error object), matching JS.
// Synchronous outbound HTTP/HTTPS. Milo has no coroutines and the event loop is
// drained in place on await, so a blocking request is consistent with the rest of
// the runtime (the server side blocks on accept too). Returns the raw HTTP
// response text prefixed with 'O', or 'E' + message on any failure — the JS side
// (lib/node-fetch.js) strips the sentinel and parses the response.
fn doHttpFetch(method: &string, url: &string, headersRaw: &string, body: &string): string {
    // parse scheme://host[:port]/path
    var rest = url.clone()
    var tls = true
    var defPort: i64 = 443
    if jsStartsWith(rest, "https://") {
        rest = strSlice(rest, 8, rest.len())
    } else if jsStartsWith(rest, "http://") {
        tls = false
        defPort = 80
        rest = strSlice(rest, 7, rest.len())
    } else {
        return "Eunsupported URL scheme: " + url.clone()
    }
    // host[:port] is up to the first '/'
    var slash = jsIndexOf(rest, "/", 0)
    var authority = rest.clone()
    var path = "/"
    if slash >= 0 {
        authority = strSlice(rest, 0, slash)
        path = strSlice(rest, slash, rest.len())
    }
    var host = authority.clone()
    var port = defPort
    let colon = jsIndexOf(authority, ":", 0)
    if colon >= 0 {
        host = strSlice(authority, 0, colon)
        let portStr = strSlice(authority, colon + 1, authority.len())
        port = toNum(JSValue.Str(portStr)) as i64
        if port <= 0 {
            port = defPort
        }
    }
    // DNS
    var ip: u32 = 0
    match resolve(host) {
        Result.Ok(a) => {
            ip = a
        }
        Result.Err(_e) => {
            return "Ecannot resolve host: " + host.clone()
        }
    }
    // build the request. HTTP/1.1 with Connection: close so the read loop ends at
    // EOF instead of needing to parse content-length/chunked to know when to stop.
    var req = method.clone() + " " + path.clone() + " HTTP/1.1\r\n"
    req = req + "Host: " + host.clone() + "\r\n"
    req = req + headersRaw.clone()
    req = req + "Connection: close\r\n"
    if body.len() > 0 {
        req = req + "Content-Length: " + i64ToStr(body.len()) + "\r\n"
    }
    req = req + "\r\n" + body.clone()

    if tls {
        match TlsStream.connect(ip, port as u16, host) {
            Result.Ok(conn) => {
                match conn.send(req) {
                    Result.Ok(_n) => {
                    }
                    Result.Err(_e) => {
                        return "Esend failed"
                    }
                }
                var resp = ""
                var reading = true
                while reading {
                    match conn.recv() {
                        Result.Ok(chunk) => {
                            if chunk.len() == 0 {
                                reading = false
                            } else {
                                resp = resp + chunk
                            }
                        }
                        Result.Err(_e) => {
                            reading = false
                        }
                    }
                }
                return "O" + resp
            }
            Result.Err(_e) => {
                return "ETLS connect failed to " + host.clone()
            }
        }
    }
    match TcpStream.connect(ip, port as u16) {
        Result.Ok(conn) => {
            match conn.send(req) {
                Result.Ok(_n) => {
                }
                Result.Err(_e) => {
                    return "Esend failed"
                }
            }
            var resp = ""
            var reading = true
            while reading {
                match conn.recv() {
                    Result.Ok(chunk) => {
                        if chunk.len() == 0 {
                            reading = false
                        } else {
                            resp = resp + chunk
                        }
                    }
                    Result.Err(_e) => {
                        reading = false
                    }
                }
            }
            return "O" + resp
        }
        Result.Err(_e) => {
            return "ETCP connect failed to " + host.clone()
        }
    }
}

fn callNative(id: i64, argVals: &Vec<JSValue>, st: &mut Interp): JSValue {
    if isErrorCtor(id) {
        let o = newObject(st)
        st.objects[o].isError = true
        let ename = nativeErrorName(id)
        objSet(st, o, "name", JSValue.Str(ename.clone()))
        var msg = ""
        if argVals.len() > 0 {
            msg = toStr(argVals[0])
        }
        objSet(st, o, "message", JSValue.Str(msg.clone()))
        // error.stack: no real backtrace here, but a string headed "Name: message"
        // so code that reads or logs e.stack (a typeof check, express's error
        // middleware) sees a string rather than undefined
        var stackHead = ename.clone()
        if msg.len() > 0 {
            stackHead = stackHead + ": " + msg
        }
        objSet(st, o, "stack", JSValue.Str(stackHead))
        // new Error(msg, { cause }) — ES2022 error chaining
        if argVals.len() > 1 {
            let oh = objHandle(argVals[1])
            if oh >= 0 && objOwnIndex(st, oh, "cause") >= 0 {
                objSet(st, o, "cause", cloneValue(getMember(st, oh, "cause")))
            }
        }
        return JSValue.Obj(o)
    }
    if id == NATIVE_JSON_STRINGIFY {
        if argVals.len() == 0 || mjJsonOmitted(argVals[0]) {
            // JSON.stringify(undefined) / a function is the JS value undefined
            return JSValue.Undefined
        }
        return JSValue.Str(mjStringifyVal(argVals[0], st))
    }
    if id == NATIVE_JSON_PARSE {
        if argVals.len() == 0 {
            return JSValue.Undefined
        }
        let text = toStr(argVals[0])
        return mjJsonParse(text, st)
    }
    if id >= NATIVE_MATH_FLOOR && id <= NATIVE_MATH_RANDOM {
        return mathNative(id, argVals, st)
    }
    // the transcendentals were appended after the original block, so they sit
    // outside the contiguous FLOOR..RANDOM range the gate above covers
    if (id >= NATIVE_MATH_EXP && id <= NATIVE_MATH_ATAN2) || id == NATIVE_MATH_LOG2 || id == NATIVE_MATH_LOG10 {
        return mathNative(id, argVals, st)
    }
    if id == NATIVE_GC {
        // a real collection, not a no-op: the QuickJS GC tests call this to force
        // finalization, and a stub would make them pass without exercising anything
        collect(st)
        return JSValue.Undefined
    }
    if id == NATIVE_REGEXP {
        var pat = ""
        var flags = ""
        if argVals.len() > 0 {
            pat = toStr(argVals[0])
        }
        if argVals.len() > 1 {
            flags = toStr(argVals[1])
        }
        return makeRegex(st, pat, flags)
    }
    if id == NATIVE_NUMBER {
        if argVals.len() == 0 {
            return JSValue.Number(0.0)
        }
        // an object coerces via ToPrimitive(number) — honouring a user
        // [Symbol.toPrimitive]/valueOf — before ToNumber; toNum alone gives NaN
        if objHandle(argVals[0]) >= 0 {
            let p = toPrimitiveNumber(gProg, argVals[0], st)
            return JSValue.Number(toNum(p))
        }
        return JSValue.Number(toNum(argVals[0]))
    }
    if id == NATIVE_BIGINT {
        if argVals.len() == 0 {
            return JSValue.BigInt("0")
        }
        match cloneValue(argVals[0]) {
            JSValue.BigInt(s) => {
                return JSValue.BigInt(s.clone())
            }
            JSValue.Bool(b) => {
                if b {
                    return JSValue.BigInt("1")
                }
                return JSValue.BigInt("0")
            }
            JSValue.Str(s) => {
                let t = jsTrim(s)
                if isDecimalIntStr(t) {
                    return JSValue.BigInt(bigNormalizeDec(t))
                }
                // radix-prefixed strings (0x/0b/0o) parse with full precision
                if t.len() > 2 && t[0] == '0' {
                    let p = t[1]
                    if p == 'x' || p == 'X' {
                        return JSValue.BigInt(bnFromRadix(bnStrFrom(t, 2), 16))
                    }
                    if p == 'b' || p == 'B' {
                        return JSValue.BigInt(bnFromRadix(bnStrFrom(t, 2), 2))
                    }
                    if p == 'o' || p == 'O' {
                        return JSValue.BigInt(bnFromRadix(bnStrFrom(t, 2), 8))
                    }
                }
                // anything else (empty → 0n) via the numeric path
                return JSValue.BigInt(bnFromF64(strToNum(t)))
            }
            _ => {
                // BigInt(number): must be an integer (JS throws otherwise); we
                // truncate defensively rather than throw, staying non-crashing
                return JSValue.BigInt(bnFromF64(toNum(argVals[0])))
            }
        }
    }
    if id == NATIVE_STRING {
        if argVals.len() == 0 {
            return JSValue.Str("")
        }
        // String(sym) is the one conversion the spec allows for a symbol, and it
        // must show Symbol(desc) rather than the internal tagged string
        match argVals[0] {
            JSValue.Str(sv) => {
                if isSymbolStr(sv) {
                    return JSValue.Str(symbolDisplay(sv))
                }
            }
            _ => {
            }
        }
        // arrays coerce to their join, not "[object Object]"
        let a0h = objHandle(argVals[0])
        if a0h >= 0 && st.objects[a0h].isArray {
            return JSValue.Str(joinArray(st, a0h, ","))
        }
        return JSValue.Str(toStr(argVals[0]))
    }
    if id == NATIVE_BOOLEAN {
        if argVals.len() == 0 {
            return JSValue.Bool(false)
        }
        return JSValue.Bool(truthy(argVals[0]))
    }
    if id == NATIVE_READ_FILE_SYNC {
        if argVals.len() == 0 {
            return JSValue.Undefined
        }
        match readFile(toStr(argVals[0])) {
            Result.Ok(txt) => {
                return JSValue.Str(txt)
            }
            Result.Err(_e) => {
                return JSValue.Undefined
            }
        }
    }
    if id == NATIVE_FILE_EXISTS {
        if argVals.len() == 0 {
            return JSValue.Bool(false)
        }
        match readFile(toStr(argVals[0])) {
            Result.Ok(_txt) => {
                return JSValue.Bool(true)
            }
            Result.Err(_e) => {
                return JSValue.Bool(false)
            }
        }
    }
    if id == NATIVE_OBJECT_DEFINEPROPERTY {
        if argVals.len() < 3 {
            return JSValue.Undefined
        }
        let target = cloneValue(argVals[0])
        let key = toStr(argVals[1])
        let o = propertyBagOf(st, target)
        if o < 0 {
            return target
        }
        let d = objHandle(argVals[2])
        if d >= 0 {
            applyDescriptor(st, o, key, d)
            return JSValue.Obj(o)
        }
        setMember(st, o, key, JSValue.Undefined)
        return JSValue.Obj(o)
    }
    if id >= NATIVE_RESOLVER_BASE {
        let off = id - NATIVE_RESOLVER_BASE
        let target = off / 2
        var v = JSValue.Undefined
        if argVals.len() > 0 {
            v = cloneValue(argVals[0])
        }
        // first settle wins, as in JS. resolve(p) where p is a promise adopts it.
        if st.objects[target].promiseState == 0 {
            let state = 1 + (off % 2)
            let vp = objHandle(v)
            if state == 1 && vp >= 0 && isPromise(st, vp) {
                adoptPromise(st, target, vp)
            } else {
                settlePromise(st, target, state, v)
            }
        }
        return JSValue.Undefined
    }
    if id == NATIVE_PROMISE_RESOLVE || id == NATIVE_PROMISE_REJECT {
        var v = JSValue.Undefined
        if argVals.len() > 0 {
            v = cloneValue(argVals[0])
        }
        if id == NATIVE_PROMISE_RESOLVE {
            // Promise.resolve(p) is p
            let h = objHandle(v)
            if h >= 0 && isPromise(st, h) {
                return v
            }
            return JSValue.Obj(newPromise(st, 1, v))
        }
        return JSValue.Obj(newPromise(st, 2, v))
    }
    if id == NATIVE_IS_NAN || id == NATIVE_IS_FINITE {
        var x = jsNan()
        if argVals.len() > 0 {
            x = toNum(argVals[0])
        }
        let isNan = x != x
        if id == NATIVE_IS_NAN {
            return JSValue.Bool(isNan)
        }
        return JSValue.Bool(!isNan && x != jsInfinity() && x != (0.0 - jsInfinity()))
    }
    if id == NATIVE_ARRAY_ISARRAY {
        if argVals.len() > 0 {
            let h = objHandle(argVals[0])
            if h >= 0 {
                return JSValue.Bool(st.objects[h].isArray)
            }
        }
        return JSValue.Bool(false)
    }
    if id == NATIVE_PARSE_INT || id == NATIVE_PARSE_FLOAT {
        if argVals.len() == 0 {
            return JSValue.Number(jsNan())
        }
        let text = toStr(argVals[0])
        if id == NATIVE_PARSE_FLOAT {
            return JSValue.Number(jsParseFloatPrefix(text))
        }
        var radix: i64 = 10
        if argVals.len() > 1 {
            let r = toNum(argVals[1]) as i64
            if r >= 2 && r <= 36 {
                radix = r
            }
        }
        return JSValue.Number(jsParsePrefixNum(text, radix))
    }
    if id == NATIVE_SYMBOL {
        // Symbols are modelled as unique strings; enough for the well-known
        // ones used as property keys, not for real symbol semantics
        var desc = ""
        if argVals.len() > 0 {
            desc = toStr(argVals[0])
        }
        st.symbolCounter = st.symbolCounter + 1
        return JSValue.Str("@@sym:" + desc + ":" + i64ToStr(st.symbolCounter))
    }
    if id == NATIVE_OBJECT_DEFINEPROPERTIES {
        if argVals.len() < 2 {
            return JSValue.Undefined
        }
        let o = propertyBagOf(st, argVals[0])
        let descs = objHandle(argVals[1])
        if o < 0 || descs < 0 {
            return cloneValue(argVals[0])
        }
        var i: i64 = 0
        while i < st.objects[descs].props.len() {
            let key = st.objects[descs].props[i].key.clone()
            let d = objHandle(st.objects[descs].props[i].value)
            if d >= 0 {
                applyDescriptor(st, o, key, d)
            }
            i = i + 1
        }
        return JSValue.Obj(o)
    }
    if id == NATIVE_MAP || id == NATIVE_SET {
        let o = newObject(st)
        if id == NATIVE_MAP {
            st.objects[o].isMap = true
        } else {
            st.objects[o].isSet = true
        }
        // Map/Set entries live in the side table — allocate the slot up front so
        // every later mapKeys/mapVals access reaches a private extra, not the
        // shared default at index 0.
        let _me = ensureExtra(st, o)
        pushTemp(st, JSValue.Obj(o))
        // new Map([[k, v], ...]) / new Set([v, ...])
        if argVals.len() > 0 {
            let src = objHandle(argVals[0])
            if src >= 0 && st.objects[src].isArray {
                var i: i64 = 0
                while i < arrLen(st, src) {
                    let e = arrGet(st, src, i)
                    if id == NATIVE_SET {
                        mapPut(st, o, e, JSValue.Bool(true))
                    } else {
                        let pair = objHandle(e)
