                var key = prog.objLits[litIdx][i].key.clone()
                let keyExprIdx = prog.objLits[litIdx][i].keyExpr
                if keyExprIdx >= 0 {
                    key = toStr(evalExpr(prog, keyExprIdx, st, scope))
                }
                let valIdx = prog.objLits[litIdx][i].val
                let v = evalExpr(prog, valIdx, st, scope)
                let propKind = prog.objLits[litIdx][i].kind
                if propKind > 0 {
                    // a getter and setter for the same key share one property
                    let existing = objOwnIndex(st, obj, key)
                    var g = JSValue.Undefined
                    var sfn = JSValue.Undefined
                    if existing >= 0 && st.objects[obj].props[existing].isAccessor {
                        g = cloneValue(st.objects[obj].props[existing].getter)
                        sfn = cloneValue(st.objects[obj].props[existing].setter)
                    }
                    if propKind == 1 {
                        g = v
                    } else {
                        sfn = v
                    }
                    objDefineAccessor(st, obj, key, g, sfn)
                } else if key == "..." {
                    let src = objHandle(v)
                    if src >= 0 {
                        if st.objects[src].isArray {
                            var e: i64 = 0
                            let ne = arrLen(st, src)
                            while e < ne {
                                objSet(st, obj, i64ToStr(e), arrGet(st, src, e))
                                e = e + 1
                            }
                        }
                        let order = enumOrder(st, src)
                        var oi: i64 = 0
                        while oi < order.len() {
                            let k = order[oi]
                            oi = oi + 1
                            if !st.objects[src].props[k].enumerable {
                                continue
                            }
                            let pk = st.objects[src].props[k].key.clone()
                            // spread copies the VALUE of an accessor, so invoke the
                            // getter rather than copying the (unused) value slot
                            var pv = JSValue.Undefined
                            if st.objects[src].props[k].isAccessor {
                                pv = getMemberDyn(prog, src, pk, st)
                            } else {
                                pv = cloneValue(st.objects[src].props[k].value)
                            }
                            objSet(st, obj, pk, pv)
                        }
                    }
                } else {
                    objSet(st, obj, key, v)
                }
                i = i + 1
            }
            popTemp(st)
            return JSValue.Obj(obj)
        }

        Expr.TemplateStrings(litIdx) => {
            // cooked chunks, plus a `raw` array. The chunks are already unescaped
            // by the lexer and token text carries no source offsets, so `raw`
            // holds the same strings — correct for everything without escape
            // sequences, which covers the SQL that tag functions are used for.
            let arr = newArray(st)
            pushTemp(st, JSValue.Obj(arr))
            let rawArr = newArray(st)
            pushTemp(st, JSValue.Obj(rawArr))
            var ti: i64 = 0
            while ti < prog.arrLits[litIdx].len() {
                let v = evalExpr(prog, prog.arrLits[litIdx][ti], st, scope)
                arrPush(st, arr, cloneValue(v))
                arrPush(st, rawArr, v)
                ti = ti + 1
            }
            objSet(st, arr, "raw", JSValue.Obj(rawArr))
            popTemp(st)
            popTemp(st)
            return JSValue.Obj(arr)
        }
        Expr.ArrLit(litIdx) => {
            let arr = newArray(st)
            // root the part-built array so a GC while evaluating later elements
            // (an element may be a call) can't reclaim it
            pushTemp(st, JSValue.Obj(arr))
            var i: i64 = 0
            let n = prog.arrLits[litIdx].len()
            while i < n {
                let elemIdx = prog.arrLits[litIdx][i]
                if elemIdx < 0 {
                    // elision sentinel from the parser: a hole
                    let at = arrLen(st, arr)
                    arrPush(st, arr, JSValue.Undefined)
                    arrMarkHole(st, arr, at)
                    i = i + 1
                    continue
                }
                match prog.exprs[elemIdx] {
                    Expr.Spread(inner) => {
                        let sv = evalExpr(prog, inner, st, scope)
                        var tmp: Vec<JSValue> = Vec.new()
                        spreadInto(prog, tmp, sv, st)
                        var t: i64 = 0
                        while t < tmp.len() {
                            arrPush(st, arr, cloneValue(tmp[t]))
                            t = t + 1
                        }
                    }
                    _ => {
                        let v = evalExpr(prog, elemIdx, st, scope)
                        arrPush(st, arr, v)
                    }
                }
                i = i + 1
            }
            popTemp(st)
            return JSValue.Obj(arr)
        }
        Expr.New(calleeIdx, argsIdx) => {
            let calleeVal = evalExpr(prog, calleeIdx, st, scope)
            // a throw while resolving the constructor expression must propagate:
            // continuing here replaced the real error with "value is not a
            // constructor", which pointed at the wrong line entirely
            if st.throwing {
                return JSValue.Undefined
            }
            // `new Promise(executor)` runs its executor immediately with a
            // resolve/reject pair bound to the new promise. Handled here rather
            // than in callNative because the executor is a user function and
            // needs the program to run.
            let ah = objHandle(calleeVal)
            if ah >= 0 && st.arrayCtorObj >= 0 && ah == st.arrayCtorObj {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                return makeArrayFromCtor(st, argVals)
            }
            let ph = objHandle(calleeVal)
            if ph >= 0 && isPromiseCtor(st, ph) {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let pr = newPromise(st, 0, JSValue.Undefined)
                pushTemp(st, JSValue.Obj(pr))
                if argVals.len() > 0 {
                    var exArgs: Vec<JSValue> = Vec.new()
                    exArgs.push(JSValue.Native(NATIVE_RESOLVER_BASE + pr * 2))
                    exArgs.push(JSValue.Native(NATIVE_RESOLVER_BASE + pr * 2 + 1))
                    let _ = callValue(prog, argVals[0], exArgs, JSValue.Undefined, st)
                    if st.throwing {
                        let err = cloneValue(st.thrownValue)
                        st.throwing = false
                        st.thrownValue = JSValue.Undefined
                        if st.objects[pr].promiseState == 0 {
                            st.objects[pr].promiseState = 2
                            st.objExtras[st.objects[pr].extra].promiseValue = err
                        }
                    }
                }
                popTemp(st)
                return JSValue.Obj(pr)
            }
            match calleeVal {
                JSValue.Func(fIdx, envIdx) => {
                    pushTemp(st, JSValue.Func(fIdx, envIdx))
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let obj = newObject(st)
                    // record the constructor (for instanceof) and link the
                    // instance to the constructor's prototype (for shared methods)
                    st.objects[obj].ctor = fIdx
                    let proto = getFuncProto(st, fIdx)
                    linkProtoConstructor(st, proto, fIdx, envIdx)
                    st.objects[obj].proto = proto
                    pushTemp(st, JSValue.Obj(obj))
                    st.newTarget = JSValue.Func(fIdx, envIdx)
                    let result = callFunction(prog, fIdx, envIdx, argVals, JSValue.Obj(obj), st)
                    st.newTarget = JSValue.Undefined
                    popTemp(st)
                    popTemp(st)
                    // A constructor that returns an object OR a function replaces
                    // the new instance. express's Router is a factory that returns
                    // an inner function; discarding it yielded an empty object.
                    match result {
                        JSValue.Obj(r) => {
                            return JSValue.Obj(r)
                        }
                        JSValue.Func(rf, renv) => {
                            return JSValue.Func(rf, renv)
                        }
                        _ => {
                            return JSValue.Obj(obj)
                        }
                    }
                }
                JSValue.Native(id) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    return callNative(id, argVals, st)
                }
                JSValue.Obj(co) => {
                    if st.objects[co].isProxy {
                        let trap = proxyTrap(st, co, "construct")
                        let target = cloneValue(st.objExtras[st.objects[co].extra].proxyTarget)
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        if isCallableIn(st, trap) {
                            // construct(target, argsArray, newTarget)
                            let arr = newArray(st)
                            var ai: i64 = 0
                            while ai < argVals.len() {
                                st.objects[arr].elems.push(cloneValue(argVals[ai]))
                                ai = ai + 1
                            }
                            var targs: Vec<JSValue> = Vec.new()
                            targs.push(cloneValue(target))
                            targs.push(JSValue.Obj(arr))
                            targs.push(JSValue.Obj(co))
                            return callValue(prog, trap, targs, cloneValue(st.objExtras[st.objects[co].extra].proxyHandler), st)
                        }
                        // no construct trap: build the instance ourselves and run
                        // the target as its constructor, matching `new target()`
                        let inst = newObject(st)
                        let th = objHandle(target)
                        if th >= 0 {
                            match objGet(st, th, "prototype") {
                                JSValue.Obj(pr) => {
                                    st.objects[inst].proto = pr
                                }
                                _ => {
                                }
                            }
                        }
                        pushTemp(st, JSValue.Obj(inst))
                        let cr = callValue(prog, target, argVals, JSValue.Obj(inst), st)
                        popTemp(st)
                        match cr {
                            JSValue.Obj(ro) => {
                                return JSValue.Obj(ro)
                            }
                            _ => {
                                return JSValue.Obj(inst)
                            }
                        }
                    }
                    // a class defined by a node-api addon (napi_define_class): build
                    // the instance here and link its prototype, then let the addon's
                    // constructor callback populate it — typically via napi_wrap.
                    if st.objExtras[st.objects[co].extra].napiFn >= 0 {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        let inst = newObject(st)
                        match objGet(st, co, "prototype") {
                            JSValue.Obj(pr) => {
                                st.objects[inst].proto = pr
                            }
                            _ => {
                            }
                        }
                        pushTemp(st, JSValue.Obj(inst))
                        let r = napiInvoke(st.objExtras[st.objects[co].extra].napiFn, argVals, JSValue.Obj(inst))
                        popTemp(st)
                        match r {
                            JSValue.Obj(ro) => {
                                return JSValue.Obj(ro)
                            }
                            _ => {
                                return JSValue.Obj(inst)
                            }
                        }
                    }
                    st.throwing = true
                    st.thrownValue = makeError(st, "TypeError", "value is not a constructor" + currentModule(st))
                    return JSValue.Undefined
                }
                _ => {
                    st.throwing = true
                    st.thrownValue = makeError(st, "TypeError", "value is not a constructor" + currentModule(st))
                    return JSValue.Undefined
                }
            }
        }
        Expr.Update(targetIdx, isInc, isPrefix) => {
            let old = readLValue(prog, targetIdx, st, scope)
            // a BigInt counter increments by 1n and stays a BigInt (x++ on 5n
            // must yield 5n / store 6n, not coerce through f64)
            if isBigIntVal(old) {
                var op = "+"
                if !isInc {
                    op = "-"
                }
                let updated = evalBigIntBin(op, cloneValue(old), JSValue.BigInt("1"), st)
                writeLValue(prog, targetIdx, st, scope, cloneValue(updated))
                if isPrefix {
                    return updated
                }
                return old
            }
            let oldNum = toNum(old)
            var newNum = oldNum + 1.0
            if !isInc {
                newNum = oldNum - 1.0
            }
            writeLValue(prog, targetIdx, st, scope, JSValue.Number(newNum))
            if isPrefix {
                return JSValue.Number(newNum)
            }
            // postfix yields the numeric value before the update (JS coerces)
            return JSValue.Number(oldNum)
        }
        Expr.CompoundAssign(targetIdx, op, rhsIdx) => {
            let cur = readLValue(prog, targetIdx, st, scope)
            let rhs = evalExpr(prog, rhsIdx, st, scope)
            // a BigInt operand takes the arbitrary-precision path, same as a
            // plain binary expression — evalBin would coerce it through f64
            let result = if isBigIntVal(cur) || isBigIntVal(rhs) {
                evalBigIntBin(op, cloneValue(cur), cloneValue(rhs), st)
            } else {
                evalBin(op, cur, rhs)
            }
            writeLValue(prog, targetIdx, st, scope, cloneValue(result))
            return result
        }
        Expr.LogicalAssign(targetIdx, op, rhsIdx) => {
            // short-circuit: read the target, and only evaluate + store the rhs
            // when the operator says an update is due (a ||= b assigns only when a
            // is falsy, &&= only when truthy, ??= only when null/undefined)
            let cur = readLValue(prog, targetIdx, st, scope)
            var doAssign = isNullish(cur)
            if op == "||" {
                doAssign = !truthy(cur)
            } else if op == "&&" {
                doAssign = truthy(cur)
            }
            if !doAssign {
                return cur
            }
            let rhs = evalExpr(prog, rhsIdx, st, scope)
            writeLValue(prog, targetIdx, st, scope, cloneValue(rhs))
            return rhs
        }
        Expr.DestructAssign(patIdx, rhsIdx) => {
            let rhs = evalExpr(prog, rhsIdx, st, scope)
            pushTemp(st, cloneValue(rhs))
            assignPattern(prog, patIdx, cloneValue(rhs), st, scope)
            popTemp(st)
            // the assignment expression evaluates to the whole rhs
            return rhs
        }
        Expr.Cond(c, a, b) => {
            let vc = evalExpr(prog, c, st, scope)
            if truthy(vc) {
                return evalExpr(prog, a, st, scope)
            }
            return evalExpr(prog, b, st, scope)
        }
        Expr.Spread(inner) => {
            // evaluated directly only in odd positions; flattening happens in
            // evalArgs / array literals
            return evalExpr(prog, inner, st, scope)
        }
        Expr.Comma(a, b) => {
            evalExpr(prog, a, st, scope)
            return evalExpr(prog, b, st, scope)
        }
        Expr.RegexLit(pat, flags) => {
            return makeRegex(st, pat.clone(), flags.clone())
        }
        Expr.OptChainRoot(inner) => {
            // scope the short-circuit flag to this chain: a nullish `?.` link
            // anywhere inside makes the whole chain undefined, and nested chains
            // (in args) mustn't leak their own short-circuit outward
            let saved = st.optShort
            st.optShort = false
            let v = evalExpr(prog, inner, st, scope)
            let shorted = st.optShort
            st.optShort = saved
            if shorted {
                return JSValue.Undefined
            }
            return v
        }
        Expr.OptCall(calleeIdx, argsIdx) => {
            // f?.(args): skip the call (result undefined) when f is nullish or an
            // earlier `?.` in the chain already short-circuited
            let calleeVal = evalExpr(prog, calleeIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            if isNullish(calleeVal) {
                st.optShort = true
                return JSValue.Undefined
            }
            pushTemp(st, cloneValue(calleeVal))
            let argVals = evalArgs(prog, argsIdx, st, scope)
            popTemp(st)
            return callValue(prog, calleeVal, argVals, JSValue.Undefined, st)
        }
        Expr.OptIndex(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            if isNullish(ov) {
                st.optShort = true
                return JSValue.Undefined
            }
            pushTemp(st, cloneValue(ov))
            let kv = evalExpr(prog, keyIdx, st, scope)
            popTemp(st)
            let key = toStr(kv)
            let o = objHandle(ov)
            if o >= 0 {
                return getMemberDyn(prog, o, key, st)
            }
            // non-nullish function/native base is a property carrier too
            match ov {
                JSValue.Func(fIdx, fe) => {
                    let statics = getFuncStatics(st, fIdx, fe)
                    return getMember(st, statics, key)
                }
                JSValue.Native(nid) => {
                    return getMember(st, getNativeProps(st, nid), key)
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        Expr.OptMember(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            if isNullish(ov) {
                st.optShort = true
                return JSValue.Undefined
            }
            match ov {
                JSValue.Obj(o) => {
                    return getMemberDyn(prog, o, name, st)
                }
                JSValue.Number(_nv) => {
                    // number primitives answer these by dispatch; without this a
                    // read yields undefined, which breaks feature detection
                    if isPrimitiveMethodName(name) {
                        return makeBoundMethod(st, cloneValue(ov), name.clone())
                    }
                    return JSValue.Undefined
                }
                JSValue.Bool(_bv) => {
                    if isPrimitiveMethodName(name) {
                        return makeBoundMethod(st, cloneValue(ov), name.clone())
                    }
                    return JSValue.Undefined
                }
                JSValue.Str(s) => {
                    if name == "length" {
                        return JSValue.Number(utf16Length(s) as f64)
                    }
                    if name == "description" && isSymbolStr(s) {
                        return JSValue.Str(symbolDescription(s))
                    }
                    if isStringMethodName(name) {
                        return makeBoundMethod(st, JSValue.Str(s.clone()), name.clone())
                    }
                    return JSValue.Undefined
                }
                JSValue.Func(fIdx, fe) => {
                    // a non-nullish function base reads like `.` does: a function
                    // is a property carrier (fn?._def, fn?.name). This was the
                    // missing case — @trpc's `procedure?._def.type`.
                    if name == "prototype" {
                        return JSValue.Obj(getFuncProto(st, fIdx))
                    }
                    if name == "length" {
                        return JSValue.Number(funcArity(prog, fIdx) as f64)
                    }
                    if name == "name" {
                        return JSValue.Str(prog.funcs[fIdx].name.clone())
                    }
                    let statics = getFuncStatics(st, fIdx, fe)
                    return getMember(st, statics, name)
                }
                JSValue.Native(nid) => {
                    let bag = getNativeProps(st, nid)
                    if name == "name" && objOwnIndex(st, bag, "name") < 0 {
                        let nn = nativeCtorName(nid)
                        if nn.len() > 0 {
                            return JSValue.Str(nn)
                        }
                    }
                    return getMember(st, bag, name)
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        Expr.FuncExpr(f) => {
            return JSValue.Func(f, scope)
        }
    }
}

// Spread an array value's elements into `out` (a no-op for non-arrays).
// Spread any iterable: the built-ins directly, and anything carrying
// [Symbol.iterator] by driving its next(). Driving calls back into user code, so
// this needs the program and a mutable interpreter — which is why it is not the
// immutable helper it once was.
fn spreadInto(prog: &Prog, out: &mut Vec<JSValue>, v: &JSValue, st: &mut Interp) {
    let h = objHandle(v)
    // typed arrays are iterable by element
    if h >= 0 && st.objExtras[st.objects[h].extra].taBuf >= 0 && !st.objects[h].isDataView {
        var i: i64 = 0
        while i < st.objExtras[st.objects[h].extra].taLen {
            out.push(JSValue.Number(taElem(st, h, i)))
            i = i + 1
        }
        return
    }
    // a generator drives through genNext (its `next` is native, not a property)
    if h >= 0 && st.objects[h].isGenerator {
        var guard: i64 = 0
        while !st.throwing && guard < 100000000 {
            guard = guard + 1
            var nA: Vec<JSValue> = Vec.new()
            let step = genNext(h, nA, st)
            let sh = objHandle(step)
            if sh < 0 || truthy(getMember(st, sh, "done")) {
                guard = 100000000
            } else {
                out.push(getMember(st, sh, "value"))
            }
        }
        return
    }
    // a Map spreads to freshly built [key, value] pairs, which needs allocation
    if h >= 0 && st.objects[h].isMap {
        var mi: i64 = 0
        while mi < st.objExtras[st.objects[h].extra].mapKeys.len() {
            let pair = newArray(st)
            pushTemp(st, JSValue.Obj(pair))
            arrPush(st, pair, cloneValue(st.objExtras[st.objects[h].extra].mapKeys[mi]))
            arrPush(st, pair, cloneValue(st.objExtras[st.objects[h].extra].mapVals[mi]))
            popTemp(st)
            out.push(JSValue.Obj(pair))
            mi = mi + 1
        }
        return
    }
    if h >= 0 && !st.objects[h].isArray && !st.objects[h].isSet {
        let itFn = getMember(st, h, symIteratorKey())
        if isCallableIn(st, itFn) {
            var noArgs: Vec<JSValue> = Vec.new()
            let iter = callValue(prog, itFn, noArgs, cloneValue(v), st)
            pushTemp(st, cloneValue(iter))
            let ih = objHandle(iter)
            var guard: i64 = 0
            while ih >= 0 && !st.throwing && guard < 100000000 {
                let nextFn = getMember(st, ih, "next")
                if !isCallableIn(st, nextFn) {
                    guard = 100000000
                } else {
                    var nArgs: Vec<JSValue> = Vec.new()
                    let step = callValue(prog, nextFn, nArgs, cloneValue(iter), st)
                    let sh = objHandle(step)
                    if sh < 0 || truthy(getMember(st, sh, "done")) {
                        guard = 100000000
                    } else {
                        out.push(getMember(st, sh, "value"))
                    }
                }
            }
            popTemp(st)
            return
        }
    }
    spreadBuiltin(out, v, st)
}

fn spreadBuiltin(out: &mut Vec<JSValue>, v: &JSValue, st: &Interp) {
    match v {
        JSValue.Obj(o) => {
            if st.objects[o].isArray {
                var k: i64 = 0
                let m = arrLen(st, o)
                while k < m {
                    out.push(arrGet(st, o, k))
                    k = k + 1
                }
            } else if st.objects[o].isSet {
                var k: i64 = 0
                while k < st.objExtras[st.objects[o].extra].mapKeys.len() {
                    out.push(cloneValue(st.objExtras[st.objects[o].extra].mapKeys[k]))
                    k = k + 1
                }
            }
        }
        JSValue.Str(s) => {
            // [..."café"] is ["c","a","f","é"] — code points, not UTF-8 bytes
            for cp in strCodePoints(s) {
                out.push(JSValue.Str(cp.clone()))
            }
        }
        _ => {
        }
    }
}

// `out` is a plain Milo local, invisible to the collector, but evaluating a later
// argument can run user code and therefore collect — so each finished argument is
// temp-rooted until the whole list is built. Without this, f([1,2], g()) can see
// the array swept and its slot reused while g() runs.
fn evalArgs(prog: &Prog, argsIdx: i64, st: &mut Interp, scope: i64): Vec<JSValue> {
    var out: Vec<JSValue> = Vec.new()
    var rooted: i64 = 0
    var j: i64 = 0
    let n = prog.argLists[argsIdx].len()
    while j < n {
        let eIdx = prog.argLists[argsIdx][j]
        match prog.exprs[eIdx] {
            Expr.Spread(inner) => {
                let v = evalExpr(prog, inner, st, scope)
                pushTemp(st, cloneValue(v))
                rooted = rooted + 1
                spreadInto(prog, out, v, st)
            }
            _ => {
                let v = evalExpr(prog, eIdx, st, scope)
                pushTemp(st, cloneValue(v))
                rooted = rooted + 1
                out.push(v)
            }
        }
        j = j + 1
    }
    // the caller binds these into a scope before the next safepoint, so the
    // temp roots can be released here
    var r: i64 = 0
    while r < rooted {
        popTemp(st)
        r = r + 1
    }
    return out
}

fn spaces(n: i64): string {
    var s = ""
    var i: i64 = 0
    while i < n {
        s = s + " "
        i = i + 1
    }
    return s
}

// Reproduces bun's console.log object rendering: one property per line, indented
// two spaces per level, a trailing comma after every entry, string *values*
// double-quoted, closing brace at the parent indent. `{}` stays inline. Nesting
// past depth 2 collapses to `[Object]`. A top-level string prints raw (see
// inspectTop) — only nested strings are quoted.
fn inspectInner(st: &Interp, v: &JSValue, depth: i64): string {
    match v {
        JSValue.Str(s) => {
            // a symbol is a tagged string internally; console.log shows it as
            // Symbol(desc) without quotes, not the raw "@@sym:..." form
            if isSymbolStr(s) {
                return symbolDisplay(s)
            }
            return "\"" + s + "\""
        }
        JSValue.BigInt(s) => {
            // console.log shows a BigInt with the trailing `n` (String() does not)
            return s + "n"
        }
        JSValue.Obj(o) => {
            return inspectObj(st, o, depth)
        }
        _ => {
            return toStr(v)
        }
    }
}

// bun renders short arrays inline: `[ 1, 2, "x" ]`, empty as `[]`.
fn inspectArr(st: &Interp, o: i64, depth: i64): string {
    if depth > 2 {
        return "[Array]"
    }
    let n = st.objects[o].elems.len()
    if n == 0 {
        return "[]"
    }
    var out = "[ "
    var i: i64 = 0
    while i < n {
        if i > 0 {
            out = out + ", "
        }
        let v = cloneValue(st.objects[o].elems[i])
        out = out + inspectInner(st, v, depth + 1)
        i = i + 1
    }
    out = out + " ]"
    return out
}

fn objIsoOrTag(st: &Interp, o: i64): string {
    return isoFromMillis(st.objExtras[st.objects[o].extra].dateMs)
}

fn inspectObj(st: &Interp, o: i64, depth: i64): string {
    if st.objects[o].isArray {
        return inspectArr(st, o, depth)
    }
    // an Error prints as "Name: message [\n stack]", like node's console
    if st.objects[o].isError {
        let ename = toStr(objGet(st, o, "name"))
        let emsg = toStr(objGet(st, o, "message"))
        let estack = objGet(st, o, "stack")
        var head = ename.clone()
        if emsg.len() > 0 {
            head = ename + ": " + emsg
        }
        // console.log(error) prints the stack, which already begins with the
        // "Name: message" header (node appends the trace after it); fall back to
        // the header when there is no stack
        match estack {
            JSValue.Str(sv) => {
                if sv.len() > 0 {
                    return sv
                }
            }
            _ => {
            }
        }
        return head
    }
    if st.objects[o].isDate {
        return objIsoOrTag(st, o)
    }
    if depth > 2 {
        return "[Object]"
    }
    let n = st.objects[o].props.len()
    if n == 0 {
        return "{}"
    }
    let inner = spaces((depth + 1) * 2)
    let outer = spaces(depth * 2)
    var out = "{\n"
    var i: i64 = 0
    while i < n {
        if !st.objects[o].props[i].enumerable {
            i = i + 1
            continue
        }
        let key = st.objects[o].props[i].key.clone()
        let val = cloneValue(st.objects[o].props[i].value)
        out = out + inner + key + ": " + inspectInner(st, val, depth + 1) + ",\n"
        i = i + 1
    }
    out = out + outer + "}"
    return out
}

fn inspectTop(st: &Interp, v: &JSValue): string {
    match v {
        JSValue.Obj(o) => {
            return inspectObj(st, o, 0)
        }
        JSValue.BigInt(s) => {
            return s + "n"
        }
        JSValue.Str(s) => {
            // a bare string logs unquoted (console.log("hi") → hi), but a symbol
            // (a tagged string) logs as Symbol(desc), not its "@@sym:..." form
            if isSymbolStr(s) {
                return symbolDisplay(s)
            }
            return s.clone()
        }
        _ => {
            return toStr(v)
        }
    }
}

// Invoke a Milo-level JS function: a fresh scope off the closure's captured env,
// with `this` and the parameters bound, then run the body. argVals is consumed.

fn callFunction(prog: &Prog, fIdx: i64, envIdx: i64, argVals: Vec<JSValue>, thisVal: JSValue, st: &mut Interp): JSValue {
    // R1: an async call runs its body on its own activation and returns at that
    // body's first await. Cleared immediately so a nested async call spawns.
    let alreadyOnActivation = st.suppressAsyncSpawn
    st.suppressAsyncSpawn = false
    if prog.funcs[fIdx].isAsync && !alreadyOnActivation {
        let caller = schedulerCurrent()
        if caller as i64 != 0 {
            return spawnActivation(fIdx, envIdx, argVals, thisVal, st, caller)
        }
    }
    // Without this, runaway recursion exhausts the native stack and the process
    // dies with no JS-level error — express's error middleware expects a
    // catchable RangeError instead.
    // Each JS frame costs several large native tree-walker frames, so the safe
    // limit tracks the stack the interpreter runs on: st.callDepthLimit, set per
    // binary. The engine runs the program on the main thread (a small default
    // stack on Linux), where a high limit exhausts the native stack before the
    // guard can construct and unwind the catchable error — so it stays low (20).
    // The runtime runs the program on an 8 MB green task, where 20 is far too
    // shallow for real code (express/tRPC middleware nests well past it and threw
    // the very RangeError this guard exists to make catchable), so it sets a much
    // higher limit that still lands safely inside 8 MB.
    if st.callDepth >= st.callDepthLimit {
        st.throwing = true
        st.thrownValue = makeError(st, "RangeError", "Maximum call stack size exceeded")
        return JSValue.Undefined
    }
    let genBody = st.suppressGenSpawn
    st.suppressGenSpawn = false
    if prog.funcs[fIdx].isGenerator && !genBody {
        return makeGenerator(fIdx, envIdx, argVals, thisVal, st)
    }
    st.callDepth = st.callDepth + 1
    let callScope = newScope(st, envIdx)
    // root the frame across the whole call so a GC inside the body (or a nested
    // call) can't reclaim it
    pushActive(st, callScope)
    // arrows have no own `this` — it stays lexical (resolved up the scope chain)
    if !prog.funcs[fIdx].isArrow {
        scopeDefine(st, callScope, "this", thisVal)
        // new.target is the constructor this frame was invoked with, or
        // undefined for a plain call
        scopeDefine(st, callScope, "new.target", cloneValue(st.newTarget))
        // a named function expression can refer to itself by name from inside its
        // own body, even though the name is not bound in the enclosing scope
        let selfName = prog.funcs[fIdx].name.clone()
        if selfName.len() > 0 {
            scopeDefine(st, callScope, selfName, JSValue.Func(fIdx, envIdx))
        }
    }
    var j: i64 = 0
    let nParams = prog.funcs[fIdx].params.len()
    let restFrom = prog.funcs[fIdx].restFrom
    while j < nParams {
        let pName = prog.funcs[fIdx].params[j].clone()
        if j == restFrom {
            let rest = newArray(st)
            var r = j
            while r < argVals.len() {
                arrPush(st, rest, cloneValue(argVals[r]))
                r = r + 1
            }
            scopeDefine(st, callScope, pName, JSValue.Obj(rest))
        } else {
            var v = JSValue.Undefined
            if j < argVals.len() {
                v = cloneValue(argVals[j])
            }
            scopeDefine(st, callScope, pName, v)
        }
        j = j + 1
    }
    // `arguments` — ES5 libraries lean on it for variadics (path.join etc).
    // Arrows don't get their own, matching JS.
    if !prog.funcs[fIdx].isArrow {
        let argsArr = newArray(st)
        var ai: i64 = 0
        while ai < argVals.len() {
            arrPush(st, argsArr, cloneValue(argVals[ai]))
            ai = ai + 1
        }
        scopeDefine(st, callScope, "arguments", JSValue.Obj(argsArr))
    }
    let body = prog.funcs[fIdx].body
    // `var`s and nested function declarations belong to the whole call frame
    hoistBlock(prog, body, st, callScope)
    let flow = execBlock(prog, body, st, callScope)
    popActive(st)
    st.callDepth = st.callDepth - 1
    var result = JSValue.Undefined
    match flow {
        Flow.Ret(v) => {
            result = v
        }
        _ => {
        }
    }
    if prog.funcs[fIdx].isAsync {
        // an async body that threw yields a rejected promise instead of
        // propagating the throw to its (synchronous) caller
        if st.throwing {
            let err = cloneValue(st.thrownValue)
            st.throwing = false
            st.thrownValue = JSValue.Undefined
            return JSValue.Obj(newPromise(st, 2, err))
        }
        // already-promise results are adopted rather than double-wrapped
        let ro = objHandle(result)
        if ro >= 0 && isPromise(st, ro) {
            return result
        }
        return JSValue.Obj(newPromise(st, 1, result))
    }
    return result
}

// Invoke any callable JSValue (user function or native).
// Build a class: the constructor becomes the class value, instance methods go on
// its prototype, statics on its own property bag. `extends` chains the prototype
// so instances inherit the base's methods, and records the base constructor
// under __super$<Name> so super(...) can find it.
// Best-effort name for a callee expression, so "is not a function" says which
// one. Diagnostics only.
fn describeCallee(prog: &Prog, calleeIdx: i64): string {
    match prog.exprs[calleeIdx] {
        Expr.Ident(n) => {
            return n.clone()
        }
        Expr.Member(_o, n) => {
            return "." + n.clone()
        }
        Expr.OptMember(_o, n) => {
            return "?." + n.clone()
        }
        Expr.OptIndex(_o, _k) => {
            return "?.[]"
        }
        _ => {
            return "value"
        }
    }
}

// A real Error object, so catch blocks see .name/.message and instanceof works.
// Raise a TypeError and yield undefined, for the proxy traps.
fn throwTypeErr(st: &mut Interp, msg: string): JSValue {
    st.throwing = true
    st.thrownValue = makeError(st, "TypeError", msg)
    return JSValue.Undefined
}

// The handler trap `name`, or undefined when the handler does not define it.
fn proxyTrap(st: &Interp, o: i64, name: &string): JSValue {
    let h = objHandle(st.objExtras[st.objects[o].extra].proxyHandler)
    if h < 0 {
        return JSValue.Undefined
    }
    return getMember(st, h, name)
}

// Enumerable own string keys of a proxy: the ownKeys trap supplies the list,
// then each key is kept only if its descriptor (getOwnPropertyDescriptor trap,
// falling back to the target's own descriptor) says enumerable. Missing ownKeys
// forwards to the target. Feeds for-in and Object.keys.
fn proxyOwnEnumKeys(prog: &Prog, st: &mut Interp, o: i64): Vec<string> {
    var out: Vec<string> = Vec.new()
    let target = cloneValue(st.objExtras[st.objects[o].extra].proxyTarget)
    let trap = proxyTrap(st, o, "ownKeys")
    var keyList: Vec<string> = Vec.new()
    if isCallableIn(st, trap) {
        var args: Vec<JSValue> = Vec.new()
        args.push(cloneValue(target))
        let res = callValue(prog, trap, args, cloneValue(st.objExtras[st.objects[o].extra].proxyHandler), st)
        if st.throwing {
            return out
        }
        let rh = objHandle(res)
        if rh >= 0 && st.objects[rh].isArray {
            var i: i64 = 0
            while i < arrLen(st, rh) {
                let kv = arrGet(st, rh, i)
                keyList.push(toStr(kv))
                i = i + 1
            }
        }
    } else {
        let th = objHandle(target)
        if th >= 0 {
            if st.objects[th].isArray {
                var e: i64 = 0
                while e < arrLen(st, th) {
                    if !arrIsHole(st, th, e) {
                        out.push(i64ToStr(e))
                    }
                    e = e + 1
                }
            }
            let order = enumOrder(st, th)
            var oi: i64 = 0
            while oi < order.len() {
                let k = order[oi]
                if st.objects[th].props[k].enumerable {
                    out.push(st.objects[th].props[k].key.clone())
                }
                oi = oi + 1
            }
        }
        return out
    }
    let dtrap = proxyTrap(st, o, "getOwnPropertyDescriptor")
    var i: i64 = 0
    while i < keyList.len() {
        if isCallableIn(st, dtrap) {
            var dargs: Vec<JSValue> = Vec.new()
            dargs.push(cloneValue(target))
            dargs.push(JSValue.Str(keyList[i].clone()))
            let d = callValue(prog, dtrap, dargs, cloneValue(st.objExtras[st.objects[o].extra].proxyHandler), st)
            if st.throwing {
                return out
            }
            let dh = objHandle(d)
            if dh >= 0 && truthy(getMember(st, dh, "enumerable")) {
                out.push(keyList[i].clone())
            }
        } else {
            let th = objHandle(target)
            if th >= 0 {
                let pi = objOwnIndex(st, th, keyList[i])
                if pi >= 0 {
                    if st.objects[th].props[pi].enumerable {
                        out.push(keyList[i].clone())
                    }
                } else if st.objects[th].isArray {
                    let ai = asArrayIndex(keyList[i])
                    if ai >= 0 && ai < arrLen(st, th) && !arrIsHole(st, th, ai) {
                        out.push(keyList[i].clone())
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}

fn makeError(st: &mut Interp, kind: string, msg: string): JSValue {
    let o = newObject(st)
    st.objects[o].isError = true
    objSet(st, o, "name", JSValue.Str(kind.clone()))
    objSet(st, o, "message", JSValue.Str(msg.clone()))
    // a string stack (headed "Name: message") so a caught runtime error's .stack
    // is a string, like a constructed Error's — no real backtrace available
    var stackHead = kind.clone()
    if msg.len() > 0 {
        stackHead = stackHead + ": " + msg
    }
    objSet(st, o, "stack", JSValue.Str(stackHead))
    return JSValue.Obj(o)
}

fn isSymbolValue(v: &JSValue): bool {
    match v {
        JSValue.Str(s) => {
            if s.len() < 6 {
                return false
            }
            return s[0] == '@' && s[1] == '@' && s[2] == 's' && s[3] == 'y' && s[4] == 'm' && s[5] == ':'
        }
        _ => {
            return false
        }
    }
}

// The well-known @@iterator key. Symbols are interned strings, so this is just a
// fixed one; counter 0 is reserved because user symbols start at 1.
fn symIteratorKey(): string {
    return "@@sym:Symbol.iterator:0"
}

fn symToPrimitiveKey(): string {
    return "@@sym:Symbol.toPrimitive:0"
}

fn symToStringTagKey(): string {
    return "@@sym:Symbol.toStringTag:0"
}

// Symbol test on the raw string. The JSValue-level isSymbolValue cannot be used
// from inside a `match` arm on that same value: matching moves it, so reading the
// original binding afterwards sees a zeroed slot and the test silently fails.
fn isSymbolStr(s: &string): bool {
    if s.len() < 6 {
        return false
    }
    return s[0] == '@' && s[1] == '@' && s[2] == 's' && s[3] == 'y' && s[4] == 'm' && s[5] == ':'
}

// The description inside "@@sym:<desc>:<counter>". The counter is what makes two
// same-description symbols distinct, so it is stripped from the LAST colon —
// a description may itself contain colons.
fn symbolDescription(s: &string): string {
    var cut = s.len()
    var i = s.len() - 1
    var found = false
    while i >= 6 && !found {
        if s[i] == ':' {
            cut = i
            found = true
        }
        i = i - 1
    }
    var out = String.withCapacity(cut)
    var j: i64 = 6
    while j < cut {
        out.push(s[j])
        j = j + 1
    }
    return out
}

// What a symbol shows as: Symbol(desc). Without this the internal representation
// leaks out of String(sym) and sym.toString().
fn symbolDisplay(s: &string): string {
    return "Symbol(" + symbolDescription(s) + ")"
}

// Drain every queued microtask. Microtasks may enqueue more, which is correct:
// JS runs the queue to exhaustion before the next timer.
// Settle a promise and queue every reaction that was waiting on it. Settling
// twice is ignored, as in JS.
// Run threadsafe-function calls queued by an addon's own threads, then apply any
// promise settlements they made. This is the only place a foreign thread's work
// crosses into the interpreter.
// Settle any fetch whose worker thread has finished. Called from the event loop
// and from a blocked await, the same way node-api work is serviced.
fn serviceFetches(st: &mut Interp) {
    var i: i64 = 0
    while i < st.fetches.len() {
        var done = false
        var payload = ""
        match st.fetches[i].chan.tryRecv() {
            Option.Some(v) => {
                payload = v
                done = true
            }
            Option.None => {
            }
        }
        if done {
            let p = st.fetches[i].promise
            st.fetches[i].chan.destroy()
            st.fetches.remove(i)
            settlePromise(st, p, 1, JSValue.Str(payload))
        } else {
            i = i + 1
        }
    }
}

fn hasPendingFetches(st: &Interp): bool {
    return st.fetches.len() > 0
}

fn napiServiceTsfn(st: &mut Interp) {
    if !napiHasTsfn() {
        return
    }
    var q = napiPollTsfn()
    var i: i64 = 0
    while i < q.len() {
        let _r = napiRunTsfnCall(q[i])
        i = i + 1
    }
    napiDrainSettlements(st)
}

// Apply promise settlements an addon requested while it held control.
fn napiDrainSettlements(st: &mut Interp) {
    var q = napiTakePending()
    var i: i64 = 0
    while i < q.len() {
        settlePromise(st, q[i].promise, q[i].state, cloneValue(q[i].value))
        i = i + 1
    }
}

// Let the caller of this activation continue. Called at the activation's first
// suspension point, and at completion if it never suspends — an async call
// returns once its body reaches the first await, not when the body finishes.
fn releaseCreatorOnce(st: &mut Interp) {
    let me = schedulerCurrent()
    if me as i64 == 0 {
        return
    }
    var i: i64 = 0
    while i < st.actTask.len() {
        if st.actTask[i] as i64 == me as i64 {
            if !st.actNotified[i] {
                st.actNotified[i] = true
                schedulerUnpark(st.actCreator[i])
            }
            return
        }
        i = i + 1
    }
}

// Drop this activation's bookkeeping and its pre-bind roots once the body ends.
// An activation reaching any await hands control back to whoever called it and
// lets the scheduler run them before this body continues. A no-op off an
// activation: the main task owns the event loop and must not yield here.
fn yieldAtAwait(st: &mut Interp) {
    let me = schedulerCurrent()
    if me as i64 == 0 {
        return
    }
    var onActivation = false
    var i: i64 = 0
    while i < st.actTask.len() {
        if st.actTask[i] as i64 == me as i64 {
            onActivation = true
        }
        i = i + 1
    }
    if !onActivation {
        return
    }
    releaseCreatorOnce(st)
    schedulerYield()
}

fn endActivation(st: &mut Interp) {
    let me = schedulerCurrent()
    if me as i64 == 0 {
        return
    }
    var i: i64 = 0
    while i < st.actTask.len() {
        if st.actTask[i] as i64 == me as i64 {
            st.actTask.remove(i)
            st.actCreator.remove(i)
            st.actNotified.remove(i)
            st.actEnv.remove(i)
            st.actArgs.remove(i)
            st.actThis.remove(i)
            st.actPromise.remove(i)
            return
        }
        i = i + 1
    }
}

// R1: run an async body on its own green task and hand the caller a pending
// promise as soon as that body reaches its first await.
//
// The caller parks straight after spawning. Tasks are cooperative and only one
// runs at a time, so the body cannot start before that park — there is no race
// between spawning and waiting.
fn spawnActivation(fIdx: i64, envIdx: i64, argVals: Vec<JSValue>, thisVal: JSValue, st: &mut Interp, caller: *u8): JSValue {
    let p = newPromise(st, 0, JSValue.Undefined)
    var rootedArgs: Vec<JSValue> = Vec.new()
    var ri: i64 = 0
    while ri < argVals.len() {
        rootedArgs.push(cloneValue(argVals[ri]))
        ri = ri + 1
    }
    let rootedThis = cloneValue(thisVal)
    var args = argVals
    let body = Task.spawnWithStack(move(): void => {
        // gProg/gInterp rather than captured references: a task body cannot hold
        // a borrow from the frame that spawned it (docs/proposal-task-shared-state.md)
        gInterp.suppressAsyncSpawn = true
        let r = callFunction(gProg, fIdx, envIdx, args, thisVal, gInterp)
        if gInterp.throwing {
            let err = cloneValue(gInterp.thrownValue)
            gInterp.throwing = false
            gInterp.thrownValue = JSValue.Undefined
            settlePromise(gInterp, p, 2, err)
        } else {
            let ro = objHandle(r)
            if ro >= 0 && isPromise(gInterp, ro) {
                let rs = gInterp.objects[ro].promiseState
                if rs == 0 {
                    // The body returned a still-pending promise (e.g. `return
                    // fetchData(url).then(...)`). Reading its state now settles the
                    // activation's promise with `pending`, which is a no-op — the
                    // caller's await then hangs forever. Instead adopt it: a
                    // reaction with non-callable handlers passes the returned
                    // promise's eventual settlement straight through to `p`.
                    gInterp.objExtras[gInterp.objects[ro].extra].reactions.push(Reaction {
                        onFulfilled: JSValue.Undefined, onRejected: JSValue.Undefined, derived: p, isFinally: false
                    }
                    )
                } else {
                    // the inner promise's settlement is forwarded to the
                    // activation promise, so it is handled — clear it from the
                    // unhandled set (a throwing async body wraps its rejection in
                    // a fresh newPromise(2) that was flagged unhandled at birth;
                    // without this a caught `await asyncThatThrows()` printed a
                    // spurious "unhandled promise rejection")
                    if rs == 2 {
                        markRejectHandled(gInterp, ro)
                    }
                    settlePromise(gInterp, p, rs, cloneValue(gInterp.objExtras[gInterp.objects[ro].extra].promiseValue))
                }
            } else {
                settlePromise(gInterp, p, 1, r)
            }
        }
        // a body that never awaited still has to let its caller go
        releaseCreatorOnce(gInterp)
        endActivation(gInterp)
    }
    , 8388608)
    st.actTask.push(body._ptr)
    st.actCreator.push(caller)
    st.actNotified.push(false)
    st.actEnv.push(envIdx)
    st.actArgs.push(rootedArgs)
    st.actThis.push(rootedThis)
    st.actPromise.push(p)
    // Root the activation's promise across the park: until this task resumes
    // and its caller binds the returned value, `p` is held only by native
    // locals and the body closure — neither is a GC root — so a collect while
    // the body runs sweeps it and recycles the slot. Observed as awaits
    // resolving with foreign values ("json is not a function") or never
    // (reaction list wiped on reuse) under concurrent fetches. Pushed before
    // saveExecCtx so it rides in the suspended ctx that collect marks.
    pushTemp(st, JSValue.Obj(p))
    // the body runs while this task is parked; it unparks us at its first await
    let ctx = saveExecCtx(st)
    st.suspended.push(ctx)
    st.suspendedTask.push(caller)
    schedulerPark()
    resumeExecCtx(st, caller)
    popTemp(st)
    return JSValue.Obj(p)
}

// Take back the execution belonging to `task`, wherever it sits in the parked
// set. Parks and wakes interleave, so position says nothing about ownership.
fn resumeExecCtx(st: &mut Interp, task: *u8) {
    var i: i64 = 0
    while i < st.suspendedTask.len() {
        if st.suspendedTask[i] as i64 == task as i64 {
            let back = st.suspended.remove(i)
            st.suspendedTask.remove(i)
            restoreExecCtx(st, back)
            return
        }
        i = i + 1
    }
}

// R2 of docs/milojs-async-suspension.md. Park the running activation until
// `p` settles. Only legal off the main task: the main task runs the event loop,
// so parking it would stop the timers and off-thread servicing that settle
// promises in the first place — that path still drains in place.
//
// Returns false when parking is not possible, so the caller can fall back.
// A settled `await` still yields to the microtask queue in node (the continuation
// is queued as a microtask). Run the microtasks pending RIGHT NOW — a snapshot,
// so ones they queue run after this await, matching node — inline: no park, so
// the activation's own ExecCtx (tempRoots/active scopes) stays live in the Interp
// and rooted (the reverted R1a attempt bypassed that by yielding the task). Only
// on an activation task; the main event-loop task drains microtasks itself.
fn awaitYieldMicrotasks(prog: &Prog, st: &mut Interp) {
    let me = schedulerCurrent()
    if me as i64 == 0 || me as i64 == st.mainTask as i64 {
        return
    }
    let snap = st.microtasks.len()
    if snap > 0 {
        drainMicrotasks(prog, st, snap)
    }
}

fn parkOnPromise(st: &mut Interp, p: i64): bool {
    let me = schedulerCurrent()
    if me as i64 == 0 || me as i64 == st.mainTask as i64 {
        return false
    }
    // Already settled: there is nothing to wait for, and parking would be
    // permanent — the wake happens at settle time, which has passed.
    if st.objects[p].promiseState != 0 {
        return true
    }
    // reaching an await is what makes the async call return to its caller
    releaseCreatorOnce(st)
    st.awaitPromise.push(p)
    st.awaitTask.push(me)
    // the activation's execution leaves the Interp with it; whoever runs next
    // starts clean, and collect keeps these roots alive (R6, R7)
    let ctx = saveExecCtx(st)
    st.suspended.push(ctx)
    st.suspendedTask.push(me)
    schedulerPark()
    // Resumed: take back OUR execution, found by task identity. Taking the last
    // entry instead hands this activation someone else's state — its pops then
    // unroot that activation's scopes and the collector sweeps frames that are
    // still live, which surfaces later as an identifier that no longer resolves.
    resumeExecCtx(st, me)
    return true
}

// ── generators ──────────────────────────────────────────────────────────────
// A `function*` call returns a generator object whose body runs on its own green
// task, reusing the async-suspension machinery: `yield` and `next()` hand control
// back and forth via schedulerPark/Unpark + the ExecCtx save/restore that the
// `suspended` set already does. The body task is spawned LAZILY on the first
// next(), which is what keeps a fresh generator paused — calling a gen* runs no
// user code. Because each generator body has its own dedicated task, `yield`
// finds its generator by schedulerCurrent()==genTask; no per-task current-gen
// stack is needed even for nested generators (a design simplification over
// docs/milojs-generators.md, which assumed a shared task).

// True if any generator has been started but not run to completion, so its body
// task is parked forever. Such a task keeps the scheduler's task count > 0, which
// would block main's final -1 poll and hang the process at exit — Node instead
// drops an unfinished generator, so the entry point exits directly when this holds.
fn anyGenParked(st: &Interp): bool {
    var i: i64 = 0
    while i < st.genObj.len() {
        if st.genStarted[i] && !st.genDone[i] {
            return true
        }
        i = i + 1
    }
    return false
}

// Drop a completed generator's record. Left in place, its stale body-task
// pointer would collide with a future generator whose freshly-spawned task
// reuses the same freed address — genIndexOfTask would then resolve `yield` to
// the wrong (dead) record and write the yielded value into the wrong slot, so
// the real consumer reads a stale value. Object indices of removed generators
// are free to be recycled since collect no longer marks them.
fn removeGen(st: &mut Interp, gi: i64) {
    st.genObj.remove(gi)
    st.genFn.remove(gi)
    st.genTask.remove(gi)
    st.genEnv.remove(gi)
    st.genArgs.remove(gi)
    st.genThis.remove(gi)
    st.genYielded.remove(gi)
    st.genSent.remove(gi)
    st.genDone.remove(gi)
    st.genThrew.remove(gi)
    st.genErr.remove(gi)
    st.genCaller.remove(gi)
    st.genStarted.remove(gi)
}

// Index of the gen* record for gen object `o`, or -1.
fn genIndexOf(st: &Interp, o: i64): i64 {
    var i: i64 = 0
    while i < st.genObj.len() {
        if st.genObj[i] == o {
            return i
        }
        i = i + 1
    }
    return -1
}

// Index of the gen* record whose body task is `task`, or -1 — how `yield`
// resolves which generator it belongs to.
fn genIndexOfTask(st: &Interp, task: *u8): i64 {
    var i: i64 = 0
    while i < st.genTask.len() {
        if st.genTask[i] as i64 == task as i64 {
            return i
        }
        i = i + 1
    }
    return -1
}

// Build a `{ value, done }` iterator-result object.
fn iterResult(st: &mut Interp, value: JSValue, done: bool): JSValue {
    let r = newObject(st)
    pushTemp(st, JSValue.Obj(r))
    objSet(st, r, "value", value)
    objSet(st, r, "done", JSValue.Bool(done))
    popTemp(st)
    return JSValue.Obj(r)
}

// Called when a generator body finishes (return or fell off the end). Records the
// return value (or the thrown error), marks it done, and hands control back to
// whoever is inside next(). Runs on the generator's own task.
fn genFinish(st: &mut Interp, gi: i64, r: JSValue) {
    if st.throwing {
        st.genThrew[gi] = true
        st.genErr[gi] = cloneValue(st.thrownValue)
        st.throwing = false
        st.thrownValue = JSValue.Undefined
        st.genYielded[gi] = JSValue.Undefined
    } else {
        st.genYielded[gi] = cloneValue(r)
    }
    st.genDone[gi] = true
    // hand control back to the next() caller; this task then returns and ends
    schedulerUnpark(st.genCaller[gi])
}

// Create a generator object for a `function*` call. Does NOT run the body — that
// starts on the first next(). Registers the gen* record and returns the object.
fn makeGenerator(fIdx: i64, envIdx: i64, argVals: Vec<JSValue>, thisVal: JSValue, st: &mut Interp): JSValue {
    let g = newObject(st)
    st.objects[g].isGenerator = true
    var rootedArgs: Vec<JSValue> = Vec.new()
    var ri: i64 = 0
    while ri < argVals.len() {
        rootedArgs.push(cloneValue(argVals[ri]))
        ri = ri + 1
    }
    st.genObj.push(g)
    st.genFn.push(fIdx)
    st.genTask.push(0 as *u8)
    st.genEnv.push(envIdx)
    st.genArgs.push(rootedArgs)
    st.genThis.push(cloneValue(thisVal))
    st.genYielded.push(JSValue.Undefined)
    st.genSent.push(JSValue.Undefined)
    st.genDone.push(false)
    st.genThrew.push(false)
    st.genErr.push(JSValue.Undefined)
    st.genCaller.push(0 as *u8)
    st.genStarted.push(false)
    return JSValue.Obj(g)
}

// gen.next(v): drive the generator one step. Spawns the body task on the first
// call. Parks the caller and runs the body until its next `yield`, `return`, or
// throw, then returns `{ value, done }`. If the body threw, the error is
// re-raised at this next() site.
fn genNext(o: i64, args: Vec<JSValue>, st: &mut Interp): JSValue {
    let gi = genIndexOf(st, o)
    if gi < 0 {
        // No record: a completed generator whose record was reclaimed (calling
        // next() on a done generator yields {done:true} forever in JS), or a
        // genuinely non-generator receiver.
        if o >= 0 && st.objects[o].isGenerator {
            return iterResult(st, JSValue.Undefined, true)
        }
        st.throwing = true
        st.thrownValue = makeError(st, "TypeError", "not a generator")
        return JSValue.Undefined
    }
    if st.genDone[gi] {
        removeGen(st, gi)
        return iterResult(st, JSValue.Undefined, true)
    }
    let caller = schedulerCurrent()
    if caller as i64 == 0 {
        // no green task to drive the body (engine main thread) — generators need
        // the runtime's task scheduler; see the R1b note in the suspension doc
        st.throwing = true
        st.thrownValue = makeError(st, "TypeError", "generators require the milojs runtime (not the engine)")
        return JSValue.Undefined
    }
    var sentArg = JSValue.Undefined
    if args.len() > 0 {
        sentArg = cloneValue(args[0])
    }
    st.genSent[gi] = sentArg
    st.genCaller[gi] = caller
    var justSpawned = false
    if !st.genStarted[gi] {
        st.genStarted[gi] = true
        justSpawned = true
        let fIdx = st.genFn[gi]
        let envIdx = st.genEnv[gi]
        var bodyArgs: Vec<JSValue> = Vec.new()
        var ai: i64 = 0
        while ai < st.genArgs[gi].len() {
            bodyArgs.push(cloneValue(st.genArgs[gi][ai]))
            ai = ai + 1
        }
        let bodyThis = cloneValue(st.genThis[gi])
        let genObjIdx = o
        let body = Task.spawnWithStack(move(): void => {
            // gProg/gInterp: a task body cannot borrow from the spawning frame.
            // Run the function* body (not another makeGenerator) — see callFunction.
            gInterp.suppressGenSpawn = true
            let r = callFunction(gProg, fIdx, envIdx, bodyArgs, bodyThis, gInterp)
            let fgi = genIndexOf(gInterp, genObjIdx)
            if fgi >= 0 {
                genFinish(gInterp, fgi, r)
            }
        }
        , 8388608)
        st.genTask[gi] = body._ptr
    }
    // Root the gen object across the park: its record vectors reference it, but
    // the caller may hold it only in a temp the save/restore does not cover.
    pushTemp(st, JSValue.Obj(o))
    let ctx = saveExecCtx(st)
    st.suspended.push(ctx)
    st.suspendedTask.push(caller)
    // A just-spawned body task is already runnable; parking the caller hands it
    // control (mirrors spawnActivation). Only a body parked at a prior yield
    // needs an explicit unpark to become runnable again.
    if !justSpawned {
        schedulerUnpark(st.genTask[gi])
    }
    schedulerPark()
    resumeExecCtx(st, caller)
    popTemp(st)
    // re-read the record: a nested generator could have shuffled the vectors
    let gj = genIndexOf(st, o)
    if gj < 0 {
        return iterResult(st, JSValue.Undefined, true)
    }
    if st.genThrew[gj] {
        st.throwing = true
        st.thrownValue = cloneValue(st.genErr[gj])
        // the body ended (by throwing); its record is dead
        removeGen(st, gj)
        return JSValue.Undefined
    }
    let done = st.genDone[gj]
    let yielded = cloneValue(st.genYielded[gj])
    // the body ran off the end / returned; drop the record so its stale task
    // pointer cannot collide with a future generator's reused task address
    if done {
        removeGen(st, gj)
    }
    return iterResult(st, yielded, done)
}

// The `yield e` expression, evaluated on a generator's body task. `handed` is the
// already-evaluated operand. Hands it out, parks the body, and on resume returns
// the value the next() caller passed in.
fn genYield(handed: JSValue, st: &mut Interp): JSValue {
    let me = schedulerCurrent()
    let gi = genIndexOfTask(st, me)
    if gi < 0 {
        // `yield` outside any generator body — not reachable through the parser,
        // which only emits it inside a function*, but fail soft rather than wedge
        return JSValue.Undefined
    }
    st.genYielded[gi] = cloneValue(handed)
    st.genDone[gi] = false
    // root the gen object across the park, like genNext does
    pushTemp(st, JSValue.Obj(st.genObj[gi]))
    let ctx = saveExecCtx(st)
    st.suspended.push(ctx)
    st.suspendedTask.push(me)
    schedulerUnpark(st.genCaller[gi])
    schedulerPark()
    resumeExecCtx(st, me)
    popTemp(st)
    let gj = genIndexOfTask(st, me)
    if gj < 0 {
        return JSValue.Undefined
    }
    return cloneValue(st.genSent[gj])
}

// Wake every activation waiting on `p`, in the order they began awaiting (R3).
fn wakeAwaiters(st: &mut Interp, p: i64) {
    var i: i64 = 0
    while i < st.awaitPromise.len() {
        if st.awaitPromise[i] == p {
            let t = st.awaitTask[i]
            st.awaitPromise.remove(i)
            st.awaitTask.remove(i)
            schedulerUnpark(t)
        } else {
            i = i + 1
        }
    }
}

fn settlePromise(st: &mut Interp, p: i64, state: i64, value: JSValue) {
    if p < 0 || !isPromise(st, p) {
        return
    }
    if st.objects[p].promiseState != 0 {
        return
    }
    st.objects[p].promiseState = state
    st.objExtras[st.objects[p].extra].promiseValue = cloneValue(value)
    // an activation parked in `await p` IS a handler — the rejection is delivered
    // to it (to catch, or to re-reject its own promise). Capture that before
    // wakeAwaiters clears the registry, or Promise.any-style rejections that are
    // awaited-and-caught get falsely reported as unhandled.
    var hadAwaiter = false
    var ai: i64 = 0
    while ai < st.awaitPromise.len() {
        if st.awaitPromise[ai] == p {
            hadAwaiter = true
            ai = st.awaitPromise.len()
        } else {
            ai = ai + 1
        }
    }
    // wake activations parked on this promise before running reactions (R2/R3)
    wakeAwaiters(st, p)
    if state == 2 && st.objExtras[st.objects[p].extra].reactions.len() == 0 && !hadAwaiter {
        // nobody is waiting on this rejection; report it when the loop idles
        // unless a .catch attaches first
        st.unhandledRejects.push(p)
    }
    var i: i64 = 0
    while i < st.objExtras[st.objects[p].extra].reactions.len() {
        var handler = cloneValue(st.objExtras[st.objects[p].extra].reactions[i].onFulfilled)
        if state == 2 {
            handler = cloneValue(st.objExtras[st.objects[p].extra].reactions[i].onRejected)
        }
        st.microtasks.push(Microtask {
            cb: handler, arg: cloneValue(value), derived: st.objExtras[st.objects[p].extra].reactions[i].derived, passthroughReject: state == 2, isFinally: st.objExtras[st.objects[p].extra].reactions[i].isFinally, noArgs: false
        }
        )
        i = i + 1
    }
    st.objExtras[st.objects[p].extra].reactions = Vec.new()
}

// Awaiting or attaching a handler to a rejected promise counts as handling it,
// so drop it from the unhandled-rejection set reported at loop end. (Without this,
// `try { await Promise.reject(e) } catch {}` still printed a spurious unhandled
// rejection — GC-masked, since a collected promise slot was skipped at reporting.)
fn markRejectHandled(st: &mut Interp, p: i64) {
    var kept: Vec<i64> = Vec.new()
    var ki: i64 = 0
    while ki < st.unhandledRejects.len() {
        if st.unhandledRejects[ki] != p {
            kept.push(st.unhandledRejects[ki])
        }
        ki = ki + 1
    }
    st.unhandledRejects = kept
}

// Make `derived` follow `source`: settle now if it already has, else register.
fn adoptPromise(st: &mut Interp, derived: i64, source: i64) {
    let state = st.objects[source].promiseState
    if state == 2 {
        // the derived promise now observes the source's rejection
        var kept: Vec<i64> = Vec.new()
        var ki: i64 = 0
        while ki < st.unhandledRejects.len() {
            if st.unhandledRejects[ki] != source {
                kept.push(st.unhandledRejects[ki])
            }
            ki = ki + 1
        }
        st.unhandledRejects = kept
    }
    if state == 0 {
        st.objExtras[st.objects[source].extra].reactions.push(Reaction {
            onFulfilled: JSValue.Undefined, onRejected: JSValue.Undefined, derived: derived, isFinally: false
        }
        )
        return
    }
    settlePromise(st, derived, state, cloneValue(st.objExtras[st.objects[source].extra].promiseValue))
}

fn describeThrownValue(st: &Interp, v: &JSValue): string {
    let h = objHandle(v)
    if h >= 0 && st.objects[h].isError {
        return toStr(objGet(st, h, "name")) + ": " + toStr(objGet(st, h, "message"))
    }
    return toStr(v)
}

// Node reports (and by default dies on) rejections nothing handles; silently
// dropping them turned a thrown await-deadline error into an invisible hang.
fn reportUnhandledRejections(st: &mut Interp) {
    var i: i64 = 0
    while i < st.unhandledRejects.len() {
        let p = st.unhandledRejects[i]
        if isPromise(st, p) && st.objects[p].promiseState == 2 {
            let v = cloneValue(st.objExtras[st.objects[p].extra].promiseValue)
            eprint("Unhandled promise rejection: " + describeThrownValue(st, v))
        }
        i = i + 1
    }
    st.unhandledRejects = Vec.new()
}

// Run queued microtasks. `limit` caps how many are processed (also the runaway
// guard); pass a large value to drain the whole queue. A bounded limit lets an
// `await` run exactly the microtasks pending at the await point — matching node,
// which queues the await continuation as a microtask, so microtasks queued
// before it run first and ones they queue run after.
fn drainMicrotasks(prog: &Prog, st: &mut Interp, limit: i64) {
    var guard: i64 = 0
    while st.microtasks.len() > 0 && guard < limit {
        let task = cloneValue(st.microtasks[0].cb)
        let arg = cloneValue(st.microtasks[0].arg)
        let derived = st.microtasks[0].derived
        let passthrough = st.microtasks[0].passthroughReject
        let isFinallyTask = st.microtasks[0].isFinally
        let noArgsTask = st.microtasks[0].noArgs
        var rest: Vec<Microtask> = Vec.new()
        var i: i64 = 1
        while i < st.microtasks.len() {
            rest.push(Microtask {
                cb: cloneValue(st.microtasks[i].cb), arg: cloneValue(st.microtasks[i].arg), derived: st.microtasks[i].derived, passthroughReject: st.microtasks[i].passthroughReject, isFinally: st.microtasks[i].isFinally, noArgs: st.microtasks[i].noArgs
            }
            )
            i = i + 1
        }
        st.microtasks = rest
        if derived < 0 {
            pushTemp(st, cloneValue(task))
            var args: Vec<JSValue> = Vec.new()
            if !noArgsTask {
                args.push(arg)
            }
            let _ = callValue(prog, task, args, JSValue.Undefined, st)
            popTemp(st)
            if st.throwing {
                eprint("Uncaught (in microtask) " + describeThrownValue(st, st.thrownValue))
                st.throwing = false
                st.thrownValue = JSValue.Undefined
            }
        } else if !isCallable(task) {
            // no handler for this state: the value flows to the derived promise
            var passState: i64 = 1
            if passthrough {
                passState = 2
            }
            settlePromise(st, derived, passState, arg)
        } else {
            // The queue entry has already been popped, so it no longer roots
            // anything: the handler, the settlement value and the derived promise
            // must all be rooted across the call, which runs user code and can
            // collect. Omitting the handler let a collection free the scope it
            // captured, and it resumed with its closure variables gone.
            pushTemp(st, cloneValue(task))
            pushTemp(st, cloneValue(arg))
            pushTemp(st, JSValue.Obj(derived))
            var args: Vec<JSValue> = Vec.new()
            args.push(cloneValue(arg))
            let r = callValue(prog, task, args, JSValue.Undefined, st)
            popTemp(st)
            popTemp(st)
            popTemp(st)
            if st.throwing {
                let err = cloneValue(st.thrownValue)
                st.throwing = false
                st.thrownValue = JSValue.Undefined
                settlePromise(st, derived, 2, err)
            } else if isFinallyTask {
                // finally: the handler's value is discarded, the original
                // settlement (including a rejection) continues down the chain
                var origState: i64 = 1
                if passthrough {
                    origState = 2
                }
                settlePromise(st, derived, origState, arg)
            } else {
                let rp = objHandle(r)
                if rp >= 0 && isPromise(st, rp) {
                    // adopt the returned promise's eventual state
                    adoptPromise(st, derived, rp)
                } else {
                    settlePromise(st, derived, 1, r)
                }
            }
        }
        guard = guard + 1
    }
}

// Index of the earliest active timer, or -1 when none remain.
fn earliestTimer(st: &Interp): i64 {
    var best: i64 = -1
    var i: i64 = 0
    while i < st.timers.len() {
        if st.timers[i].active {
            if best < 0 || st.timers[i].dueMs < st.timers[best].dueMs {
                best = i
            }
        }
        i = i + 1
    }
    return best
}

// Run one due timer, sleeping until it is due. Returns false when there is
// nothing left to run.
fn runOneTimer(prog: &Prog, st: &mut Interp): bool {
    let idx = earliestTimer(st)
    if idx < 0 {
        return false
    }
    let nowMs = epochMillis() as f64
    let due = st.timers[idx].dueMs
    if due > nowMs {
        sleepMs((due - nowMs) as i64)
    }
    let cb = cloneValue(st.timers[idx].cb)
    var args: Vec<JSValue> = Vec.new()
    var ai: i64 = 0
    while ai < st.timers[idx].args.len() {
        args.push(cloneValue(st.timers[idx].args[ai]))
        ai = ai + 1
    }
    if st.timers[idx].intervalMs > 0.0 {
        st.timers[idx].dueMs = (epochMillis() as f64) + st.timers[idx].intervalMs
    } else {
        st.timers[idx].active = false
    }
    let _ = callValue(prog, cb, args, JSValue.Undefined, st)
    if st.throwing {
        eprint("Uncaught (in timer) " + describeThrownValue(st, st.thrownValue))
        st.throwing = false
        st.thrownValue = JSValue.Undefined
    }
    return true
}

// The event loop: microtasks to exhaustion, then one timer, repeat. Returns when
// nothing is left to run — which for a server with an interval never happens.
// Give any runnable activation the CPU. Returns true if one was there to run,
// so the event loop prefers a live continuation over sleeping on a timer.
fn schedulerYieldedToActivation(st: &mut Interp): bool {
    var ready = false
    var i: i64 = 0
    while i < st.actTask.len() {
        if !isParkedOnPromise(st, st.actTask[i]) {
            ready = true
        }
        i = i + 1
    }
    if ready {
        schedulerYield()
    }
    return ready
}

fn isParkedOnPromise(st: &Interp, t: *u8): bool {
    var i: i64 = 0
    while i < st.awaitTask.len() {
        if st.awaitTask[i] as i64 == t as i64 {
            return true
        }
        i = i + 1
    }
    return false
}

fn runEventLoop(prog: &Prog, st: &mut Interp) {
    var going = true
    while going {
        // Deliver anything an addon's worker threads queued. Runs before
        // microtasks so a settlement made off-thread is visible in this turn.
        napiServiceTsfn(st)
        serviceFetches(st)
        drainMicrotasks(prog, st, 1000000)
        reportUnhandledRejections(st)
        compactTimers(st)
        // Order matters: run timers that are already due, then service a
        // listening server, and only sleep for a future timer when no server is
        // waiting. Sleeping first would block accept() for the whole delay — a
        // pending 9s timer made the server unreachable for 9s.
        if runDueTimer(prog, st) {
            // ran one; loop round
        } else if serveHttpOnce(prog, st) {
            // handled a connection
        } else if st.actTask.len() > 0 && schedulerYieldedToActivation(st) {
            // An activation woken by a settle is runnable now. Yield to it before
            // sleeping on a timer: runOneTimer sleeps until the earliest timer is
            // due, so a far-future timer would otherwise fire long before an
            // activation that is ready right now.
        } else if hasPendingFetches(st) {
            // A worker thread owes us a response; sleep rather than spin a core.
            // Checked BEFORE runOneTimer: serveHttpOnce no longer swallows this
            // branch, and runOneTimer sleeps to the next due timer — behind a
            // far-future timer the fetch would sit delivered but unserviced.
            napiWaitBriefly()
        } else if napiHasPendingWork() {
            // an addon still owes us a settlement, and it will arrive on one of its
            // own threads — there is no timer or socket to wait on, so yield briefly
            // rather than spinning a core while the worker finishes.
            napiWaitBriefly()
        } else if st.httpServers.len() > 0 {
            // A listener with nothing pending, but the loop was not idle enough
            // for a blocking accept (live activations or an armed timer). Sleep a
            // slice and re-probe; due timers are caught at the top of the loop.
            sleepMs(1)
        } else if runOneTimer(prog, st) {
            // nothing to serve, so waiting for the next timer is correct
        } else if st.actTask.len() > 0 {
            // activations are still live; their continuations are real work, so
            // exiting here would drop them on the floor
            schedulerYield()
        } else {
            going = false
        }
    }
}

// Run a timer only if it is already due; never sleeps.
fn runDueTimer(prog: &Prog, st: &mut Interp): bool {
    let idx = earliestTimer(st)
    if idx < 0 {
        return false
    }
    if st.timers[idx].dueMs > (epochMillis() as f64) {
        return false
    }
    return runOneTimer(prog, st)
}

// Ask each registered http server to accept and handle one connection. Returns
// true only when a connection was actually handled, so the event loop can tell
// a served request apart from an idle listener.
fn serveHttpOnce(prog: &Prog, st: &mut Interp): bool {
    if st.httpServers.len() == 0 {
        return false
    }
    // A blocking accept is only safe when nothing else needs the loop: any live
    // activation, in-flight fetch, queued microtask, pending addon settlement or
    // armed timer must keep being serviced, and a park on the listener stops all
    // of them until the next connection arrives. That park was the cold-fetch
    // hang: a request whose handler awaited an upstream fetch parked, the loop
    // re-entered accept, and the response sat unserviced in its channel forever.
    let mayBlock = st.httpServers.len() == 1 && st.actTask.len() == 0 && st.fetches.len() == 0 && st.microtasks.len() == 0 && earliestTimer(st) < 0 && !napiHasPendingWork()
    var handled = false
    var i: i64 = 0
    while i < st.httpServers.len() {
        let so = st.httpServers[i]
        if so >= 0 {
            let server = JSValue.Obj(so)
            var args: Vec<JSValue> = Vec.new()
            args.push(JSValue.Bool(mayBlock))
            let r = callMemberValue(prog, server, "_serveOnce", args, st)
            if truthy(r) {
                handled = true
            }
            if st.throwing {
                eprint("Uncaught (in request handler) " + describeThrownValue(st, st.thrownValue))
                st.throwing = false
                st.thrownValue = JSValue.Undefined
            }
        }
        i = i + 1
    }
    // A request's transient graph — the parsed body, fetched response strings
    // (each a single but often multi-MB allocation), the Request/Response objects
    // — is garbage the moment the response is sent. The alloc-COUNT GC threshold
    // barely moves for a few huge strings, so without this the heap grows
    // unbounded across requests (observed: ~30 MB/request to >1 GB). This request
    // boundary is a safe collection point: nothing is in flight on the eval stack.
    if handled {
        collect(st)
    }
    return handled
}

// Call a method on an object with already-evaluated arguments.
fn callMemberValue(prog: &Prog, recv: &JSValue, name: &string, args: Vec<JSValue>, st: &mut Interp): JSValue {
    let o = objHandle(recv)
    if o < 0 {
        return JSValue.Undefined
    }
    let m = getMemberDyn(prog, o, name, st)
    return callValue(prog, m, args, cloneValue(recv), st)
}

// Drop cancelled timers so the list cannot grow without bound in a long run.
fn compactTimers(st: &mut Interp) {
    var anyDead = false
    var i: i64 = 0
    while i < st.timers.len() {
        if !st.timers[i].active {
            anyDead = true
        }
        i = i + 1
    }
    if !anyDead {
        return
    }
    var live: Vec<Timer> = Vec.new()
    var j: i64 = 0
    while j < st.timers.len() {
        if st.timers[j].active {
            var args: Vec<JSValue> = Vec.new()
            var k: i64 = 0
            while k < st.timers[j].args.len() {
                args.push(cloneValue(st.timers[j].args[k]))
                k = k + 1
            }
            live.push(Timer {
                id: st.timers[j].id, dueMs: st.timers[j].dueMs, intervalMs: st.timers[j].intervalMs, cb: cloneValue(st.timers[j].cb), args: args, active: true
            }
            )
        }
        j = j + 1
    }
    st.timers = live
}

// `delete obj.k` / `delete obj[k]` — remove an own property. Array elements
// become holes (undefined) rather than shifting, as in JS. Always returns true
// here; the non-configurable cases the spec reports false for do not arise.
// `delete proxy[key]`: the deleteProperty trap, else delete on the target.
fn proxyDelete(prog: &Prog, o: i64, key: string, st: &mut Interp): JSValue {
    let trap = proxyTrap(st, o, "deleteProperty")
    if isCallableIn(st, trap) {
        var dargs: Vec<JSValue> = Vec.new()
        dargs.push(cloneValue(st.objExtras[st.objects[o].extra].proxyTarget))
        dargs.push(JSValue.Str(key.clone()))
        return JSValue.Bool(truthy(callValue(prog, trap, dargs, cloneValue(st.objExtras[st.objects[o].extra].proxyHandler), st)))
    }
    let th = objHandle(st.objExtras[st.objects[o].extra].proxyTarget)
    if th >= 0 {
        return JSValue.Bool(objDeleteKey(st, th, key))
    }
    return JSValue.Bool(true)
}

fn evalDelete(prog: &Prog, targetIdx: i64, st: &mut Interp, scope: i64): JSValue {
    match prog.exprs[targetIdx] {
        Expr.Member(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            let o = objHandle(ov)
            if o >= 0 {
                if st.objects[o].isProxy {
                    return proxyDelete(prog, o, name.clone(), st)
                }
                if st.objects[o].frozen || st.objects[o].sealed {
                    return JSValue.Bool(false)
                }
                return JSValue.Bool(objDeleteKey(st, o, name))
            }
            return JSValue.Bool(true)
        }
        Expr.Index(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            pushTemp(st, cloneValue(ov))
            let kv = evalExpr(prog, keyIdx, st, scope)
            popTemp(st)
            let key = toStr(kv)
            let o = objHandle(ov)
            if o >= 0 {
                if st.objects[o].isProxy {
                    return proxyDelete(prog, o, key, st)
                }
                if st.objects[o].frozen || st.objects[o].sealed {
                    return JSValue.Bool(false)
                }
                return JSValue.Bool(objDeleteKey(st, o, key))
            }
            return JSValue.Bool(true)
        }
        _ => {
            // `delete someVariable` is not permitted on bindings; evaluate for
            // effect and report false
            let _ = evalExpr(prog, targetIdx, st, scope)
            return JSValue.Bool(false)
        }
    }
}

// new Array(n) preallocates n holes; new Array(a, b, ...) is a literal list.
fn makeArrayFromCtor(st: &mut Interp, argVals: &Vec<JSValue>): JSValue {
    let arr = newArray(st)
    if argVals.len() == 1 {
        match cloneValue(argVals[0]) {
            JSValue.Number(n) => {
                var i: i64 = 0
                while i < (n as i64) {
                    arrPush(st, arr, JSValue.Undefined)
                    i = i + 1
                }
                return JSValue.Obj(arr)
            }
            _ => {
            }
        }
    }
    var k: i64 = 0
    while k < argVals.len() {
        arrPush(st, arr, cloneValue(argVals[k]))
        k = k + 1
    }
    return JSValue.Obj(arr)
}

// The object that holds a value's properties: itself for an object, the statics
// bag for a function, the native bag for a builtin. Functions are property
// carriers in JS, and express builds its app by copying descriptors onto one.
fn propertyBagOf(st: &mut Interp, v: &JSValue): i64 {
    let o = objHandle(v)
    if o >= 0 {
        return o
    }
    let f = funcHandle(v)
    if f >= 0 {
        return getFuncStatics(st, f, funcEnv(v))
    }
    let n = nativeHandle(v)
    if n >= 0 {
        return getNativeProps(st, n)
    }
    return -1
}

// The module currently executing, for error messages. Empty at top level.

fn hasNodeAddonExt(p: &string): bool {
    let n = p.len()
    if n < 6 {
        return false
    }
    return p[n - 5] == '.' && p[n - 4] == 'n' && p[n - 3] == 'o' && p[n - 2] == 'd' && p[n - 1] == 'e'
}

// dlopen is not idempotent for addon state: a second registration would hand back
// a fresh exports object and re-run module init, so loaded addons are cached by
// path exactly like JS modules are.
fn findNapiAddon(st: &Interp, path: &string): Option<JSValue> {
    var i: i64 = 0
    while i < st.napiAddonPaths.len() {
        if st.napiAddonPaths[i] == path {
            return Option.Some(cloneValue(st.napiAddonExports[i]))
        }
        i = i + 1
    }
    return Option.None
}

fn isUndefinedValue(v: &JSValue): bool {
    match v {
        JSValue.Undefined => {
            return true
        }
        _ => {
            return false
        }
    }
}

// SameValue: strict equality with the two exceptions the spec carves out —
// NaN is equal to itself, and +0 is not equal to -0.
fn sameValue(a: &JSValue, b: &JSValue): bool {
    match a {
        JSValue.Number(x) => {
            match b {
                JSValue.Number(y) => {
                    if x != x && y != y {
                        return true
                    }
                    if x == 0.0 && y == 0.0 {
                        // 1/x distinguishes the zeroes; the sign bit is not
                        // otherwise reachable from f64 here
                        return (1.0 / x) == (1.0 / y)
                    }
                    return x == y
                }
                _ => {
                    return false
                }
            }
        }
        _ => {
            return jsStrictEquals(a, b)
        }
    }
}

// A single JS identifier and nothing else — what the limited eval accepts.
fn isIdentifierText(s: &string): bool {
    if s.len() == 0 {
        return false
    }
    var i: i64 = 0
    while i < s.len() {
        let c = s[i]
        let alpha = (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_' || c == '$'
        let digit = c >= '0' && c <= '9'
        if !alpha && !(digit && i > 0) {
            return false
        }
        i = i + 1
    }
    return true
}

fn currentModule(st: &Interp): string {
    if st.modPathStack.len() == 0 {
        return ""
    }
    return " (in " + st.modPathStack[st.modPathStack.len() - 1].clone() + ")"
}

fn isBoundThisSet(st: &Interp, o: i64): bool {
    match st.objExtras[st.objects[o].extra].boundThis {
        JSValue.Undefined => {
            return false
        }
        _ => {
            return true
        }
    }
}

// Builtin methods dispatch natively by name; they are not properties. Reading one
// as a VALUE therefore used to yield undefined even though calling it worked, which
// breaks two very common patterns: feature detection (`typeof x.test === "function"`)
// and method extraction (`Array.prototype.slice.call(args)`). These predicates say
// whether a receiver answers to a name, so the member paths can hand back a bound
// method instead of undefined.
fn isPrimitiveMethodName(n: &string): bool {
    return n == "toString" || n == "valueOf" || n == "toFixed" || n == "toPrecision" || n == "toExponential" || n == "toLocaleString"
}

fn isStringMethodName(n: &string): bool {
    return n == "charAt" || n == "charCodeAt" || n == "codePointAt" || n == "at" || n == "indexOf" || n == "lastIndexOf" || n == "includes" || n == "startsWith" || n == "endsWith" || n == "slice" || n == "substring" || n == "substr" || n == "split" || n == "replace" || n == "replaceAll" || n == "toUpperCase" || n == "toLowerCase" || n == "trim" || n == "trimStart" || n == "trimEnd" || n == "trimLeft" || n == "trimRight" || n == "padStart" || n == "padEnd" || n == "repeat" || n == "concat" || n == "localeCompare" || n == "normalize" || n == "match" || n == "matchAll" || n == "search" || n == "toString" || n == "valueOf"
}

fn isMapSetMethodName(n: &string): bool {
    return n == "get" || n == "set" || n == "add" || n == "has" || n == "delete" || n == "clear" || n == "forEach" || n == "keys" || n == "values" || n == "entries" || n == "isSupersetOf" || n == "isSubsetOf" || n == "isDisjointFrom" || n == "union" || n == "intersection" || n == "difference"
}

fn isRegexMethodName(n: &string): bool {
    return n == "test" || n == "exec" || n == "toString"
}

fn isTypedArrayMethodName(n: &string): bool {
    return n == "fill" || n == "set" || n == "subarray" || n == "slice" || n == "at" || n == "indexOf" || n == "includes" || n == "join" || n == "toString" || n == "forEach" || n == "map" || n == "filter" || n == "reduce" || n == "reduceRight" || n == "find" || n == "findIndex" || n == "findLast" || n == "findLastIndex" || n == "some" || n == "every" || n == "reverse" || n == "sort" || n == "with"
}

// Typed-array methods. Views share their buffer, so subarray returns a new view
// over the SAME bytes while slice copies — getting that backwards is the classic
// typed-array bug.
fn typedArrayMethod(prog: &Prog, o: i64, name: &string, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    let n = st.objExtras[st.objects[o].extra].taLen
    let kind = st.objExtras[st.objects[o].extra].taKind
    let w = taWidth(kind)

    if name == "at" {
        var idx: i64 = 0
        if args.len() > 0 {
            idx = toNum(args[0]) as i64
        }
        if idx < 0 {
            idx = n + idx
        }
        if idx < 0 || idx >= n {
            return JSValue.Undefined
        }
        return JSValue.Number(taElem(st, o, idx))
    }
    if name == "fill" {
        var v: f64 = 0.0
        if args.len() > 0 {
            v = toNum(args[0])
        }
        var start: i64 = 0
        if args.len() > 1 {
            start = toNum(args[1]) as i64
            if start < 0 {
                start = n + start
            }
        }
        var end = n
        if args.len() > 2 {
            end = toNum(args[2]) as i64
            if end < 0 {
                end = n + end
            }
        }
        if start < 0 {
            start = 0
        }
        if end > n {
            end = n
        }
        var i = start
        while i < end {
            taSetElem(st, o, i, v)
            i = i + 1
        }
        return JSValue.Obj(o)
    }
    if name == "indexOf" || name == "includes" {
        var target: f64 = 0.0
        if args.len() > 0 {
            target = toNum(args[0])
        }
        var i: i64 = 0
        while i < n {
            if taElem(st, o, i) == target {
                if name == "includes" {
                    return JSValue.Bool(true)
                }
                return JSValue.Number(i as f64)
            }
            i = i + 1
        }
        if name == "includes" {
            return JSValue.Bool(false)
        }
        return JSValue.Number(0.0 - 1.0)
    }
    if name == "join" || name == "toString" {
        var sep = ","
        if name == "join" && args.len() > 0 {
            sep = toStr(args[0])
        }
        var out = ""
        var i: i64 = 0
        while i < n {
            if i > 0 {
                out = out + sep
            }
            out = out + numToStr(taElem(st, o, i))
            i = i + 1
        }
        return JSValue.Str(out)
    }
    if name == "set" {
        // set(source, offset) — copies element values in
        if args.len() == 0 {
            return JSValue.Undefined
        }
        var off: i64 = 0
        if args.len() > 1 {
            off = toNum(args[1]) as i64
        }
        let sh = objHandle(args[0])
        if sh < 0 {
            return JSValue.Undefined
        }
        if st.objects[sh].isArray {
            var i: i64 = 0
            while i < arrLen(st, sh) {
                taSetElem(st, o, off + i, toNum(arrGet(st, sh, i)))
                i = i + 1
            }
        } else if st.objExtras[st.objects[sh].extra].taBuf >= 0 {
            var i: i64 = 0
            while i < st.objExtras[st.objects[sh].extra].taLen {
                taSetElem(st, o, off + i, taElem(st, sh, i))
                i = i + 1
            }
        }
        return JSValue.Undefined
    }
    if name == "subarray" || name == "slice" {
        var start: i64 = 0
        if args.len() > 0 {
            start = toNum(args[0]) as i64
            if start < 0 {
                start = n + start
            }
        }
        var end = n
        if args.len() > 1 {
            end = toNum(args[1]) as i64
            if end < 0 {
                end = n + end
            }
        }
        if start < 0 {
            start = 0
        }
        if end > n {
            end = n
        }
        if end < start {
            end = start
        }
        let count = end - start
        if name == "subarray" {
            // a VIEW over the same buffer: writes through it are visible in the
            // original, which is the whole point of subarray
            let view = newObject(st)
            let _ev = ensureExtra(st, view)
            st.objExtras[st.objects[view].extra].taBuf = st.objExtras[st.objects[o].extra].taBuf
            st.objExtras[st.objects[view].extra].taKind = kind
            st.objExtras[st.objects[view].extra].taOffset = st.objExtras[st.objects[o].extra].taOffset + start * w
            st.objExtras[st.objects[view].extra].taLen = count
            return JSValue.Obj(view)
        }
        // slice COPIES into a fresh buffer
        let nb = newObject(st)
        st.objects[nb].isArrayBuffer = true
        let _eb = ensureExtra(st, nb)
        pushTemp(st, JSValue.Obj(nb))
        var bytes: Vec<u8> = Vec.new()
        var bi: i64 = 0
        while bi < count * w {
            bytes.push(0 as u8)
            bi = bi + 1
        }
        st.objExtras[st.objects[nb].extra].bytes = bytes
        let view = newObject(st)
        let _ev = ensureExtra(st, view)
        st.objExtras[st.objects[view].extra].taBuf = nb
        st.objExtras[st.objects[view].extra].taKind = kind
        st.objExtras[st.objects[view].extra].taOffset = 0
        st.objExtras[st.objects[view].extra].taLen = count
        var i: i64 = 0
        while i < count {
            taSetElem(st, view, i, taElem(st, o, start + i))
            i = i + 1
        }
        popTemp(st)
        return JSValue.Obj(view)
    }
    // callback-based iteration methods. The element and index are passed to the
    // callback; map/filter build a new typed array (map keeps the kind).
    if name == "forEach" {
        var i: i64 = 0
        while i < n && !st.throwing {
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(JSValue.Number(taElem(st, o, i)))
            cbArgs.push(JSValue.Number(i as f64))
            let _r = callValue(prog, args[0], cbArgs, JSValue.Undefined, st)
            i = i + 1
        }
        return JSValue.Undefined
    }
    if name == "map" {
        var lenArgs: Vec<JSValue> = Vec.new()
        lenArgs.push(JSValue.Number(n as f64))
        let out = makeTypedArray(st, kind, lenArgs)
        let oh = objHandle(out)
        pushTemp(st, cloneValue(out))
        var i: i64 = 0
        while i < n && !st.throwing {
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(JSValue.Number(taElem(st, o, i)))
            cbArgs.push(JSValue.Number(i as f64))
            let r = callValue(prog, args[0], cbArgs, JSValue.Undefined, st)
            taSetElem(st, oh, i, toNum(r))
            i = i + 1
        }
        popTemp(st)
        return out
    }
    if name == "filter" {
        var kept: Vec<f64> = Vec.new()
        var i: i64 = 0
        while i < n && !st.throwing {
            let e = taElem(st, o, i)
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(JSValue.Number(e))
            cbArgs.push(JSValue.Number(i as f64))
            if truthy(callValue(prog, args[0], cbArgs, JSValue.Undefined, st)) {
                kept.push(e)
            }
            i = i + 1
        }
        var lenArgs: Vec<JSValue> = Vec.new()
        lenArgs.push(JSValue.Number(kept.len() as f64))
        let out = makeTypedArray(st, kind, lenArgs)
        let oh = objHandle(out)
        var k: i64 = 0
        while k < kept.len() {
            taSetElem(st, oh, k, kept[k])
            k = k + 1
        }
        return out
    }
    if name == "reduce" || name == "reduceRight" {
        let rev = name == "reduceRight"
        var acc = JSValue.Undefined
        var started = false
        if args.len() > 1 {
            acc = cloneValue(args[1])
            started = true
        }
        var c: i64 = 0
        while c < n && !st.throwing {
            let i = if rev {
                n - 1 - c
            } else {
                c
            }
            let e = JSValue.Number(taElem(st, o, i))
            if !started {
                acc = e
                started = true
            } else {
                var cbArgs: Vec<JSValue> = Vec.new()
                cbArgs.push(cloneValue(acc))
                cbArgs.push(e)
                cbArgs.push(JSValue.Number(i as f64))
                acc = callValue(prog, args[0], cbArgs, JSValue.Undefined, st)
            }
            c = c + 1
        }
        return acc
    }
    if name == "find" || name == "findIndex" || name == "some" || name == "every" || name == "findLast" || name == "findLastIndex" {
        let rev = name == "findLast" || name == "findLastIndex"
        var c: i64 = 0
        while c < n && !st.throwing {
            let i = if rev {
                n - 1 - c
            } else {
                c
            }
            let e = taElem(st, o, i)
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(JSValue.Number(e))
            cbArgs.push(JSValue.Number(i as f64))
            let hit = truthy(callValue(prog, args[0], cbArgs, JSValue.Undefined, st))
            if name == "some" && hit {
                return JSValue.Bool(true)
            }
            if name == "every" && !hit {
                return JSValue.Bool(false)
            }
            if (name == "find" || name == "findLast") && hit {
                return JSValue.Number(e)
            }
            if (name == "findIndex" || name == "findLastIndex") && hit {
                return JSValue.Number(i as f64)
            }
            c = c + 1
        }
        if name == "some" {
            return JSValue.Bool(false)
        }
        if name == "every" {
            return JSValue.Bool(true)
        }
        if name == "find" || name == "findLast" {
            return JSValue.Undefined
        }
        return JSValue.Number(0.0 - 1.0)
    }
    if name == "with" {
        // a copy with one element replaced (negative index from the end)
        var idx: i64 = 0
        if args.len() > 0 {
            idx = toNum(args[0]) as i64
        }
        if idx < 0 {
            idx = n + idx
        }
        var lenArgs: Vec<JSValue> = Vec.new()
        lenArgs.push(JSValue.Number(n as f64))
        let out = makeTypedArray(st, kind, lenArgs)
        let oh = objHandle(out)
        pushTemp(st, cloneValue(out))
        var i: i64 = 0
        while i < n {
            if i == idx && args.len() > 1 {
                taSetElem(st, oh, i, toNum(args[1]))
            } else {
                taSetElem(st, oh, i, taElem(st, o, i))
            }
            i = i + 1
        }
        popTemp(st)
        return out
    }
    if name == "reverse" {
        var i: i64 = 0
        while i < n / 2 {
            let tmp = taElem(st, o, i)
            taSetElem(st, o, i, taElem(st, o, n - 1 - i))
            taSetElem(st, o, n - 1 - i, tmp)
            i = i + 1
        }
        return JSValue.Obj(o)
    }
    if name == "sort" {
        // numeric ascending by default; a comparator (args[0]) overrides. Simple
        // insertion sort over the element values (typed arrays are usually small).
        var i: i64 = 1
        while i < n && !st.throwing {
            let cur = taElem(st, o, i)
            var j = i - 1
            var cont = true
            while j >= 0 && cont {
                let ej = taElem(st, o, j)
                var swap = ej > cur
                if args.len() > 0 && isCallableIn(st, args[0]) {
                    var cbArgs: Vec<JSValue> = Vec.new()
                    cbArgs.push(JSValue.Number(ej))
                    cbArgs.push(JSValue.Number(cur))
                    swap = toNum(callValue(prog, args[0], cbArgs, JSValue.Undefined, st)) > 0.0
                }
                if swap {
                    taSetElem(st, o, j + 1, ej)
                    j = j - 1
                } else {
                    cont = false
                }
            }
            taSetElem(st, o, j + 1, cur)
            i = i + 1
        }
        return JSValue.Obj(o)
    }
    return JSValue.Undefined
}

fn isDataViewMethodName(n: &string): bool {
    return n == "getInt8" || n == "getUint8" || n == "getInt16" || n == "getUint16" || n == "getInt32" || n == "getUint32" || n == "getFloat32" || n == "getFloat64" || n == "setInt8" || n == "setUint8" || n == "setInt16" || n == "setUint16" || n == "setInt32" || n == "setUint32" || n == "setFloat32" || n == "setFloat64"
}

// DataView get/set. Default endianness is BIG-endian (the littleEndian arg
// defaults false), unlike typed arrays which store host/little-endian. taLen is
// the view's byte length here; taBuf/taOffset locate it in the backing buffer.
fn dataViewMethod(o: i64, name: &string, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    var width: i64 = 1
    var isFloat = false
    var signed = false
    if name == "getInt16" || name == "setInt16" || name == "getUint16" || name == "setUint16" {
        width = 2
    } else if name == "getInt32" || name == "setInt32" || name == "getUint32" || name == "setUint32" {
        width = 4
    } else if name == "getFloat32" || name == "setFloat32" {
        width = 4
        isFloat = true
    } else if name == "getFloat64" || name == "setFloat64" {
        width = 8
        isFloat = true
    }
    if name == "getInt8" || name == "setInt8" || name == "getInt16" || name == "setInt16" || name == "getInt32" || name == "setInt32" {
        signed = true
    }
    // "set..." starts with 's' (115), "get..." with 'g'
    let isSet = name.len() > 0 && name[0] == 115
    var byteOffset: i64 = 0
    if args.len() > 0 {
        byteOffset = toNum(args[0]) as i64
    }
    if byteOffset < 0 || byteOffset + width > st.objExtras[st.objects[o].extra].taLen {
        st.throwing = true
        st.thrownValue = makeError(st, "RangeError", "Offset is outside the bounds of the DataView")
        return JSValue.Undefined
    }
    let buf = st.objExtras[st.objects[o].extra].taBuf
    let absPos = st.objExtras[st.objects[o].extra].taOffset + byteOffset
    if isSet {
        var value: f64 = 0.0
        if args.len() > 1 {
            value = toNum(args[1])
        }
        var littleEndian = false
        if args.len() > 2 {
            littleEndian = truthy(args[2])
        }
        var bits: i64 = 0
        if isFloat {
            if width == 8 {
                bits = f64ToBits(value)
            } else {
                bits = f32ToBits(value)
            }
        } else {
            bits = value as i64
        }
        var i: i64 = 0
        while i < width {
            var shift = 8 * i
            if !littleEndian {
                shift = 8 * (width - 1 - i)
            }
            st.objExtras[st.objects[buf].extra].bytes[absPos + i] = ((bits >> shift) & 255) as u8
            i = i + 1
        }
        return JSValue.Undefined
    }
    var littleEndian = false
    if args.len() > 1 {
        littleEndian = truthy(args[1])
    }
    var bits: i64 = 0
    var i: i64 = 0
    while i < width {
        var shift = 8 * i
        if !littleEndian {
            shift = 8 * (width - 1 - i)
        }
        bits = bits | ((st.objExtras[st.objects[buf].extra].bytes[absPos + i] as i64) << shift)
        i = i + 1
    }
    if isFloat {
        if width == 8 {
            return JSValue.Number(bitsToF64(bits))
        }
        return JSValue.Number(bitsToF32(bits))
    }
    if signed {
        let signbit = (1 as i64) << (8 * width - 1)
        if (bits & signbit) != 0 {
            bits = bits - ((1 as i64) << (8 * width))
        }
    }
    return JSValue.Number(bits as f64)
}

fn dateProtoMethodNames(): Vec<string> {
    var out: Vec<string> = Vec.new()
    out.push("getTime")
    out.push("valueOf")
    out.push("toISOString")
    out.push("toJSON")
    out.push("toString")
    out.push("toUTCString")
    out.push("toDateString")
    out.push("toLocaleString")
    out.push("toLocaleDateString")
    out.push("toLocaleTimeString")
    out.push("getFullYear")
    out.push("getMonth")
    out.push("getDate")
    out.push("getDay")
    out.push("getHours")
    out.push("getMinutes")
    out.push("getSeconds")
    out.push("getMilliseconds")
    out.push("getTimezoneOffset")
    out.push("setTime")
    return out
}

fn strProtoMethodNames(): Vec<string> {
    var out: Vec<string> = Vec.new()
    out.push("replace")
    out.push("split")
    out.push("slice")
    out.push("substring")
    out.push("substr")
    out.push("indexOf")
    out.push("lastIndexOf")
    out.push("charAt")
    out.push("charCodeAt")
    out.push("toUpperCase")
    out.push("toLowerCase")
    out.push("trim")
    out.push("trimStart")
    out.push("trimEnd")
    out.push("startsWith")
    out.push("endsWith")
    out.push("includes")
    out.push("repeat")
    out.push("padStart")
    out.push("padEnd")
    out.push("concat")
    out.push("match")
    out.push("search")
    out.push("toString")
    out.push("valueOf")
    return out
}

// Function.prototype.length: the count of parameters before the first one with
// a default or a rest parameter. milojs does not record defaults per-param, so
// this counts declared params minus a trailing rest — enough for express, which
// only checks length === 4 to detect error-handler middleware.
fn funcArity(prog: &Prog, fIdx: i64): i64 {
    var n = prog.funcs[fIdx].params.len()
    if prog.funcs[fIdx].restFrom >= 0 {
        n = prog.funcs[fIdx].restFrom
    }
    return n
}

fn isSuperName(name: &string): bool {
    if name.len() < 8 {
        return false
    }
    return name[0] == '_' && name[1] == '_' && name[2] == 's' && name[3] == 'u' && name[4] == 'p' && name[5] == 'e' && name[6] == 'r' && name[7] == '$'
}

fn instantiateClass(prog: &Prog, classIdx: i64, st: &mut Interp, scope: i64): JSValue {
    var ctorFn = prog.classes[classIdx].ctorFn
    if ctorFn < 0 {
        // no declared constructor — reuse an empty one so the class is callable
        ctorFn = prog.classes[classIdx].defaultCtor
    }
    // A named class expression binds its own name inside the class body, in a
    // scope of its own: `X = class e { static empty() { return new e } }` — `e`
    // exists only in there, and prisma's runtime is built out of exactly this.
    // Methods and the constructor close over this scope rather than the defining
    // one; the super binding lives here too, so it can't be seen by siblings.
    let classScope = newScope(st, scope)
    pushActive(st, classScope)
    let classVal = JSValue.Func(ctorFn, classScope)
    let className = prog.classes[classIdx].name.clone()
    if className.len() > 0 {
        scopeDefine(st, classScope, className, JSValue.Func(ctorFn, classScope))
    }
    let proto = getFuncProto(st, ctorFn)
    linkProtoConstructor(st, proto, ctorFn, classScope)
    let superName = prog.classes[classIdx].superName.clone()
    if superName.len() > 0 {
        let baseVal = scopeLookup(st, scope, superName)
        let baseFn = funcHandle(baseVal)
        if baseFn >= 0 {
            let baseProto = getFuncProto(st, baseFn)
            st.objects[proto].proto = baseProto
        }
        scopeDefine(st, classScope, "__super$" + prog.classes[classIdx].superKey.clone(), baseVal)
    }
    var i: i64 = 0
    while i < prog.classes[classIdx].members.len() {
        let mName = prog.classes[classIdx].members[i].name.clone()
        let mFn = prog.classes[classIdx].members[i].fnIdx
        let mv = JSValue.Func(mFn, classScope)
        let mKind = prog.classes[classIdx].members[i].kind
        var target = proto
        if prog.classes[classIdx].members[i].isStatic {
            target = getFuncStatics(st, ctorFn, classScope)
        }
        if mKind > 0 {
            let existing = objOwnIndex(st, target, mName)
            var g = JSValue.Undefined
            var sfn = JSValue.Undefined
            if existing >= 0 && st.objects[target].props[existing].isAccessor {
                g = cloneValue(st.objects[target].props[existing].getter)
                sfn = cloneValue(st.objects[target].props[existing].setter)
            }
            if mKind == 1 {
                g = mv
            } else {
                sfn = mv
            }
            objDefineAccessor(st, target, mName, g, sfn)
        } else {
            objSet(st, target, mName, mv)
        }
        i = i + 1
    }
    // static field initializers, evaluated in the class scope (so they can see
    // the class binding and static methods) and set on the constructor object
    var sf: i64 = 0
    while sf < prog.classes[classIdx].staticFieldNames.len() {
        let sfName = prog.classes[classIdx].staticFieldNames[sf].clone()
        let sfInit = prog.classes[classIdx].staticFieldInits[sf]
        let statics = getFuncStatics(st, ctorFn, classScope)
        let sfVal = evalExpr(prog, sfInit, st, classScope)
        objSet(st, statics, sfName, sfVal)
        sf = sf + 1
    }
    popActive(st)
    return classVal
}

fn callValue(prog: &Prog, fnVal: &JSValue, args: Vec<JSValue>, thisVal: JSValue, st: &mut Interp): JSValue {
    match fnVal {
        JSValue.Func(fIdx, envIdx) => {
            return callFunction(prog, fIdx, envIdx, args, thisVal, st)
        }
        JSValue.Native(id) => {
            return callNative(id, args, st)
        }
        JSValue.Obj(o) => {
            if st.objects[o].isProxy {
                let trap = proxyTrap(st, o, "apply")
                let target = cloneValue(st.objExtras[st.objects[o].extra].proxyTarget)
                if isCallableIn(st, trap) {
                    // apply(target, thisArg, argsArray)
                    let arr = newArray(st)
                    var i: i64 = 0
                    while i < args.len() {
                        st.objects[arr].elems.push(cloneValue(args[i]))
                        i = i + 1
                    }
                    var targs: Vec<JSValue> = Vec.new()
                    targs.push(cloneValue(target))
                    targs.push(cloneValue(thisVal))
                    targs.push(JSValue.Obj(arr))
                    return callValue(prog, trap, targs, cloneValue(st.objExtras[st.objects[o].extra].proxyHandler), st)
                }
                return callValue(prog, target, args, thisVal, st)
            }
            // implemented by a loaded node-api addon: dispatch to its C callback
            if st.objExtras[st.objects[o].extra].napiFn >= 0 {
                let r = napiInvoke(st.objExtras[st.objects[o].extra].napiFn, args, thisVal)
                napiDrainSettlements(st)
                return r
            }
            // a bind() result: the captured receiver wins over the call site's
            if st.objects[o].isBound {
                let ex = st.objects[o].extra
                if st.objExtras[ex].boundMethod.len() > 0 {
                    let mname = st.objExtras[ex].boundMethod.clone()
                    var recvV = cloneValue(st.objExtras[ex].boundThis)
                    // an unbound builtin method (Object.prototype.toString stored
                    // with no bound this) takes the call-site receiver, so
                    // ({}).toString() gets `this` = {} rather than undefined
                    if !isBoundThisSet(st, o) {
                        recvV = cloneValue(thisVal)
                    }
                    return callBuiltinByName(prog, recvV, mname, args, st)
                }
                let target = cloneValue(st.objExtras[ex].boundTarget)
                let boundThis = cloneValue(st.objExtras[ex].boundThis)
                var merged: Vec<JSValue> = Vec.new()
                var b: i64 = 0
                while b < st.objExtras[ex].boundArgs.len() {
                    merged.push(cloneValue(st.objExtras[ex].boundArgs[b]))
                    b = b + 1
                }
                var a: i64 = 0
                while a < args.len() {
                    merged.push(cloneValue(args[a]))
                    a = a + 1
                }
                return callValue(prog, target, merged, boundThis, st)
            }
            return JSValue.Undefined
        }
        _ => {
            return JSValue.Undefined
        }
    }
}

// The (element, index, array) triple JS array-iteration callbacks receive.
fn makeCbArgs(st: &Interp, o: i64, i: i64): Vec<JSValue> {
    var v: Vec<JSValue> = Vec.new()
    v.push(arrGet(st, o, i))
    v.push(JSValue.Number(i as f64))
    v.push(JSValue.Obj(o))
    return v
}

// Map and Set share one entry list; a Set just stores true as every value.
// Call a method by name on a user object (set-like argument plumbing).
fn callObjMethod(prog: &Prog, st: &mut Interp, recv: &JSValue, name: &string, args: Vec<JSValue>): JSValue {
    let h = objHandle(recv)
    if h < 0 {
        return JSValue.Undefined
    }
    let f = getMember(st, h, name)
    if !isCallableIn(st, f) {
        st.throwing = true
        st.thrownValue = makeError(st, "TypeError", name.clone() + " is not a function")
        return JSValue.Undefined
    }
    return callValue(prog, f, args, cloneValue(recv), st)
}

// The set-methods proposal takes "set-like" objects: {size, has, keys}. `size` is
// validated first and its diagnostics must name `.size`, which the suite checks.
// Returns the size, or -1.0 after throwing.
fn setLikeSize(_prog: &Prog, st: &mut Interp, other: &JSValue): f64 {
    let h = objHandle(other)
    if h < 0 {
        st.throwing = true
        st.thrownValue = makeError(st, "TypeError", "set-like argument has no .size")
        return 0.0 - 1.0
    }
    // a real Set answers .size itself
    if st.objects[h].isSet || st.objects[h].isMap {
        return st.objExtras[st.objects[h].extra].mapKeys.len() as f64
    }
    let sv = getMember(st, h, "size")
    let n = toNum(sv)
    if n != n {
        st.throwing = true
        st.thrownValue = makeError(st, "TypeError", "set-like argument has a NaN .size")
        return 0.0 - 1.0
    }
    if n < 0.0 {
        st.throwing = true
        st.thrownValue = makeError(st, "RangeError", "set-like argument has a negative .size")
        return 0.0 - 1.0
    }
    return n
}

// other.keys() — the iterator a set-like exposes.
fn setLikeKeys(prog: &Prog, st: &mut Interp, other: &JSValue): JSValue {
    let h = objHandle(other)
    if h >= 0 && (st.objects[h].isSet || st.objects[h].isMap) {
        var noArgs: Vec<JSValue> = Vec.new()
        return mapMethod(prog, h, "keys", noArgs, st)
    }
    var noArgs: Vec<JSValue> = Vec.new()
    return callObjMethod(prog, st, other, "keys", noArgs)
}

// One step of an iterator: returns done via the out-param slot.
fn iterStep(prog: &Prog, st: &mut Interp, iter: &JSValue, done: &mut bool): JSValue {
    var noArgs: Vec<JSValue> = Vec.new()
    let step = callObjMethod(prog, st, iter, "next", noArgs)
    let sh = objHandle(step)
    if sh < 0 || st.throwing {
        done = true
        return JSValue.Undefined
    }
    done = truthy(getMember(st, sh, "done"))
    if done {
        return JSValue.Undefined
    }
    return getMember(st, sh, "value")
}

// Closing an iterator early is observable (the suite counts return() calls), so
// every early exit from a set method has to do it.
fn iterClose(prog: &Prog, st: &mut Interp, iter: &JSValue) {
    let h = objHandle(iter)
    if h < 0 {
        return
    }
    let f = getMember(st, h, "return")
    if isCallableIn(st, f) {
        var noArgs: Vec<JSValue> = Vec.new()
        let _ = callValue(prog, f, noArgs, cloneValue(iter), st)
    }
}

fn setHasValue(st: &Interp, o: i64, v: &JSValue): bool {
    return mapFind(st, o, v) >= 0
}

// `other.has(v)` where other may be a real Set (whose `has` is native dispatch,
// not a property) or a user set-like (where it is a property).
fn setLikeHas(prog: &Prog, st: &mut Interp, other: &JSValue, v: &JSValue): bool {
    let h = objHandle(other)
    if h >= 0 && (st.objects[h].isSet || st.objects[h].isMap) {
        return mapFind(st, h, v) >= 0
    }
    var hargs: Vec<JSValue> = Vec.new()
    hargs.push(cloneValue(v))
    return truthy(callObjMethod(prog, st, other, "has", hargs))
}

fn mapMethod(prog: &Prog, o: i64, name: &string, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    let isSet = st.objects[o].isSet
    if name == "get" {
        var key = JSValue.Undefined
        if args.len() > 0 {
            key = cloneValue(args[0])
        }
        let at = mapFind(st, o, key)
        if at < 0 {
            return JSValue.Undefined
        }
        return cloneValue(st.objExtras[st.objects[o].extra].mapVals[at])
    }
    if name == "set" || name == "add" {
        var key = JSValue.Undefined
        if args.len() > 0 {
            key = cloneValue(args[0])
        }
        var val = JSValue.Bool(true)
        if !isSet && args.len() > 1 {
            val = cloneValue(args[1])
        }
        mapPut(st, o, key, val)
        return JSValue.Obj(o)
    }
    if name == "has" {
        var key = JSValue.Undefined
        if args.len() > 0 {
            key = cloneValue(args[0])
        }
        return JSValue.Bool(mapFind(st, o, key) >= 0)
    }
    if name == "delete" {
        var key = JSValue.Undefined
        if args.len() > 0 {
            key = cloneValue(args[0])
        }
        let at = mapFind(st, o, key)
        if at < 0 {
            return JSValue.Bool(false)
        }
        var nk: Vec<JSValue> = Vec.new()
        var nv: Vec<JSValue> = Vec.new()
        var i: i64 = 0
        while i < st.objExtras[st.objects[o].extra].mapKeys.len() {
            if i != at {
                nk.push(cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i]))
                nv.push(cloneValue(st.objExtras[st.objects[o].extra].mapVals[i]))
            }
            i = i + 1
        }
        st.objExtras[st.objects[o].extra].mapKeys = nk
        st.objExtras[st.objects[o].extra].mapVals = nv
        return JSValue.Bool(true)
    }
    if name == "clear" {
        st.objExtras[st.objects[o].extra].mapKeys = Vec.new()
        st.objExtras[st.objects[o].extra].mapVals = Vec.new()
        return JSValue.Undefined
    }
    if name == "isSupersetOf" || name == "isSubsetOf" || name == "isDisjointFrom" || name == "union" || name == "intersection" || name == "difference" {
        var other = JSValue.Undefined
        if args.len() > 0 {
            other = cloneValue(args[0])
        }
        let osize = setLikeSize(prog, st, other)
        if st.throwing {
            return JSValue.Undefined
        }
        let mine = st.objExtras[st.objects[o].extra].mapKeys.len() as f64

        if name == "isSupersetOf" {
            if mine < osize {
                return JSValue.Bool(false)
            }
            let iter = setLikeKeys(prog, st, other)
            pushTemp(st, cloneValue(iter))
            var done = false
            var ok = true
            while !done && !st.throwing {
                let v = iterStep(prog, st, iter, done)
                if !done && !setHasValue(st, o, v) {
                    iterClose(prog, st, iter)
                    ok = false
                    done = true
                }
            }
            popTemp(st)
            return JSValue.Bool(ok)
        }
        if name == "isSubsetOf" {
            if mine > osize {
                return JSValue.Bool(false)
            }
            var i: i64 = 0
            while i < st.objExtras[st.objects[o].extra].mapKeys.len() && !st.throwing {
                let mk = cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i])
                if !setLikeHas(prog, st, other, mk) {
                    return JSValue.Bool(false)
                }
                i = i + 1
            }
            return JSValue.Bool(true)
        }
        if name == "isDisjointFrom" {
            // walk whichever side is smaller; only the other-side walk uses an
            // iterator, which is what makes the suite's call counts meaningful
            if mine <= osize {
                var i: i64 = 0
                while i < st.objExtras[st.objects[o].extra].mapKeys.len() && !st.throwing {
                    let mk = cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i])
                    if setLikeHas(prog, st, other, mk) {
                        return JSValue.Bool(false)
                    }
                    i = i + 1
                }
                return JSValue.Bool(true)
            }
            let iter = setLikeKeys(prog, st, other)
            pushTemp(st, cloneValue(iter))
            var done = false
            var disjoint = true
            while !done && !st.throwing {
                let v = iterStep(prog, st, iter, done)
                if !done && setHasValue(st, o, v) {
                    iterClose(prog, st, iter)
                    disjoint = false
                    done = true
                }
            }
            popTemp(st)
            return JSValue.Bool(disjoint)
        }
        // union / intersection / difference all build a fresh Set
        let res = newObject(st)
        st.objects[res].isSet = true
        let _re = ensureExtra(st, res)
        pushTemp(st, JSValue.Obj(res))
        if name == "union" {
            var i: i64 = 0
            while i < st.objExtras[st.objects[o].extra].mapKeys.len() {
                mapPut(st, res, cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i]), JSValue.Bool(true))
                i = i + 1
            }
            let iter = setLikeKeys(prog, st, other)
            pushTemp(st, cloneValue(iter))
            var done = false
            while !done && !st.throwing {
                let v = iterStep(prog, st, iter, done)
                if !done {
                    mapPut(st, res, v, JSValue.Bool(true))
                }
            }
            popTemp(st)
        } else {
            let wantIn = name == "intersection"
            var i: i64 = 0
            while i < st.objExtras[st.objects[o].extra].mapKeys.len() && !st.throwing {
                let k = cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i])
                let inOther = setLikeHas(prog, st, other, k)
                if inOther == wantIn {
                    mapPut(st, res, k, JSValue.Bool(true))
                }
                i = i + 1
            }
        }
        popTemp(st)
        return JSValue.Obj(res)
    }
    if name == "keys" || name == "values" || name == "entries" {
        // Snapshot into an array, then hand back a real iterator over it — so
        // .next(), the Iterator.prototype helpers, for-of and Array.from all
        // work. (A snapshot, not a live view: mutating the map mid-iteration
        // will not be observed, which JS would show.)
        let arr = newArray(st)
        pushTemp(st, JSValue.Obj(arr))
        var i: i64 = 0
        while i < st.objExtras[st.objects[o].extra].mapKeys.len() {
            let k = cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i])
            let v = cloneValue(st.objExtras[st.objects[o].extra].mapVals[i])
            if name == "keys" {
                arrPush(st, arr, k)
            } else if name == "values" {
                if isSet {
                    arrPush(st, arr, k)
                } else {
                    arrPush(st, arr, v)
                }
            } else {
                let pair = newArray(st)
                pushTemp(st, JSValue.Obj(pair))
                arrPush(st, pair, k)
                if isSet {
                    arrPush(st, pair, cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i]))
                } else {
                    arrPush(st, pair, v)
                }
                popTemp(st)
                arrPush(st, arr, JSValue.Obj(pair))
            }
            i = i + 1
        }
        let it = makeArrayIterator(st, arr, 0)
        popTemp(st)
        return it
    }
    if name == "forEach" {
        if args.len() == 0 {
            return JSValue.Undefined
        }
        let cb = cloneValue(args[0])
        pushTemp(st, cloneValue(cb))
        // The callback may delete entries (including the current one) or add
        // new ones; the backing vecs compact on delete, so a plain i++ would
        // skip the entry that shifted into slot i. Re-sync the cursor against
        // the just-visited key after every call; if that key is gone, resume at
        // the first entry not yet visited (keys are unique, so this is sound).
        var visited: Vec<JSValue> = Vec.new()
        var i: i64 = 0
        while i < st.objExtras[st.objects[o].extra].mapKeys.len() && !st.throwing {
            let k = cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i])
            var v = cloneValue(st.objExtras[st.objects[o].extra].mapVals[i])
            if isSet {
                v = cloneValue(st.objExtras[st.objects[o].extra].mapKeys[i])
            }
            visited.push(cloneValue(k))
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(v)
            cbArgs.push(cloneValue(k))
            cbArgs.push(JSValue.Obj(o))
            let _ = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            if st.throwing {
                break
            }
            if i < st.objExtras[st.objects[o].extra].mapKeys.len() && sameValue(st.objExtras[st.objects[o].extra].mapKeys[i], k) {
                i = i + 1
            } else {
                let j = mapFind(st, o, k)
                if j >= 0 {
                    i = j + 1
                } else {
                    var p: i64 = 0
                    var next = st.objExtras[st.objects[o].extra].mapKeys.len()
                    while p < st.objExtras[st.objects[o].extra].mapKeys.len() {
                        var seen = false
                        var q: i64 = 0
                        while q < visited.len() {
                            if sameValue(st.objExtras[st.objects[o].extra].mapKeys[p], visited[q]) {
                                seen = true
                                q = visited.len()
                            }
                            q = q + 1
                        }
                        if !seen {
                            next = p
                            p = st.objExtras[st.objects[o].extra].mapKeys.len()
                        }
                        p = p + 1
                    }
                    i = next
                }
            }
        }
        popTemp(st)
        return JSValue.Undefined
    }
    return JSValue.Undefined
}

// Date instance methods. Everything derives from the stored epoch milliseconds.
// ISO-8601 in UTC, the format Date.prototype.toISOString produces.
fn isoFromMillis(ms: f64): string {
    if ms != ms {
        return "Invalid Date"
    }
    let total = (ms / 1000.0) as i64
    let dt = dateTimeFromEpoch(total)
    var frac = mathMod(ms, 1000.0) as i64
    if frac < 0 {
        frac = frac + 1000
    }
    return i64ToStr(dt.year as i64) + "-" + pad2(dt.month as i64) + "-" + pad2(dt.day as i64) + "T" + pad2(dt.hour as i64) + ":" + pad2(dt.minute as i64) + ":" + pad2(dt.second as i64) + "." + pad3(frac) + "Z"
}

fn dateMethod(st: &mut Interp, o: i64, name: &string, args: &Vec<JSValue>): JSValue {
    let ms = st.objExtras[st.objects[o].extra].dateMs
    if name == "getTime" || name == "valueOf" {
        return JSValue.Number(ms)
    }
    if name == "setTime" {
        var v = 0.0
        if args.len() > 0 {
            v = toNum(args[0])
        }
        st.objExtras[st.objects[o].extra].dateMs = v
        return JSValue.Number(v)
    }
    if name == "toISOString" || name == "toJSON" {
        return JSValue.Str(isoFromMillis(ms))
    }
    // the set*/setUTC* family. milojs keeps dates in UTC with a 0 offset, so the
    // local and UTC setters are equivalent — normalise setUTCFoo -> setFoo. The
    // date is decomposed to civil parts, the requested field(s) replaced, and
    // recomposed to epoch ms.
    var sname = name.clone()
    if sname.len() >= 6 && strSlice(sname, 0, 6) == "setUTC" {
        sname = "set" + strSlice(sname, 6, sname.len())
    }
    if sname == "setFullYear" || sname == "setMonth" || sname == "setDate" || sname == "setHours" || sname == "setMinutes" || sname == "setSeconds" || sname == "setMilliseconds" {
        let secs = (ms / 1000.0) as i64
        let dt = dateTimeFromEpoch(secs)
        var frac = mathMod(ms, 1000.0) as i64
        if frac < 0 {
            frac = frac + 1000
        }
        var year = dt.year as i64
        var month = dt.month as i64
        var day = dt.day as i64
        var hour = dt.hour as i64
        var minute = dt.minute as i64
        var second = dt.second as i64
        var millis = frac
        if sname == "setFullYear" {
            if args.len() > 0 {
                year = toNum(args[0]) as i64
            }
            if args.len() > 1 {
                month = (toNum(args[1]) as i64) + 1
            }
            if args.len() > 2 {
                day = toNum(args[2]) as i64
            }
        } else if sname == "setMonth" {
            if args.len() > 0 {
                month = (toNum(args[0]) as i64) + 1
            }
            if args.len() > 1 {
                day = toNum(args[1]) as i64
            }
        } else if sname == "setDate" {
            if args.len() > 0 {
                day = toNum(args[0]) as i64
            }
        } else if sname == "setHours" {
            if args.len() > 0 {
                hour = toNum(args[0]) as i64
            }
            if args.len() > 1 {
                minute = toNum(args[1]) as i64
            }
            if args.len() > 2 {
                second = toNum(args[2]) as i64
            }
            if args.len() > 3 {
                millis = toNum(args[3]) as i64
            }
        } else if sname == "setMinutes" {
            if args.len() > 0 {
                minute = toNum(args[0]) as i64
            }
            if args.len() > 1 {
                second = toNum(args[1]) as i64
            }
            if args.len() > 2 {
                millis = toNum(args[2]) as i64
            }
        } else if sname == "setSeconds" {
            if args.len() > 0 {
                second = toNum(args[0]) as i64
            }
            if args.len() > 1 {
                millis = toNum(args[1]) as i64
            }
        } else if sname == "setMilliseconds" {
            if args.len() > 0 {
                millis = toNum(args[0]) as i64
            }
        }
        let days = daysFromCivil(year, month, day)
        let newMs = ((days * 86400 + hour * 3600 + minute * 60 + second) * 1000 + millis) as f64
        st.objExtras[st.objects[o].extra].dateMs = newMs
        return JSValue.Number(newMs)
    }
    // getUTC* mirrors the local accessors but decomposes in UTC; normalise
    // getUTCFoo -> getFoo for the branch match and pick the decomposition by
    // whether the caller asked for UTC.
    var gname = name.clone()
    var isUtc = false
    if gname.len() >= 6 && strSlice(gname, 0, 6) == "getUTC" {
        isUtc = true
        gname = "get" + strSlice(gname, 6, gname.len())
    }
    if gname == "getFullYear" || gname == "getMonth" || gname == "getDate" || gname == "getHours" || gname == "getMinutes" || gname == "getSeconds" || gname == "getMilliseconds" || gname == "getDay" {
        var dt = dateTimeFromEpochLocal((ms / 1000.0) as i64)
        if isUtc {
            dt = dateTimeFromEpoch((ms / 1000.0) as i64)
        }
        if gname == "getFullYear" {
            return JSValue.Number(dt.year as f64)
        }
        if gname == "getMonth" {
            // JS months are zero-based
            return JSValue.Number((dt.month - 1) as f64)
        }
        if gname == "getDate" {
            return JSValue.Number(dt.day as f64)
        }
        if gname == "getHours" {
            return JSValue.Number(dt.hour as f64)
        }
        if gname == "getMinutes" {
            return JSValue.Number(dt.minute as f64)
        }
        if gname == "getSeconds" {
            return JSValue.Number(dt.second as f64)
        }
        if gname == "getDay" {
            return JSValue.Number(dt.weekday as f64)
        }
        return JSValue.Number(mathMod(ms, 1000.0))
    }
    if name == "toString" || name == "toUTCString" || name == "toLocaleString" || name == "toLocaleDateString" || name == "toLocaleTimeString" || name == "toDateString" {
        return JSValue.Str(isoFromMillis(ms))
    }
    if name == "getTimezoneOffset" {
        return JSValue.Number(0.0)
    }
    return JSValue.Undefined
}

fn isArrayMethod(name: &string): bool {
    return name == "map" || name == "filter" || name == "forEach" || name == "reduce" || name == "join" || name == "toString" || name == "indexOf" || name == "includes" || name == "slice" || name == "reverse" || name == "concat" || name == "push" || name == "pop" || name == "find" || name == "findIndex" || name == "some" || name == "every" || name == "shift" || name == "unshift" || name == "splice" || name == "sort" || name == "lastIndexOf" || name == "flat" || name == "fill" || name == "at" || name == "findLast" || name == "findLastIndex" || name == "copyWithin" || name == "reduceRight" || name == "flatMap" || name == "values" || name == "keys" || name == "entries" || name == "with" || name == "toReversed" || name == "toSorted" || name == "toSpliced"
}

// Dispatch a built-in Array method. `o` (the array) is temp-rooted by the caller;
// the result array and the callback are additionally rooted while callbacks run
// (a callback can allocate and collect).
// .then/.catch/.finally on an already-settled promise. Callbacks run immediately
// (no microtask queue), so ordering differs from real JS, but the value flow and
// the rejection-skips-onFulfilled rule match.
// .then/.catch/.finally. Handlers never run synchronously: they are queued as
// microtasks, so ordering matches JS instead of the old settle-in-place model.
fn promiseMethod(o: i64, name: &string, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    var onFul = JSValue.Undefined
    var onRej = JSValue.Undefined
    var isFinally = false
    if name == "then" {
        if args.len() > 0 {
            onFul = cloneValue(args[0])
        }
        if args.len() > 1 {
            onRej = cloneValue(args[1])
        }
    } else if name == "catch" {
        if args.len() > 0 {
            onRej = cloneValue(args[0])
        }
    } else {
        // finally: run the callback on either path, then pass the ORIGINAL
        // settlement through — the callback's return value is discarded and a
        // rejection stays a rejection
        if args.len() > 0 {
            onFul = cloneValue(args[0])
            onRej = cloneValue(args[0])
        }
        isFinally = true
    }
    let derived = newPromise(st, 0, JSValue.Undefined)
    let state = st.objects[o].promiseState
    if state == 2 {
        var ki: i64 = 0
        var kept: Vec<i64> = Vec.new()
        while ki < st.unhandledRejects.len() {
            if st.unhandledRejects[ki] != o {
                kept.push(st.unhandledRejects[ki])
            }
            ki = ki + 1
        }
        st.unhandledRejects = kept
    }
    if state == 0 {
        st.objExtras[st.objects[o].extra].reactions.push(Reaction {
            onFulfilled: onFul, onRejected: onRej, derived: derived, isFinally: isFinally
        }
        )
    } else {
        var handler = onFul
        if state == 2 {
            handler = onRej
        }
        st.microtasks.push(Microtask {
            cb: handler, arg: cloneValue(st.objExtras[st.objects[o].extra].promiseValue), derived: derived, passthroughReject: state == 2, isFinally: isFinally, noArgs: false
        }
        )
    }
    return JSValue.Obj(derived)
}

fn isCallable(v: &JSValue): bool {
    match v {
        JSValue.Func(_f, _e) => {
            return true
        }
        JSValue.Native(_i) => {
            return true
        }
        _ => {
            return false
        }
    }
}

// isCallable, but also true for bound-method objects (Function.prototype.bind
// results and the builtin bound methods). They are ordinary JSObjs, so the
// JSValue-only test above cannot see them — typeof already reports "function".
fn isCallableIn(st: &Interp, v: &JSValue): bool {
    if isCallable(v) {
        return true
    }
    let h = objHandle(v)
    if h >= 0 {
        // napiFn objects are functions implemented by a loaded addon; a proxy is
        // callable when whatever it wraps is
        if st.objects[h].isProxy {
            return isCallableIn(st, st.objExtras[st.objects[h].extra].proxyTarget)
        }
        return st.objects[h].isBound || st.objExtras[st.objects[h].extra].napiFn >= 0
    }
    return false
}

fn arrayMethod(prog: &Prog, o: i64, name: &string, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    let n = arrLen(st, o)
    // the mutating methods write through arrPush/elems directly, bypassing
    // setMember's frozen check, so a frozen array has to be caught here too
    if st.objects[o].frozen {
        if name == "push" || name == "pop" || name == "shift" || name == "unshift" || name == "splice" || name == "sort" || name == "reverse" || name == "fill" || name == "copyWithin" {
            return JSValue.Number(n as f64)
        }
    }
    if name == "push" {
        var j: i64 = 0
        while j < args.len() {
            arrPush(st, o, cloneValue(args[j]))
            j = j + 1
        }
        return JSValue.Number(arrLen(st, o) as f64)
    }
    if name == "pop" {
        if n == 0 {
            return JSValue.Undefined
        }
        return st.objects[o].elems.pop()!
    }
    if name == "shift" {
        if n == 0 {
            return JSValue.Undefined
        }
        let head = arrGet(st, o, 0)
        var rest: Vec<JSValue> = Vec.new()
        var i: i64 = 1
        while i < n {
            rest.push(arrGet(st, o, i))
            i = i + 1
        }
        st.objects[o].elems = rest
        return head
    }
    if name == "unshift" {
        var merged: Vec<JSValue> = Vec.new()
        var a: i64 = 0
        while a < args.len() {
            merged.push(cloneValue(args[a]))
            a = a + 1
        }
        var i: i64 = 0
        while i < n {
            merged.push(arrGet(st, o, i))
            i = i + 1
        }
        st.objects[o].elems = merged
        return JSValue.Number((n + args.len()) as f64)
    }
    if name == "find" || name == "findIndex" || name == "some" || name == "every" {
        if args.len() == 0 {
            if name == "every" {
                return JSValue.Bool(true)
            }
            if name == "some" {
                return JSValue.Bool(false)
            }
            if name == "findIndex" {
                return JSValue.Number(0.0 - 1.0)
            }
            return JSValue.Undefined
        }
        let cb = cloneValue(args[0])
        pushTemp(st, cloneValue(cb))
        var i: i64 = 0
        var found = -1
        var allTrue = true
        var anyTrue = false
        while i < arrLen(st, o) && found < 0 {
            let cbArgs = makeCbArgs(st, o, i)
            let r = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            let t = truthy(r)
            if t {
                anyTrue = true
                if name == "find" || name == "findIndex" || name == "some" {
                    found = i
                }
            } else {
                allTrue = false
                if name == "every" {
                    found = i
                }
            }
            if st.throwing {
                found = i
            }
            i = i + 1
        }
        popTemp(st)
        if name == "every" {
            return JSValue.Bool(allTrue)
        }
        if name == "some" {
            return JSValue.Bool(anyTrue)
        }
        if name == "findIndex" {
            return JSValue.Number(found as f64)
        }
        if found >= 0 {
            return arrGet(st, o, found)
        }
        return JSValue.Undefined
    }
    if name == "lastIndexOf" {
        var target = JSValue.Undefined
        if args.len() > 0 {
            target = cloneValue(args[0])
        }
        var i = n - 1
        while i >= 0 {
            if jsStrictEquals(arrGet(st, o, i), target) {
                return JSValue.Number(i as f64)
            }
            i = i - 1
        }
        return JSValue.Number(0.0 - 1.0)
    }
    if name == "values" || name == "keys" || name == "entries" {
        var kind: i64 = 0
        if name == "keys" {
            kind = 1
        } else if name == "entries" {
            kind = 2
        }
        return makeArrayIterator(st, o, kind)
    }
    if name == "at" {
        var idx: i64 = 0
        if args.len() > 0 {
            idx = toNum(args[0]) as i64
        }
        if idx < 0 {
            idx = n + idx
        }
        if idx < 0 || idx >= n {
            return JSValue.Undefined
        }
        return arrGet(st, o, idx)
    }
    // ES2023 change-by-copy: build a new array, never touch the receiver. These
    // live here rather than in the prelude because array member lookup never
    // falls back to Array.prototype — a method has to be on the whitelist above
    // and implemented here to be reachable at all.
    if name == "with" {
        var wi: i64 = 0
        if args.len() > 0 {
            wi = toNum(args[0]) as i64
        }
        if wi < 0 {
            wi = wi + n
        }
        // spec: out of range throws rather than clamping, so a bad index is a
        // loud error instead of a silently misplaced element
        if wi < 0 || wi >= n {
            st.throwing = true
            st.thrownValue = makeError(st, "RangeError", "Invalid index")
            return JSValue.Undefined
        }
        var wv = JSValue.Undefined
        if args.len() > 1 {
            wv = cloneValue(args[1])
        }
        let wout = newArray(st)
        pushTemp(st, JSValue.Obj(wout))
        var wk: i64 = 0
        while wk < n {
            if wk == wi {
                arrPush(st, wout, cloneValue(wv))
            } else {
                arrPush(st, wout, arrGet(st, o, wk))
            }
            wk = wk + 1
        }
        popTemp(st)
        return JSValue.Obj(wout)
    }
    if name == "toReversed" {
        let rout = newArray(st)
        pushTemp(st, JSValue.Obj(rout))
        var rk = n - 1
        while rk >= 0 {
            arrPush(st, rout, arrGet(st, o, rk))
            rk = rk - 1
        }
        popTemp(st)
        return JSValue.Obj(rout)
    }
    if name == "toSorted" {
        let sout = newArray(st)
        pushTemp(st, JSValue.Obj(sout))
        var sk: i64 = 0
        while sk < n {
            arrPush(st, sout, arrGet(st, o, sk))
            sk = sk + 1
        }
        // sort the copy in place with the existing implementation, so the two
        // orderings cannot drift apart
        let sorted = arrayMethod(prog, sout, "sort", args, st)
        popTemp(st)
        return sorted
    }
    if name == "toSpliced" {
        var ss: i64 = 0
        if args.len() > 0 {
            ss = toNum(args[0]) as i64
        }
        if ss < 0 {
            ss = n + ss
            if ss < 0 {
                ss = 0
            }
        } else if ss > n {
            ss = n
        }
        // no args deletes nothing; a lone start deletes the whole tail
        var sd: i64 = 0
        if args.len() == 1 {
            sd = n - ss
        } else if args.len() > 1 {
            sd = toNum(args[1]) as i64
            if sd < 0 {
                sd = 0
            }
            if sd > n - ss {
                sd = n - ss
            }
        }
        let tout = newArray(st)
        pushTemp(st, JSValue.Obj(tout))
        var tk: i64 = 0
        while tk < ss {
            arrPush(st, tout, arrGet(st, o, tk))
            tk = tk + 1
        }
        var ta: i64 = 2
        while ta < args.len() {
            arrPush(st, tout, cloneValue(args[ta]))
            ta = ta + 1
        }
        var tb = ss + sd
        while tb < n {
            arrPush(st, tout, arrGet(st, o, tb))
            tb = tb + 1
        }
        popTemp(st)
        return JSValue.Obj(tout)
    }
    if name == "findLast" || name == "findLastIndex" {
        if args.len() == 0 {
            if name == "findLastIndex" {
                return JSValue.Number(0.0 - 1.0)
            }
            return JSValue.Undefined
        }
        let cb = cloneValue(args[0])
        pushTemp(st, cloneValue(cb))
        var i = n - 1
        var found: i64 = -1
        while i >= 0 && found < 0 {
            let cbArgs = makeCbArgs(st, o, i)
            let r = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            if truthy(r) || st.throwing {
                found = i
            }
            i = i - 1
        }
        popTemp(st)
        if name == "findLastIndex" {
            return JSValue.Number(found as f64)
        }
        if found >= 0 {
            return arrGet(st, o, found)
        }
        return JSValue.Undefined
    }
    if name == "copyWithin" {
        // copyWithin(target, start, end) — an in-place memmove within the array
        var target: i64 = 0
        if args.len() > 0 {
            target = toNum(args[0]) as i64
        }
        if target < 0 {
            target = n + target
        }
        var start: i64 = 0
        if args.len() > 1 {
            start = toNum(args[1]) as i64
        }
        if start < 0 {
            start = n + start
        }
        var end = n
        if args.len() > 2 {
            end = toNum(args[2]) as i64
            if end < 0 {
                end = n + end
            }
        }
        if target < 0 {
            target = 0
        }
        if start < 0 {
            start = 0
        }
        if end > n {
            end = n
        }
        // snapshot first: source and destination ranges may overlap
        var snap: Vec<JSValue> = Vec.new()
        var s = start
        while s < end {
            snap.push(arrGet(st, o, s))
            s = s + 1
        }
        var k: i64 = 0
        while k < snap.len() && target + k < n {
            st.objects[o].elems[target + k] = cloneValue(snap[k])
            k = k + 1
        }
        return JSValue.Obj(o)
    }
    if name == "fill" {
        var v = JSValue.Undefined
        if args.len() > 0 {
            v = cloneValue(args[0])
        }
        // fill(value, start, end) — the range args are optional but not ignorable
        var start: i64 = 0
        if args.len() > 1 {
            start = toNum(args[1]) as i64
            if start < 0 {
                start = n + start
            }
        }
        var end = n
        if args.len() > 2 {
            end = toNum(args[2]) as i64
            if end < 0 {
                end = n + end
            }
        }
        if start < 0 {
            start = 0
        }
        if end > n {
            end = n
        }
        var i = start
        while i < end {
            st.objects[o].elems[i] = cloneValue(v)
            i = i + 1
        }
        return JSValue.Obj(o)
    }
    if name == "splice" {
        // splice(start, deleteCount, ...items) — mutates and returns the removed
        var start: i64 = 0
        if args.len() > 0 {
            start = toNum(args[0]) as i64
        }
        if start < 0 {
            start = n + start
        }
        if start < 0 {
            start = 0
        }
        if start > n {
            start = n
        }
        var delCount = n - start
        if args.len() > 1 {
            delCount = toNum(args[1]) as i64
        }
        if delCount < 0 {
            delCount = 0
        }
        if start + delCount > n {
            delCount = n - start
        }
        let removed = newArray(st)
        pushTemp(st, JSValue.Obj(removed))
        var kept: Vec<JSValue> = Vec.new()
        var i: i64 = 0
        while i < n {
            if i == start {
                var a: i64 = 2
                while a < args.len() {
                    kept.push(cloneValue(args[a]))
                    a = a + 1
                }
            }
            if i >= start && i < start + delCount {
                arrPush(st, removed, arrGet(st, o, i))
            } else {
                kept.push(arrGet(st, o, i))
            }
            i = i + 1
        }
        if start >= n {
            var a: i64 = 2
            while a < args.len() {
                kept.push(cloneValue(args[a]))
                a = a + 1
            }
        }
        st.objects[o].elems = kept
        popTemp(st)
        return JSValue.Obj(removed)
    }
    if name == "sort" {
        // insertion sort; default order is by string value, as in JS
        var hasCmp = false
        var cmp = JSValue.Undefined
        if args.len() > 0 && isCallable(args[0]) {
            hasCmp = true
            cmp = cloneValue(args[0])
        }
        pushTemp(st, cloneValue(cmp))
        var i: i64 = 1
        while i < arrLen(st, o) {
            let key = arrGet(st, o, i)
            var j = i - 1
            var placed = false
            while j >= 0 && !placed {
                let cur = arrGet(st, o, j)
                var greater = false
                if hasCmp {
                    var cargs: Vec<JSValue> = Vec.new()
                    cargs.push(cloneValue(cur))
                    cargs.push(cloneValue(key))
                    let r = callValue(prog, cmp, cargs, JSValue.Undefined, st)
                    greater = toNum(r) > 0.0
                } else {
                    greater = strLess(toStr(key), toStr(cur))
                }
                if greater {
                    st.objects[o].elems[j + 1] = cur
                    j = j - 1
                } else {
                    placed = true
                }
            }
            st.objects[o].elems[j + 1] = key
            i = i + 1
        }
        popTemp(st)
        return JSValue.Obj(o)
    }
    if name == "join" || name == "toString" {
        // Array.prototype.toString is join(",") — NOT the [object Array] type tag
        // (that is Object.prototype.toString.call(arr), a separate dispatch)
        var sep = ","
        if name == "join" && args.len() > 0 {
            sep = toStr(args[0])
        }
        return JSValue.Str(joinArray(st, o, sep))
    }
    if name == "indexOf" {
        // optional fromIndex (negative counts from the end)
        var i: i64 = 0
        if args.len() > 1 {
            var fi = toNum(args[1]) as i64
            if fi < 0 {
                fi = n + fi
                if fi < 0 {
                    fi = 0
                }
            }
            i = fi
        }
        while i < n {
            let e = arrGet(st, o, i)
            if args.len() > 0 && jsEquals(e, args[0]) {
                return JSValue.Number(i as f64)
            }
            i = i + 1
        }
        return JSValue.Number(0.0 - 1.0)
    }
    if name == "includes" {
        var i: i64 = 0
        while i < n {
            let e = arrGet(st, o, i)
            // includes uses SameValueZero, so it finds NaN (unlike indexOf's ===)
            if args.len() > 0 && sameValueZero(e, args[0]) {
                return JSValue.Bool(true)
            }
            i = i + 1
        }
        return JSValue.Bool(false)
    }
    if name == "slice" {
        var a: i64 = 0
        var b = n
        if args.len() > 0 {
            a = toNum(args[0]) as i64
        }
        if args.len() > 1 {
            b = toNum(args[1]) as i64
        }
        if a < 0 {
            a = n + a
            if a < 0 {
                a = 0
            }
        }
        if b < 0 {
            b = n + b
        }
        if b > n {
            b = n
        }
        let sliced = newArray(st)
        var i = a
        while i < b {
            arrPush(st, sliced, arrGet(st, o, i))
            i = i + 1
        }
        return JSValue.Obj(sliced)
    }
    if name == "reverse" {
        var i: i64 = 0
        var j = n - 1
        while i < j {
            let lo = arrGet(st, o, i)
            let hi = arrGet(st, o, j)
            arrSet(st, o, i, hi)
            arrSet(st, o, j, lo)
            i = i + 1
            j = j - 1
        }
        return JSValue.Obj(o)
    }
    if name == "concat" {
        let joined = newArray(st)
        pushTemp(st, JSValue.Obj(joined))
        var i: i64 = 0
        while i < n {
            arrPush(st, joined, arrGet(st, o, i))
            i = i + 1
        }
        var a: i64 = 0
        while a < args.len() {
            let av = cloneValue(args[a])
            match av {
                JSValue.Obj(other) => {
                    if st.objects[other].isArray {
                        var k: i64 = 0
                        let m = arrLen(st, other)
                        while k < m {
                            arrPush(st, joined, arrGet(st, other, k))
                            k = k + 1
                        }
                    } else {
                        arrPush(st, joined, JSValue.Obj(other))
                    }
                }
                _ => {
                    arrPush(st, joined, cloneValue(args[a]))
                }
            }
            a = a + 1
        }
        popTemp(st)
        return JSValue.Obj(joined)
    }
    // callback methods: root the callback across the loop
    var cb = JSValue.Undefined
    if args.len() > 0 {
        cb = cloneValue(args[0])
    }
    pushTemp(st, cloneValue(cb))
    if name == "map" {
        let mapped = newArray(st)
        pushTemp(st, JSValue.Obj(mapped))
        var i: i64 = 0
        while i < n {
            let cbArgs = makeCbArgs(st, o, i)
            let r = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            arrPush(st, mapped, r)
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return JSValue.Obj(mapped)
    }
    if name == "filter" {
        let kept = newArray(st)
        pushTemp(st, JSValue.Obj(kept))
        var i: i64 = 0
        while i < n {
            let elem = arrGet(st, o, i)
            let cbArgs = makeCbArgs(st, o, i)
            let keep = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            if truthy(keep) {
                arrPush(st, kept, elem)
            }
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return JSValue.Obj(kept)
    }
    if name == "forEach" {
        var i: i64 = 0
        while i < n {
            let cbArgs = makeCbArgs(st, o, i)
            let _ = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            i = i + 1
        }
        popTemp(st)
        return JSValue.Undefined
    }
    if name == "reduce" {
        var acc = JSValue.Undefined
        var start: i64 = 0
        if args.len() > 1 {
            acc = cloneValue(args[1])
        } else {
            if n > 0 {
                acc = arrGet(st, o, 0)
                start = 1
            }
        }
        pushTemp(st, cloneValue(acc))
        var i = start
        while i < n {
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(cloneValue(acc))
            cbArgs.push(arrGet(st, o, i))
            cbArgs.push(JSValue.Number(i as f64))
            acc = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return acc
    }
    if name == "reduceRight" {
        var acc = JSValue.Undefined
        var start = n - 1
        if args.len() > 1 {
            acc = cloneValue(args[1])
        } else {
            if n > 0 {
                acc = arrGet(st, o, n - 1)
                start = n - 2
            }
        }
        pushTemp(st, cloneValue(acc))
        var i = start
        while i >= 0 {
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(cloneValue(acc))
            cbArgs.push(arrGet(st, o, i))
            cbArgs.push(JSValue.Number(i as f64))
            acc = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            i = i - 1
        }
        popTemp(st)
        popTemp(st)
        return acc
    }
    if name == "flatMap" {
        let out = newArray(st)
        pushTemp(st, JSValue.Obj(out))
        var i: i64 = 0
        while i < arrLen(st, o) && !st.throwing {
            let cbArgs = makeCbArgs(st, o, i)
            let r = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            // one level of flattening, and only for array results
            let rh = objHandle(r)
            if rh >= 0 && st.objects[rh].isArray {
                var j: i64 = 0
                while j < arrLen(st, rh) {
                    arrPush(st, out, arrGet(st, rh, j))
                    j = j + 1
                }
            } else {
                arrPush(st, out, r)
            }
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return JSValue.Obj(out)
    }
    if name == "flat" {
        var depth: i64 = 1
        if args.len() > 0 {
            let dn = toNum(args[0])
            if dn > 1000000.0 {
                // Infinity / very deep → cap (real arrays never nest this far)
                depth = 1000000
            } else if dn < 0.0 || dn != dn {
                depth = 0
            } else {
                depth = dn as i64
            }
        }
        let out = newArray(st)
        pushTemp(st, JSValue.Obj(out))
        flattenInto(st, out, o, depth)
        popTemp(st)
        popTemp(st)
        return JSValue.Obj(out)
    }
    popTemp(st)
    return JSValue.Undefined
}

// Flatten `arr` into `out` up to `depth` levels of nested arrays.
fn flattenInto(st: &mut Interp, out: i64, arr: i64, depth: i64) {
    var i: i64 = 0
    while i < arrLen(st, arr) {
        let v = arrGet(st, arr, i)
        let vh = objHandle(v)
        if depth > 0 && vh >= 0 && st.objects[vh].isArray {
            flattenInto(st, out, vh, depth - 1)
        } else {
            arrPush(st, out, v)
        }
        i = i + 1
    }
}

// Call a member as a method: `this` binds to the receiver. String and array
// receivers dispatch to built-in methods; object receivers use function-valued
// properties. The receiver is temp-rooted across argument evaluation (an argument
// may be a call that triggers GC).
// toString/valueOf and friends on a number, boolean, string, null or undefined.
// Number.toLocaleString default (en-US): thousands-grouped integer part, up to 3
// fraction digits with trailing zeros stripped — (1000000).toLocaleString() is
// "1,000,000" and (1234.5678) is "1,234.568". Only the default locale; no
// currency/percent options.
fn numToLocale(n: f64): string {
    if !(n == n) {
        return "NaN"
    }
    if !isFiniteF(n) {
        if n < 0.0 {
            return "-∞"
        }
        return "∞"
    }
    let neg = n < 0.0
    var abs = n
    if neg {
        abs = 0.0 - n
    }
    // round to 3 fraction digits, then split on the '.'
    let fixed = numToFixed(abs, 3)
    var intPart = fixed.clone()
    var fracPart = ""
    var dot: i64 = 0
    while dot < fixed.len() {
        if fixed[dot] == '.' {
            intPart = strSlice(fixed, 0, dot)
            fracPart = strSlice(fixed, dot + 1, fixed.len())
            dot = fixed.len()
        } else {
            dot = dot + 1
        }
    }
    // strip trailing zeros from the fraction
    var fe = fracPart.len()
    while fe > 0 && fracPart[fe - 1] == '0' {
        fe = fe - 1
    }
    fracPart = strSlice(fracPart, 0, fe)
    // group the integer part with commas every three digits from the right
    var grouped = ""
    let ilen = intPart.len()
    var k: i64 = 0
    while k < ilen {
        if k > 0 && (ilen - k) % 3 == 0 {
            grouped = grouped + ","
        }
        grouped = grouped + strSlice(intPart, k, k + 1)
        k = k + 1
    }
    var out = grouped
    if fracPart.len() > 0 {
        out = out + "." + fracPart
    }
    if neg {
        out = "-" + out
    }
    return out
}

fn primitiveMethod(name: &string, recv: &JSValue, args: &Vec<JSValue>): JSValue {
    if name == "valueOf" {
        return cloneValue(recv)
    }
    // symbols are interned strings, so a direct sym.toString() lands here before
    // the builtin-method path and would otherwise leak the internal form
    match recv {
        JSValue.Str(sv) => {
            if isSymbolStr(sv) && name == "toString" {
                return JSValue.Str(symbolDisplay(sv))
            }
        }
        _ => {
        }
    }
    if name == "toExponential" {
        if args.len() == 0 {
            return JSValue.Str(numToExponential(toNum(recv), 0, false))
        }
        return JSValue.Str(numToExponential(toNum(recv), toNum(args[0]) as i64, true))
    }
    if name == "toFixed" || name == "toPrecision" {
        var digits: i64 = 0
        if args.len() > 0 {
            digits = toNum(args[0]) as i64
        }
        if name == "toPrecision" {
            if args.len() == 0 {
                return JSValue.Str(toStr(recv))
            }
            return JSValue.Str(numToPrecision(toNum(recv), digits))
        }
        return JSValue.Str(numToFixed(toNum(recv), digits))
    }
    // toString(radix). BigInt uses arbitrary-precision conversion (bnToRadix);
    // numbers go through the f64-backed numToRadix. A BigInt is exact at any size.
    if isBigIntVal(recv) {
        var radix: i64 = 10
        if args.len() > 0 {
            radix = toNum(args[0]) as i64
        }
        if radix >= 2 && radix <= 36 {
            return JSValue.Str(bnToRadix(bigStrOf(recv), radix))
        }
    }
    if args.len() > 0 {
        let radix = toNum(args[0]) as i64
        if radix >= 2 && radix <= 36 && radix != 10 {
            return JSValue.Str(numToRadix(toNum(recv), radix))
        }
    }
    // number.toLocaleString() → thousands-grouped default-locale form
    if name == "toLocaleString" {
        match recv {
            JSValue.Number(n) => {
                return JSValue.Str(numToLocale(n))
            }
            _ => {
            }
        }
    }
    return JSValue.Str(toStr(recv))
}

fn callMember(prog: &Prog, recv: JSValue, name: &string, argsIdx: i64, st: &mut Interp, scope: i64): JSValue {
    // Methods every primitive answers to. JS boxes the receiver for these; here
    // they are answered directly, which covers the cases real code uses.
    if name == "toString" || name == "valueOf" || name == "toFixed" || name == "toPrecision" || name == "toExponential" || name == "toLocaleString" {
        let isPrimitive = objHandle(recv) < 0 && funcHandle(recv) < 0
        if isPrimitive {
            let argVals = evalArgs(prog, argsIdx, st, scope)
            return primitiveMethod(name, recv, argVals)
        }
    }
    match recv {
        JSValue.Str(s) => {
            let argVals = evalArgs(prog, argsIdx, st, scope)
            // regex-based string ops when the first arg is a RegExp
            if argVals.len() > 0 && regexIdOf(st, argVals[0]) >= 0 {
                let rid = regexIdOf(st, argVals[0])
                if name == "replace" || name == "replaceAll" {
                    if argVals.len() > 1 && isCallable(argVals[1]) {
                        return regexReplaceFn(prog, st, s, rid, argVals[1])
                    }
                    var repl = ""
                    if argVals.len() > 1 {
                        repl = toStr(argVals[1])
                    }
                    return regexReplace(st, s, rid, repl)
                }
                if name == "match" {
                    return regexStrMatch(st, s, rid)
                }
                if name == "matchAll" {
                    return regexStrMatchAll(st, s, rid)
                }
                if name == "split" {
                    return regexSplit(st, s, rid)
                }
                if name == "search" {
                    // index of the first match, or -1 (UTF-16 units)
                    let saves = regexExec(st.regexes[rid], s, 0)
                    if saves.len() == 0 {
                        return JSValue.Number(0.0 - 1.0)
                    }
                    return JSValue.Number(byteToUtf16(s, saves[0]) as f64)
                }
            }
            return stringMethod(name, s, argVals, st)
        }
        JSValue.Obj(o) => {
            pushTemp(st, JSValue.Obj(o))
            // ArrayBuffer methods (resize/transfer/slice) live in
            // callBuiltinByName; route them there rather than duplicating
            if st.objects[o].isArrayBuffer {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = callBuiltinByName(prog, JSValue.Obj(o), name, argVals, st)
                popTemp(st)
                return r
            }
            if st.objExtras[st.objects[o].extra].regexId >= 0 {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = regexMethod(st, o, name, argVals)
                popTemp(st)
                return r
            }
            // .call/.apply on a bound-method value: [].slice.call(arguments, 1)
            if st.objects[o].isBound && (name == "call" || name == "apply" || name == "bind") {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                var newThis = JSValue.Undefined
                if argVals.len() > 0 {
                    newThis = cloneValue(argVals[0])
                }
                var rest: Vec<JSValue> = Vec.new()
                if name == "apply" {
                    if argVals.len() > 1 {
                        let ah = objHandle(argVals[1])
                        if ah >= 0 && st.objects[ah].isArray {
                            var ai: i64 = 0
                            while ai < arrLen(st, ah) {
                                rest.push(arrGet(st, ah, ai))
                                ai = ai + 1
                            }
                        }
                    }
                } else {
                    var ai: i64 = 1
                    while ai < argVals.len() {
                        rest.push(cloneValue(argVals[ai]))
                        ai = ai + 1
                    }
                }
                let exo = st.objects[o].extra
                let mname = st.objExtras[exo].boundMethod.clone()
                if name == "bind" {
                    // re-binding an already-bound function: JS keeps the ORIGINAL
                    // this and only APPENDS args (the second bind's thisArg is
                    // ignored). The old code dropped to makeBoundMethod with the
                    // (usually empty) method name, so a double bind returned a
                    // broken value — which silently made zod's constructor-bound
                    // parseAsync return undefined once tRPC bound it again.
                    // newObject runs while `o` is still temp-rooted (popTemp below).
                    var na: Vec<JSValue> = Vec.new()
                    var oi: i64 = 0
                    while oi < st.objExtras[exo].boundArgs.len() {
                        na.push(cloneValue(st.objExtras[exo].boundArgs[oi]))
                        oi = oi + 1
                    }
                    var ri: i64 = 0
                    while ri < rest.len() {
                        na.push(cloneValue(rest[ri]))
                        ri = ri + 1
                    }
                    let bTarget = cloneValue(st.objExtras[exo].boundTarget)
                    let bThis = cloneValue(st.objExtras[exo].boundThis)
                    let nb = newObject(st)
                    st.objects[nb].isBound = true
                    let exn = ensureExtra(st, nb)
                    st.objExtras[exn].boundTarget = bTarget
                    st.objExtras[exn].boundMethod = mname.clone()
                    st.objExtras[exn].boundThis = bThis
                    st.objExtras[exn].boundArgs = na
                    popTemp(st)
                    return JSValue.Obj(nb)
                }
                popTemp(st)
                if mname.len() > 0 {
                    return callBuiltinByName(prog, newThis, mname, rest, st)
                }
                let target = cloneValue(st.objExtras[exo].boundTarget)
                return callValue(prog, target, rest, newThis, st)
            }
            if st.objects[o].isBound && st.objExtras[st.objects[o].extra].boundMethod.len() == 0 {
                // any other method on a bind() result goes to its target
                let target = cloneValue(st.objExtras[st.objects[o].extra].boundTarget)
                let th = objHandle(target)
                if th >= 0 {
                    let r = callMember(prog, target, name, argsIdx, st, scope)
                    popTemp(st)
                    return r
                }
            }
            if name == "hasOwnProperty" || name == "isPrototypeOf" || name == "propertyIsEnumerable" {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = callBuiltinByName(prog, JSValue.Obj(o), name, argVals, st)
                popTemp(st)
                return r
            }
            // err.toString() -> "Name: message"; arr.toString() -> join(",").
            // Object.prototype.toString.call(x) still gives the type tag (it
            // reaches callBuiltinByName directly, a separate path).
            if name == "toString" && st.objects[o].isError {
                let en = toStr(objGet(st, o, "name"))
                let em = toStr(objGet(st, o, "message"))
                popTemp(st)
                if em.len() > 0 {
                    return JSValue.Str(en + ": " + em)
                }
                return JSValue.Str(en)
            }
            if st.objects[o].isDate {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = dateMethod(st, o, name, argVals)
                popTemp(st)
                return r
            }
            if st.objects[o].isMap || st.objects[o].isSet {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = mapMethod(prog, o, name, argVals, st)
                popTemp(st)
                return r
            }
            if isPromise(st, o) && (name == "then" || name == "catch" || name == "finally") {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = promiseMethod(o, name, argVals, st)
                popTemp(st)
                return r
            }
            if st.objects[o].isArray && isArrayMethod(name) {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = arrayMethod(prog, o, name, argVals, st)
                popTemp(st)
                return r
            }
            // getMemberDyn so a property whose value comes from a getter is
            // callable, e.g. Object.defineProperty(o, "fn", { get: () => f })
            let m = getMemberDyn(prog, o, name, st)
            match m {
                JSValue.Func(fIdx, envIdx) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let r = callFunction(prog, fIdx, envIdx, argVals, JSValue.Obj(o), st)
                    popTemp(st)
                    return r
                }
                JSValue.Native(id) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let r = callNative(id, argVals, st)
                    popTemp(st)
                    return r
                }
                JSValue.Obj(fo) => {
                    // a bound-method or bind() result stored as a property: it is
                    // callable (typeof reports "function") but is not a Func/Native
                    if st.objects[fo].isBound || st.objExtras[st.objects[fo].extra].napiFn >= 0 || st.objects[fo].isProxy {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        let r = callValue(prog, JSValue.Obj(fo), argVals, JSValue.Obj(o), st)
                        popTemp(st)
                        return r
                    }
                    popTemp(st)
                    st.throwing = true
                    st.thrownValue = makeError(st, "TypeError", name.clone() + " is not a function" + currentModule(st))
                    return JSValue.Undefined
                }
                _ => {
                    // plain objects are not linked to Object.prototype, so its
                    // methods (toString/valueOf) fall through to here
                    if name == "toString" || name == "valueOf" {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        let r = callBuiltinByName(prog, JSValue.Obj(o), name, argVals, st)
                        popTemp(st)
                        return r
                    }
                    popTemp(st)
                    st.throwing = true
                    st.thrownValue = makeError(st, "TypeError", name.clone() + " is not a function" + currentModule(st))
                    return JSValue.Undefined
                }
            }
        }
        JSValue.Native(nid) => {
            // Function.prototype.apply/call/bind on a native function
            // (Math.max.apply(null, arr) etc.) — dispatch through callBuiltinByName
            if name == "apply" || name == "call" || name == "bind" {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                return callBuiltinByName(prog, JSValue.Native(nid), name, argVals, st)
            }
            // statics hanging off a native constructor, e.g. String.fromCharCode
            let bag = getNativeProps(st, nid)
            let assigned = getMember(st, bag, name)
            if isCallable(assigned) {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                return callValue(prog, assigned, argVals, JSValue.Native(nid), st)
            }
            if nid == NATIVE_DATE && st.dateCtorProps >= 0 {
                let m = getMember(st, st.dateCtorProps, name)
                if isCallable(m) {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    return callValue(prog, m, argVals, JSValue.Undefined, st)
                }
            }
            if nid == NATIVE_STRING && st.stringCtorProps >= 0 {
                let m = getMember(st, st.stringCtorProps, name)
                if isCallable(m) {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    return callValue(prog, m, argVals, JSValue.Undefined, st)
                }
            }
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", name.clone() + " is not a function" + currentModule(st))
            return JSValue.Undefined
        }
        JSValue.Func(bf, benv) => {
            // method call on a function value: either a static (Class.make())
            // or .call/.apply, which retarget `this`
            if name == "bind" {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                var extra: Vec<JSValue> = Vec.new()
                var bi: i64 = 1
                while bi < argVals.len() {
                    extra.push(cloneValue(argVals[bi]))
                    bi = bi + 1
                }
                let bo = newObject(st)
                st.objects[bo].isBound = true
                let ex = ensureExtra(st, bo)
                st.objExtras[ex].boundTarget = JSValue.Func(bf, benv)
                if argVals.len() > 0 {
                    st.objExtras[ex].boundThis = cloneValue(argVals[0])
                }
                st.objExtras[ex].boundArgs = extra
                return JSValue.Obj(bo)
            }
            if name == "call" || name == "apply" {
                var argVals = evalArgs(prog, argsIdx, st, scope)
                var thisArg = JSValue.Undefined
                var rest: Vec<JSValue> = Vec.new()
                if argVals.len() > 0 {
                    thisArg = cloneValue(argVals[0])
                }
                if name == "apply" {
                    // apply takes the args as one array
                    if argVals.len() > 1 {
                        let ah = objHandle(argVals[1])
                        if ah >= 0 && st.objects[ah].isArray {
                            var ai: i64 = 0
                            while ai < arrLen(st, ah) {
                                rest.push(arrGet(st, ah, ai))
                                ai = ai + 1
                            }
                        }
                    }
                } else {
                    var ai: i64 = 1
                    while ai < argVals.len() {
                        rest.push(cloneValue(argVals[ai]))
                        ai = ai + 1
                    }
                }
                return callFunction(prog, bf, benv, rest, thisArg, st)
            }
            let statics = getFuncStatics(st, bf, benv)
            let m = getMember(st, statics, name)
            let mf = funcHandle(m)
            if mf >= 0 {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                return callValue(prog, m, argVals, JSValue.Func(bf, benv), st)
            }
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", name.clone() + " is not a function" + currentModule(st))
            return JSValue.Undefined
        }
        _ => {
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", "cannot read property '" + name.clone() + "' of a non-object" + currentModule(st))
            return JSValue.Undefined
        }
    }
}

// Reading a property of null/undefined is a TypeError, not undefined. Returning
// undefined instead turns a typo into a value that fails much later, somewhere
// unrelated.
fn throwNullMember(st: &mut Interp, name: &string, base: &string): JSValue {
    // No currentModule() suffix here: this message is spec-defined text that real
    // code (and the conformance suite) compares against, so decorating it would
    // corrupt e.message.
    st.throwing = true
    st.thrownValue = makeError(st, "TypeError", "cannot read property '" + name.clone() + "' of " + base.clone())
    return JSValue.Undefined
}

fn evalCall(prog: &Prog, calleeIdx: i64, argsIdx: i64, st: &mut Interp, scope: i64): JSValue {
    // builtin: console.log(...)
    match prog.exprs[calleeIdx] {
        Expr.Ident(fname) => {
            // super(...) — parsed as a call of __super$<Class>. The base
            // constructor runs against the instance being built, so `this` has
            // to be threaded through explicitly.
            if isSuperName(fname) {
                let baseVal = scopeLookup(st, scope, fname)
                let thisVal = scopeLookup(st, scope, "this")
                let argVals = evalArgs(prog, argsIdx, st, scope)
                // A native base constructor (class X extends Error) would build
                // and return its own object, discarding `this`. Initialise the
                // instance in place instead, so this.message is set and the
                // instance is recognised by instanceof Error.
                let baseNative = nativeHandle(baseVal)
                if baseNative >= 0 && isErrorCtor(baseNative) {
                    let selfObj = objHandle(thisVal)
                    if selfObj >= 0 {
                        st.objects[selfObj].isError = true
                        objSet(st, selfObj, "name", JSValue.Str(nativeErrorName(baseNative)))
                        var msg = ""
                        if argVals.len() > 0 {
                            msg = toStr(argVals[0])
                        }
                        objSet(st, selfObj, "message", JSValue.Str(msg))
                    }
                    return JSValue.Undefined
                }
                return callValue(prog, baseVal, argVals, thisVal, st)
            }
            // eval of a bare identifier, resolved in the calling scope. Not a
            // real eval — there is no runtime compiler — but it covers the one
            // shape bundled libraries actually use to reach past a bundler:
            // `eval("__dirname")` (prisma) and `eval("require")`. Anything else
            // is a hard error rather than a silent wrong answer.
            if fname == "eval" && !scopeHas(st, scope, "eval") {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                var src = ""
                if argVals.len() > 0 {
                    src = toStr(argVals[0])
                }
                if isIdentifierText(src) && scopeHas(st, scope, src) {
                    return scopeLookup(st, scope, src)
                }
                st.throwing = true
                st.thrownValue = makeError(st, "EvalError", "eval is limited to a bare identifier in scope, got: " + src)
                return JSValue.Undefined
            }
            // require(spec) is handled here rather than as a native because it
            // needs the program (to run the required module's block)
            if fname == "require" {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                var spec = ""
                if argVals.len() > 0 {
                    spec = toStr(argVals[0])
                }
                return requireModule(prog, spec, st)
            }
        }
        Expr.Member(objIdx, name) => {
            match prog.exprs[objIdx] {
                Expr.Ident(objName) => {
                    if objName == "console" && (name == "log" || name == "error" || name == "warn" || name == "info" || name == "debug" || name == "trace" || name == "dir") {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        // an argument that threw must not still be printed
                        if st.throwing {
                            return JSValue.Undefined
                        }
                        var line = ""
                        var j: i64 = 0
                        while j < argVals.len() {
                            if j > 0 {
                                line = line + " "
                            }
                            line = line + inspectTop(st, argVals[j])
                            j = j + 1
                        }
                        print(line)
                        // node line-buffers to a terminal; without flushing here
                        // a Ctrl-C or SIGKILL discards everything the program
                        // printed, which makes a long-running server look silent
                        flush()
                        return JSValue.Undefined
                    }
                }
                _ => {
                }
            }
        }
        _ => {
        }
    }

    // A Member/Index callee is a method call: `this` binds to the receiver.
    // Anything else is a plain call with `this` = undefined.
    match prog.exprs[calleeIdx] {
        Expr.Member(objIdx, name) => {
            // super.method() — the base's *prototype* holds the method, and it
            // must run against the current `this`, not against the base itself
            match prog.exprs[objIdx] {
                Expr.Ident(bname) => {
                    if isSuperName(bname) {
                        let baseVal = scopeLookup(st, scope, bname)
                        let bf = funcHandle(baseVal)
                        if bf >= 0 {
                            let baseProto = getFuncProto(st, bf)
                            let m = getMember(st, baseProto, name)
                            let thisVal = scopeLookup(st, scope, "this")
                            let argVals = evalArgs(prog, argsIdx, st, scope)
                            return callValue(prog, m, argVals, thisVal, st)
                        }
                    }
                }
                _ => {
                }
            }
            let recv = evalExpr(prog, objIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            // a throw while evaluating the receiver must propagate. Continuing
            // called the method on `undefined`, so a real error deep in a
            // method chain surfaced as "cannot read property 'x' of a
            // non-object" at the NEXT link — pointing at the wrong code.
            if st.throwing {
                return JSValue.Undefined
            }
            return callMember(prog, recv, name, argsIdx, st, scope)
        }
        Expr.Index(objIdx, keyIdx) => {
            let recv = evalExpr(prog, objIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            if st.throwing {
                return JSValue.Undefined
            }
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            return callMember(prog, recv, key, argsIdx, st, scope)
        }
        Expr.OptMember(objIdx, name) => {
            // a?.method(args): dispatch as a method call on the base (so string/
            // native methods resolve) unless the base is nullish
            let recv = evalExpr(prog, objIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            if isNullish(recv) {
                st.optShort = true
                return JSValue.Undefined
            }
            return callMember(prog, recv, name, argsIdx, st, scope)
        }
        Expr.OptIndex(objIdx, keyIdx) => {
            let recv = evalExpr(prog, objIdx, st, scope)
            if st.optShort {
                return JSValue.Undefined
            }
            if isNullish(recv) {
                st.optShort = true
                return JSValue.Undefined
            }
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            return callMember(prog, recv, key, argsIdx, st, scope)
        }
        _ => {
            let calleeVal = evalExpr(prog, calleeIdx, st, scope)
            // a preceding `?.` short-circuited: the call is skipped, result undefined
            if st.optShort {
                return JSValue.Undefined
            }
            // evaluating the callee can throw (an undeclared name is a
            // ReferenceError); reporting "is not a function" on top of that just
            // buries the real error
            if st.throwing {
                return JSValue.Undefined
            }
            match calleeVal {
                JSValue.Func(fIdx, envIdx) => {
                    pushTemp(st, JSValue.Func(fIdx, envIdx))
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let r = callFunction(prog, fIdx, envIdx, argVals, JSValue.Undefined, st)
                    popTemp(st)
                    return r
                }
                JSValue.Native(id) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    return callNative(id, argVals, st)
                }
                JSValue.Obj(bo) => {
                    // bound methods, addon functions and proxies are all callable
                    // objects rather than Func/Native values
                    if st.objects[bo].isBound || st.objects[bo].isProxy || st.objExtras[st.objects[bo].extra].napiFn >= 0 {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        return callValue(prog, JSValue.Obj(bo), argVals, JSValue.Undefined, st)
                    }
                    // Array(n) without `new` behaves identically to new Array(n)
                    if st.arrayCtorObj >= 0 && bo == st.arrayCtorObj {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        return makeArrayFromCtor(st, argVals)
                    }
                    st.throwing = true
                    st.thrownValue = makeError(st, "TypeError", describeCallee(prog, calleeIdx) + " is not a function" + currentModule(st))
                    return JSValue.Undefined
                }
                _ => {
                    st.throwing = true
                    st.thrownValue = makeError(st, "TypeError", describeCallee(prog, calleeIdx) + " is not a function" + currentModule(st))
                    return JSValue.Undefined
                }
            }
        }
    }
}

// try/catch/finally. The catch binding and both the pending throw value and any
// pending return value are rooted across the finally block (which can allocate
// and collect). finally overrides: its own throw or return wins; otherwise the
// try/catch's pending throw or return is restored.
fn execTry(prog: &Prog, tryB: i64, param: &string, catchB: i64, finallyB: i64, st: &mut Interp, scope: i64): Flow {
    let tryScope = newScope(st, scope)
    pushActive(st, tryScope)
    var flow = execBlock(prog, tryB, st, tryScope)
    popActive(st)

    if st.throwing && catchB >= 0 {
        let caught = cloneValue(st.thrownValue)
        st.throwing = false
        st.thrownValue = JSValue.Undefined
        let catchScope = newScope(st, scope)
        pushActive(st, catchScope)
        if param.len() > 0 {
            scopeDefine(st, catchScope, param.clone(), caught)
        }
        flow = execBlock(prog, catchB, st, catchScope)
        popActive(st)
    }

    if finallyB < 0 {
        return flow
    }

    // capture what try/catch left pending, then run finally with a clean slate
    let hadThrow = st.throwing
    var savedThrow = cloneValue(st.thrownValue)
    var hadRet = false
    var savedRet = JSValue.Undefined
    match flow {
        Flow.Ret(v) => {
            hadRet = true
            savedRet = cloneValue(v)
        }
        _ => {
        }
    }
    st.throwing = false
    st.thrownValue = JSValue.Undefined
    // stash the captured values on the temp-root stack so finally's allocations
    // can't collect them, then recover them afterward (Vec.pop returns the value)
    pushTemp(st, savedThrow)
    pushTemp(st, savedRet)
    let finScope = newScope(st, scope)
    pushActive(st, finScope)
    let finFlow = execBlock(prog, finallyB, st, finScope)
    popActive(st)
    savedRet = st.tempRoots.pop()!
    savedThrow = st.tempRoots.pop()!

    match finFlow {
        Flow.Ret(fv) => {
            return Flow.Ret(fv)
        }
        _ => {
        }
    }
    if st.throwing {
        return Flow.Normal
    }
    if hadThrow {
        st.throwing = true
        st.thrownValue = savedThrow
        return Flow.Normal
    }
    if hadRet {
        return Flow.Ret(savedRet)
    }
    return Flow.Normal
}

fn execStmt(prog: &Prog, idx: i64, st: &mut Interp, scope: i64): Flow {
    if st.throwing {
        return Flow.Normal
    }
    // Take any label handed down by an enclosing Stmt.Labeled and clear it, so
    // it reaches only the statement being executed now (a loop reads myLabel; a
    // block or if drops it). Cleared globally here, re-set only by Labeled just
    // before it recurses, so it cannot leak into a nested loop.
    let myLabel = st.pendingLabel.clone()
    st.pendingLabel = ""
    match prog.stmts[idx] {
        Stmt.Decl(name, e) => {
            let v = evalExpr(prog, e, st, scope)
            scopeDefine(st, scope, name.clone(), v)
            return Flow.Normal
        }
        Stmt.DoWhile(body, cond) => {
            var looping = true
            while looping {
                let flow = execStmt(prog, body, st, scope)
                match flow {
                    Flow.Ret(v) => {
                        return Flow.Ret(v)
                    }
                    Flow.Break(l) => {
                        if l == "" || l == myLabel {
                            looping = false
                        } else {
                            return Flow.Break(l.clone())
                        }
                    }
                    Flow.Continue(l) => {
                        if l != "" && l != myLabel {
                            return Flow.Continue(l.clone())
                        }
                    }
                    Flow.Normal => {
                    }
                }
                if looping {
                    if st.throwing || !truthy(evalExpr(prog, cond, st, scope)) {
                        looping = false
                    }
                }
            }
            return Flow.Normal
        }
        Stmt.Switch(discrIdx, casesIdx) => {
            let dv = evalExpr(prog, discrIdx, st, scope)
            pushTemp(st, cloneValue(dv))
            let n = prog.switches[casesIdx].len()
            // pick the arm, then run every arm from there on: fallthrough is the
            // default in JS and only break stops it
            var start = -1
            var defaultAt = -1
            var i: i64 = 0
            while i < n && start < 0 {
                let test = prog.switches[casesIdx][i].test
                if test < 0 {
                    if defaultAt < 0 {
                        defaultAt = i
                    }
                } else {
                    let tv = evalExpr(prog, test, st, scope)
                    if jsStrictEquals(dv, tv) {
                        start = i
                    }
                }
                i = i + 1
            }
            if start < 0 {
                start = defaultAt
            }
            var result = Flow.Normal
            if start >= 0 {
                let switchScope = newScope(st, scope)
                pushActive(st, switchScope)
                var c = start
                var going = true
                while going && c < n {
                    let flow = execBlock(prog, prog.switches[casesIdx][c].body, st, switchScope)
                    match flow {
                        Flow.Ret(v) => {
                            result = Flow.Ret(v)
                            going = false
                        }
                        Flow.Break(l) => {
                            // an unlabeled break ends the switch; a labeled one
                            // targets an enclosing statement, so let it out
                            going = false
                            if l != "" {
                                result = Flow.Break(l.clone())
                            }
                        }
                        Flow.Continue(l) => {
                            // a continue always belongs to an enclosing loop
                            result = Flow.Continue(l.clone())
                            going = false
                        }
                        Flow.Normal => {
                        }
                    }
                    if st.throwing {
                        going = false
                    }
                    c = c + 1
                }
                popActive(st)
            }
            popTemp(st)
            return result
        }
        Stmt.ClassDecl(classIdx) => {
            let v = instantiateClass(prog, classIdx, st, scope)
            scopeDefine(st, scope, prog.classes[classIdx].name.clone(), v)
            return Flow.Normal
        }
        Stmt.ForOf(name, objExpr, body) => {
            let ov = evalExpr(prog, objExpr, st, scope)
            // the snapshot's element handles are only kept alive by the source
            // object, so it must stay rooted for the whole loop. `holder` keeps
            // alive any values synthesised during iteration (Map pairs), which
            // the source does not reference.
            pushTemp(st, cloneValue(ov))
            let holder = newArray(st)
            pushTemp(st, JSValue.Obj(holder))

            // A user object carrying [Symbol.iterator] drives the real protocol:
            // next() is called lazily, one step per iteration, so an iterator with
            // side effects (or one the body mutates) observes the same order it
            // would in JS. Built-in types below keep their eager snapshot.
            let srcH = objHandle(ov)
            // A generator is its own iterator but its `next` is a native method,
            // not a stored property, so it drives through genNext rather than the
            // getMember(next)+callValue path a user iterator uses.
            let isGen = srcH >= 0 && st.objects[srcH].isGenerator
            var driveIter = isGen
            var iterVal = cloneValue(ov)
            if srcH >= 0 && !isGen && !st.objects[srcH].isArray && !st.objects[srcH].isMap && !st.objects[srcH].isSet {
                let itFn = getMember(st, srcH, symIteratorKey())
                if isCallableIn(st, itFn) {
                    var noArgs: Vec<JSValue> = Vec.new()
                    iterVal = callValue(prog, itFn, noArgs, cloneValue(ov), st)
                    driveIter = true
                }
            }
            if driveIter {
                let iter = cloneValue(iterVal)
                pushTemp(st, cloneValue(iter))
                let iterH = objHandle(iter)
                let loopScope2 = newScope(st, scope)
                pushActive(st, loopScope2)
                var running = true
                var out = Flow.Normal
                while running && !st.throwing && iterH >= 0 {
                    var step = JSValue.Undefined
                    if isGen {
                        var nArgs: Vec<JSValue> = Vec.new()
                        step = genNext(iterH, nArgs, st)
                    } else {
                        let nextFn = getMember(st, iterH, "next")
                        if !isCallableIn(st, nextFn) {
                            st.throwing = true
                            st.thrownValue = makeError(st, "TypeError", "iterator has no next method" + currentModule(st))
                            running = false
                        } else {
                            var nArgs: Vec<JSValue> = Vec.new()
                            step = callValue(prog, nextFn, nArgs, cloneValue(iter), st)
                        }
                    }
                    if running && !st.throwing {
                        let stepH = objHandle(step)
                        if stepH < 0 || st.throwing {
                            running = false
                        } else if truthy(getMember(st, stepH, "done")) {
                            running = false
                        } else {
                            pushTemp(st, cloneValue(step))
                            // fresh per-iteration binding so body closures don't
                            // all capture the final value (for-of over let/const)
                            let iterScope = newScope(st, loopScope2)
                            pushActive(st, iterScope)
                            scopeDefine(st, iterScope, name.clone(), getMember(st, stepH, "value"))
                            let flow = execStmt(prog, body, st, iterScope)
                            popActive(st)
                            popTemp(st)
                            match flow {
                                Flow.Ret(v) => {
                                    out = Flow.Ret(v)
                                    running = false
                                }
                                Flow.Break(l) => {
                                    // an unmatched label re-propagates through
                                    // out so the loop's cleanup below still runs
                                    running = false
                                    if l != "" && l != myLabel {
                                        out = Flow.Break(l.clone())
                                    }
                                }
                                Flow.Continue(l) => {
                                    if l != "" && l != myLabel {
                                        out = Flow.Continue(l.clone())
                                        running = false
                                    }
                                }
                                Flow.Normal => {
                                }
                            }
                        }
                    }
                }
                popActive(st)
                popTemp(st)
                popTemp(st)
                popTemp(st)
                return out
            }

            var vals: Vec<JSValue> = Vec.new()
            var iterable = false
            match ov {
                JSValue.Obj(o) => {
                    if st.objects[o].isArray {
                        iterable = true
                        var e: i64 = 0
                        let ne = arrLen(st, o)
                        while e < ne {
                            vals.push(arrGet(st, o, e))
                            e = e + 1
                        }
                    } else if st.objExtras[st.objects[o].extra].taBuf >= 0 && !st.objects[o].isDataView {
                        // typed array: iterate by element
                        iterable = true
                        var e: i64 = 0
                        while e < st.objExtras[st.objects[o].extra].taLen {
                            vals.push(JSValue.Number(taElem(st, o, e)))
                            e = e + 1
                        }
                    } else if st.objects[o].isMap || st.objects[o].isSet {
                        // a Map yields freshly built [key, value] pairs; a Set
                        // yields its values. The pairs exist only in `vals`,
                        // which the collector cannot see, so they are also held
                        // in a rooted holder array for the life of the loop.
                        iterable = true
                        let isSet = st.objects[o].isSet
                        var e: i64 = 0
                        while e < st.objExtras[st.objects[o].extra].mapKeys.len() {
                            if isSet {
                                vals.push(cloneValue(st.objExtras[st.objects[o].extra].mapKeys[e]))
                            } else {
                                let pair = newArray(st)
                                pushTemp(st, JSValue.Obj(pair))
                                arrPush(st, pair, cloneValue(st.objExtras[st.objects[o].extra].mapKeys[e]))
                                arrPush(st, pair, cloneValue(st.objExtras[st.objects[o].extra].mapVals[e]))
                                popTemp(st)
                                arrPush(st, holder, JSValue.Obj(pair))
                                vals.push(JSValue.Obj(pair))
                            }
                            e = e + 1
                        }
                    }
                }
                JSValue.Str(s) => {
                    iterable = true
                    // iterate Unicode code points, not bytes (é/😀 must stay whole)
                    for cp in strCodePoints(s) {
                        vals.push(JSValue.Str(cp.clone()))
                    }
                }
                _ => {
                }
            }
            if !iterable {
                popTemp(st)
                popTemp(st)
                st.throwing = true
                st.thrownValue = JSValue.Str("TypeError: value is not iterable")
                return Flow.Normal
            }
            let loopScope = newScope(st, scope)
            pushActive(st, loopScope)
            var i: i64 = 0
            var looping = true
            while looping && i < vals.len() {
                // each iteration gets its own binding (for-of over let/const), so a
                // closure made in the body captures that iteration's value, not the
                // last — the isbot `for (let key of ...) getters[key]=...` idiom
                let iterScope = newScope(st, loopScope)
                pushActive(st, iterScope)
                scopeDefine(st, iterScope, name.clone(), cloneValue(vals[i]))
                let flow = execStmt(prog, body, st, iterScope)
                popActive(st)
                match flow {
                    Flow.Ret(v) => {
                        popActive(st)
                        popTemp(st)
                        popTemp(st)
                        return Flow.Ret(v)
                    }
                    Flow.Break(l) => {
                        looping = false
                        if l != "" && l != myLabel {
                            popActive(st)
                            popTemp(st)
                            popTemp(st)
                            return Flow.Break(l.clone())
                        }
                    }
                    Flow.Continue(l) => {
                        if l != "" && l != myLabel {
                            popActive(st)
                            popTemp(st)
                            popTemp(st)
                            return Flow.Continue(l.clone())
                        }
                    }
                    Flow.Normal => {
                    }
                }
                if st.throwing {
                    looping = false
                }
                i = i + 1
            }
            popActive(st)
            popTemp(st)
            popTemp(st)
            return Flow.Normal
        }
        Stmt.ForIn(name, objExpr, body) => {
            let ov = evalExpr(prog, objExpr, st, scope)
            var keys: Vec<string> = Vec.new()
            match ov {
                JSValue.Obj(o) => {
                    if st.objects[o].isProxy {
                        keys = proxyOwnEnumKeys(prog, st, o)
                    }
                    if st.objects[o].isArray {
                        var e: i64 = 0
                        let ne = arrLen(st, o)
                        while e < ne {
                            if !arrIsHole(st, o, e) {
                                keys.push(i64ToStr(e))
                            }
                            e = e + 1
                        }
                    }
                    // own properties, then inherited ones (JS enumerates the chain)
                    var cur = o
                    while cur >= 0 {
                        let order = enumOrder(st, cur)
                        var oi: i64 = 0
                        while oi < order.len() {
                            let k = order[oi]
                            if st.objects[cur].props[k].enumerable {
                                keys.push(st.objects[cur].props[k].key.clone())
                            }
                            oi = oi + 1
                        }
                        cur = st.objects[cur].proto
                    }
                }
                _ => {
                }
            }
            let loopScope = newScope(st, scope)
            pushActive(st, loopScope)
            var i: i64 = 0
            var looping = true
            while looping && i < keys.len() {
                // fresh per-iteration binding (for-in over let/const) so a closure
                // in the body captures this key, not the last one enumerated
                let iterScope = newScope(st, loopScope)
                pushActive(st, iterScope)
                scopeDefine(st, iterScope, name.clone(), JSValue.Str(keys[i].clone()))
                let flow = execStmt(prog, body, st, iterScope)
                popActive(st)
                match flow {
                    Flow.Ret(v) => {
                        popActive(st)
                        return Flow.Ret(v)
                    }
                    Flow.Break(l) => {
                        looping = false
                        if l != "" && l != myLabel {
                            popActive(st)
                            return Flow.Break(l.clone())
                        }
                    }
                    Flow.Continue(l) => {
                        if l != "" && l != myLabel {
                            popActive(st)
                            return Flow.Continue(l.clone())
                        }
                    }
                    Flow.Normal => {
                    }
                }
                if st.throwing {
                    looping = false
                }
                i = i + 1
            }
            popActive(st)
            return Flow.Normal
        }
        Stmt.MultiDecl(listIdx) => {
            var i: i64 = 0
            let n = prog.declLists[listIdx].len()
            while i < n {
                let name = prog.declLists[listIdx][i].name.clone()
                let initIdx = prog.declLists[listIdx][i].init
                let v = evalExpr(prog, initIdx, st, scope)
                if prog.declLists[listIdx][i].isVar {
                    // `var` was already bound in the function scope by hoisting;
                    // assign there rather than shadowing it in this block
                    scopeAssign(st, scope, name, v)
                } else {
                    scopeDefine(st, scope, name, v)
                }
                i = i + 1
            }
            return Flow.Normal
        }
        Stmt.ExprStmt(e) => {
            evalExpr(prog, e, st, scope)
            return Flow.Normal
        }
        Stmt.If(c, t, f) => {
            let vc = evalExpr(prog, c, st, scope)
            if truthy(vc) {
                return execStmt(prog, t, st, scope)
            }
            if f >= 0 {
                return execStmt(prog, f, st, scope)
            }
            return Flow.Normal
        }
        Stmt.While(c, body) => {
            var looping = true
            while looping {
                let vc = evalExpr(prog, c, st, scope)
                if st.throwing || !truthy(vc) {
                    looping = false
                } else {
                    let flow = execStmt(prog, body, st, scope)
                    match flow {
                        Flow.Ret(v) => {
                            return Flow.Ret(v)
                        }
                        Flow.Break(l) => {
                            looping = false
                            if l != "" && l != myLabel {
                                return Flow.Break(l.clone())
                            }
                        }
                        Flow.Continue(l) => {
                            if l != "" && l != myLabel {
                                return Flow.Continue(l.clone())
                            }
                        }
                        Flow.Normal => {
                        }
                    }
                    if st.throwing {
                        looping = false
                    }
                }
            }
            return Flow.Normal
        }
        Stmt.For(init, cond, update, body) => {
            // the loop gets its own scope so `let`/`var` in the init clause don't
            // leak, and closures made per-iteration capture it
            let loopScope = newScope(st, scope)
            pushActive(st, loopScope)
            var letNames: Vec<string> = Vec.new()
            if init >= 0 {
                execStmt(prog, init, st, loopScope)
                // names the init clause declared with let/const need re-binding
                // per iteration
                match prog.stmts[init] {
                    Stmt.MultiDecl(listIdx) => {
                        var di: i64 = 0
                        while di < prog.declLists[listIdx].len() {
                            if !prog.declLists[listIdx][di].isVar {
                                letNames.push(prog.declLists[listIdx][di].name.clone())
                            }
                            di = di + 1
                        }
                    }
                    _ => {
                    }
                }
            }
            var looping = true
            while looping {
                if st.throwing {
                    looping = false
                } else {
                    var run = true
                    if cond >= 0 {
                        let vc = evalExpr(prog, cond, st, loopScope)
                        run = truthy(vc)
                    }
                    if !run || st.throwing {
                        looping = false
                    } else {
                        // `for (let i ...)` gives each iteration its own binding,
                        // so a closure made in the body captures that iteration's
                        // value rather than the final one
                        var bodyScope = loopScope
                        if letNames.len() > 0 {
                            bodyScope = newScope(st, loopScope)
                            pushActive(st, bodyScope)
                            var li: i64 = 0
                            while li < letNames.len() {
                                scopeDefine(st, bodyScope, letNames[li].clone(), scopeLookup(st, loopScope, letNames[li]))
                                li = li + 1
                            }
                        }
                        let flow = execStmt(prog, body, st, bodyScope)
                        if letNames.len() > 0 {
                            // copy back so the update clause sees the body's writes
                            var lo: i64 = 0
                            while lo < letNames.len() {
                                scopeAssign(st, loopScope, letNames[lo].clone(), scopeLookup(st, bodyScope, letNames[lo]))
                                lo = lo + 1
                            }
                            popActive(st)
                        }
                        var broke = false
                        match flow {
                            Flow.Ret(v) => {
                                popActive(st)
                                return Flow.Ret(v)
                            }
                            Flow.Break(l) => {
                                broke = true
                                if l != "" && l != myLabel {
                                    popActive(st)
                                    return Flow.Break(l.clone())
                                }
                            }
                            Flow.Continue(l) => {
                                if l != "" && l != myLabel {
                                    popActive(st)
                                    return Flow.Continue(l.clone())
                                }
                            }
                            Flow.Normal => {
                            }
                        }
                        if broke {
                            looping = false
                        } else if st.throwing {
                            looping = false
                        } else if update >= 0 {
                            evalExpr(prog, update, st, loopScope)
                        }
                    }
                }
            }
            popActive(st)
            return Flow.Normal
        }
        Stmt.Throw(e) => {
            let v = evalExpr(prog, e, st, scope)
            if !st.throwing {
                st.throwing = true
                st.thrownValue = v
            }
            return Flow.Normal
        }
        Stmt.Try(tryB, param, catchB, finallyB) => {
            return execTry(prog, tryB, param, catchB, finallyB, st, scope)
        }
        Stmt.Ret(e) => {
            let v = evalExpr(prog, e, st, scope)
            return Flow.Ret(v)
        }
        Stmt.Block(b) => {
            let child = newScope(st, scope)
            pushActive(st, child)
            let flow = execBlock(prog, b, st, child)
            popActive(st)
            return flow
        }
        Stmt.FuncDecl(f) => {
            let name = prog.funcs[f].name.clone()
            scopeDefine(st, scope, name, JSValue.Func(f, scope))
            return Flow.Normal
        }
        Stmt.Empty => {
            return Flow.Normal
        }
        Stmt.Break(label) => {
            return Flow.Break(label.clone())
        }
        Stmt.Continue(label) => {
            return Flow.Continue(label.clone())
        }
        Stmt.Labeled(label, body) => {
            // Hand the label to the wrapped statement (a loop reads it), then run
            // it. A loop consumes a break/continue naming this label and returns
            // Normal. A labeled non-loop (e.g. `foo: { ... break foo }`) does not,
            // so catch a matching break here — that is what makes break out of a
            // labeled block work.
            st.pendingLabel = label.clone()
            let f = execStmt(prog, body, st, scope)
            match f {
                Flow.Break(l) => {
                    if l == label {
                        return Flow.Normal
                    }
                    return Flow.Break(l.clone())
                }
                _ => {
                    return f
                }
            }
        }
    }
}

// Bind `var` declarations and function declarations for a whole function body
// before it runs. JS hoists both to the function scope through arbitrary
// nesting, so this walks into blocks, loops, if/else, switch and try — unlike
// let/const, which stay in the block they are written in.
fn hoistBlock(prog: &Prog, blockIdx: i64, st: &mut Interp, scope: i64) {
    var i: i64 = 0
    let n = prog.blocks[blockIdx].len()
    while i < n {
        hoistStmt(prog, prog.blocks[blockIdx][i], st, scope)
        i = i + 1
    }
}

fn hoistStmt(prog: &Prog, idx: i64, st: &mut Interp, scope: i64) {
    if idx < 0 {
        return
    }
    match prog.stmts[idx] {
        Stmt.FuncDecl(fIdx) => {
            let fname = prog.funcs[fIdx].name.clone()
            if fname.len() > 0 {
                scopeDefine(st, scope, fname, JSValue.Func(fIdx, scope))
            }
        }
        Stmt.MultiDecl(listIdx) => {
            var d: i64 = 0
            while d < prog.declLists[listIdx].len() {
                if prog.declLists[listIdx][d].isVar {
                    let dname = prog.declLists[listIdx][d].name.clone()
                    if dname.len() > 0 && !scopeHasOwn(st, scope, dname) {
                        scopeDefine(st, scope, dname, JSValue.Undefined)
                    }
                }
                d = d + 1
            }
        }
        Stmt.Block(b) => {
            hoistBlock(prog, b, st, scope)
        }
        Stmt.If(_c, thenS, elseS) => {
            hoistStmt(prog, thenS, st, scope)
            hoistStmt(prog, elseS, st, scope)
        }
        Stmt.While(_c, body) => {
            hoistStmt(prog, body, st, scope)
        }
        Stmt.DoWhile(body, _c) => {
            hoistStmt(prog, body, st, scope)
        }
        Stmt.For(init, _c, _u, body) => {
            hoistStmt(prog, init, st, scope)
            hoistStmt(prog, body, st, scope)
        }
        Stmt.ForIn(_nm, _o, body) => {
            hoistStmt(prog, body, st, scope)
        }
        Stmt.ForOf(_nm, _o, body) => {
            hoistStmt(prog, body, st, scope)
        }
        Stmt.Try(tryB, _p, catchB, finallyB) => {
            hoistBlock(prog, tryB, st, scope)
            if catchB >= 0 {
                hoistBlock(prog, catchB, st, scope)
            }
            if finallyB >= 0 {
                hoistBlock(prog, finallyB, st, scope)
            }
        }
        Stmt.Switch(_d, casesIdx) => {
            var c: i64 = 0
            while c < prog.switches[casesIdx].len() {
                hoistBlock(prog, prog.switches[casesIdx][c].body, st, scope)
                c = c + 1
            }
        }
        _ => {
        }
    }
}

fn execBlock(prog: &Prog, blockIdx: i64, st: &mut Interp, scope: i64): Flow {
    let n = prog.blocks[blockIdx].len()
    var j: i64 = 0
    while j < n {
        // statement boundary = the only GC safepoint (no closure in-flight, all
        // live values rooted in scopes)
        maybeGc(st)
        let sIdx = prog.blocks[blockIdx][j]
        let flow = execStmt(prog, sIdx, st, scope)
        match flow {
            Flow.Ret(v) => {
                return Flow.Ret(v)
            }
            Flow.Break(l) => {
                return Flow.Break(l.clone())
            }
            Flow.Continue(l) => {
                return Flow.Continue(l.clone())
            }
            Flow.Normal => {
            }
        }
        // an exception raised in this statement unwinds out of the block
        if st.throwing {
            return Flow.Normal
        }
        j = j + 1
    }
    return Flow.Normal
}
