            if proto >= 0 {
                st.objects[o].proto = proto
            }
        }
        // second argument: property descriptors, same shape as
        // Object.defineProperties. express builds app.request/app.response with
        // this to hang `app` off the prototype, so ignoring it left req.app and
        // res.app undefined.
        if argVals.len() > 1 {
            let descs = objHandle(argVals[1])
            if descs >= 0 {
                pushTemp(st, JSValue.Obj(o))
                var di: i64 = 0
                while di < st.objects[descs].props.len() {
                    let key = st.objects[descs].props[di].key.clone()
                    let dh = objHandle(cloneValue(st.objects[descs].props[di].value))
                    if dh >= 0 {
                        applyDescriptor(st, o, key, dh)
                    }
                    di = di + 1
                }
                popTemp(st)
            }
        }
        return JSValue.Obj(o)
    }
    if id == NATIVE_OBJECT_GETPROTO {
        if argVals.len() > 0 {
            let h = propertyBagOf(st, argVals[0])
            let p = protoOfHandle(st, h)
            if p >= 0 {
                return JSValue.Obj(p)
            }
        }
        return JSValue.Null
    }
    if id == NATIVE_OBJECT_SETPROTO {
        if argVals.len() > 1 {
            // express's Router is a function whose prototype chain is set to the
            // router proto object, so the bag a function's properties live in is
            // what has to inherit
            let h = propertyBagOf(st, argVals[0])
            if h >= 0 {
                let p = propertyBagOf(st, argVals[1])
                st.objects[h].proto = p
            }
        }
        if argVals.len() > 0 {
            return cloneValue(argVals[0])
        }
        return JSValue.Undefined
    }
    if id == NATIVE_OBJECT_GETOWNPROPDESC {
        if argVals.len() < 2 {
            return JSValue.Undefined
        }
        let h = propertyBagOf(st, argVals[0])
        if h < 0 {
            return JSValue.Undefined
        }
        let key = toStr(argVals[1])
        let idx = objOwnIndex(st, h, key)
        if idx < 0 {
            return JSValue.Undefined
        }
        return JSValue.Obj(buildPropDescriptor(st, h, idx))
    }
    if id == NATIVE_OBJECT_GETOWNPROPDESCS {
        let out = newObject(st)
        if argVals.len() > 0 {
            let h = propertyBagOf(st, argVals[0])
            if h >= 0 {
                pushTemp(st, JSValue.Obj(out))
                var pi: i64 = 0
                while pi < st.objects[h].props.len() {
                    let k = st.objects[h].props[pi].key.clone()
                    let d = buildPropDescriptor(st, h, pi)
                    // root d across objSet, which may grow `out` and collect
                    pushTemp(st, JSValue.Obj(d))
                    objSet(st, out, k, JSValue.Obj(d))
                    popTemp(st)
                    pi = pi + 1
                }
                popTemp(st)
            }
        }
        return JSValue.Obj(out)
    }
    if id == NATIVE_OBJECT_FREEZE {
        if argVals.len() > 0 {
            let fh = objHandle(argVals[0])
            if fh >= 0 {
                st.objects[fh].frozen = true
            }
            return cloneValue(argVals[0])
        }
        return JSValue.Undefined
    }
    if id == NATIVE_ARRAYBUFFER {
        var n: i64 = 0
        if argVals.len() > 0 {
            n = toNum(argVals[0]) as i64
        }
        if n < 0 {
            n = 0
        }
        let bo = newObject(st)
        st.objects[bo].isArrayBuffer = true
        let _e = ensureExtra(st, bo)
        // new ArrayBuffer(n, { maxByteLength }) — resizable up to the cap
        if argVals.len() > 1 {
            let oh = objHandle(argVals[1])
            if oh >= 0 {
                let cap = getMember(st, oh, "maxByteLength")
                match cap {
                    JSValue.Undefined => {
                    }
                    _ => {
                        var c = toNum(cap) as i64
                        if c < n {
                            c = n
                        }
                        st.objExtras[st.objects[bo].extra].abMaxLen = c
                    }
                }
            }
        }
        var b: Vec<u8> = Vec.new()
        var i: i64 = 0
        while i < n {
            b.push(0 as u8)
            i = i + 1
        }
        st.objExtras[st.objects[bo].extra].bytes = b
        return JSValue.Obj(bo)
    }
    if id >= NATIVE_TA_BASE && id <= NATIVE_TA_BASE + TA_U8C {
        let kind = id - NATIVE_TA_BASE
        // Float32/Float64 now store real IEEE-754 bytes via taStore's f32/f64
        // reinterpret (runtime.milo), so every kind is constructible.
        return makeTypedArray(st, kind, argVals)
    }
    if id == NATIVE_DATAVIEW {
        // new DataView(buffer, byteOffset = 0, byteLength = buffer.byteLength - offset)
        var bufH: i64 = -1
        if argVals.len() > 0 {
            bufH = objHandle(argVals[0])
        }
        if bufH < 0 || !st.objects[bufH].isArrayBuffer {
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", "First argument to DataView constructor must be an ArrayBuffer")
            return JSValue.Undefined
        }
        let bufLen = st.objExtras[st.objects[bufH].extra].bytes.len()
        var off: i64 = 0
        if argVals.len() > 1 {
            off = toNum(argVals[1]) as i64
        }
        var byteLen = bufLen - off
        if argVals.len() > 2 {
            byteLen = toNum(argVals[2]) as i64
        }
        if off < 0 || byteLen < 0 || off + byteLen > bufLen {
            st.throwing = true
            st.thrownValue = makeError(st, "RangeError", "Invalid DataView length")
            return JSValue.Undefined
        }
        let dv = newObject(st)
        st.objects[dv].isDataView = true
        let _e = ensureExtra(st, dv)
        st.objExtras[st.objects[dv].extra].taBuf = bufH
        st.objExtras[st.objects[dv].extra].taOffset = off
        st.objExtras[st.objects[dv].extra].taLen = byteLen
        return JSValue.Obj(dv)
    }
    if id == NATIVE_OBJECT_PREVENTEXT || id == NATIVE_OBJECT_SEAL {
        if argVals.len() > 0 {
            let h = objHandle(argVals[0])
            if h >= 0 {
                st.objects[h].noExtend = true
                if id == NATIVE_OBJECT_SEAL {
                    st.objects[h].sealed = true
                }
            }
            return cloneValue(argVals[0])
        }
        return JSValue.Undefined
    }
    if id == NATIVE_OBJECT_ISEXT {
        if argVals.len() > 0 {
            let h = objHandle(argVals[0])
            if h >= 0 {
                return JSValue.Bool(!st.objects[h].noExtend && !st.objects[h].frozen)
            }
        }
        // primitives are never extensible
        return JSValue.Bool(false)
    }
    if id == NATIVE_PROXY {
        if argVals.len() < 2 {
            return throwTypeErr(st, "Cannot create proxy with a non-object as target or handler")
        }
        let t = cloneValue(argVals[0])
        let h = cloneValue(argVals[1])
        // a function target is legal and common — `new Proxy(fn, {apply})`
        if (objHandle(t) < 0 && !isCallable(t)) || objHandle(h) < 0 {
            return throwTypeErr(st, "Cannot create proxy with a non-object as target or handler")
        }
        let o = newObject(st)
        st.objects[o].isProxy = true
        let ex = ensureExtra(st, o)
        st.objExtras[ex].proxyTarget = t
        st.objExtras[ex].proxyHandler = h
        // a proxy over a callable must itself report as callable
        if isCallableIn(st, st.objExtras[ex].proxyTarget) {
            st.objects[o].isFunctionLike = true
        }
        return JSValue.Obj(o)
    }
    if id == NATIVE_CONSOLE_LOG {
        var line = ""
        var j: i64 = 0
        while j < argVals.len() {
            if j > 0 {
                line = line + " "
            }
            line = line + inspectTop(st, argVals[j])
            j = j + 1
        }
        print(line)
        flush()
        return JSValue.Undefined
    }
    if id == NATIVE_NAPI_LOAD {
        if argVals.len() == 0 {
            return JSValue.Undefined
        }
        match napiLoadAddon(toStr(argVals[0])) {
            Result.Ok(v) => {
                return v
            }
            Result.Err(e) => {
                let eo = newObject(st)
                st.objects[eo].isError = true
                objSet(st, eo, "name", JSValue.Str("Error"))
                objSet(st, eo, "message", JSValue.Str(e))
                st.throwing = true
                st.thrownValue = JSValue.Obj(eo)
                return JSValue.Undefined
            }
        }
    }
    if id == NATIVE_BYTE_LENGTH {
        if argVals.len() == 0 {
            return JSValue.Number(0.0)
        }
        return JSValue.Number(toStr(argVals[0]).len() as f64)
    }
    if id == NATIVE_OBJECT_IS {
        if argVals.len() < 2 {
            return JSValue.Bool(argVals.len() == 0 || isUndefinedValue(argVals[0]))
        }
        return JSValue.Bool(sameValue(argVals[0], argVals[1]))
    }
    if id == NATIVE_OBJECT_HASOWN {
        if argVals.len() < 2 {
            return JSValue.Bool(false)
        }
        let o = objHandle(argVals[0])
        if o < 0 {
            return JSValue.Bool(false)
        }
        let key = toStr(argVals[1])
        // mirrors hasOwnProperty: own named prop, or a real (non-hole) array index
        return JSValue.Bool(objOwnIndex(st, o, key) >= 0 || (st.objects[o].isArray && asArrayIndex(key) >= 0 && asArrayIndex(key) < arrLen(st, o) && !arrIsHole(st, o, asArrayIndex(key))))
    }
    if id == NATIVE_OBJECT_ISSEALED {
        if argVals.len() > 0 {
            let h = objHandle(argVals[0])
            if h >= 0 {
                return JSValue.Bool(st.objects[h].sealed || st.objects[h].frozen)
            }
        }
        return JSValue.Bool(true)
    }
    if id == NATIVE_OBJECT_ISFROZEN {
        if argVals.len() > 0 {
            let fh = objHandle(argVals[0])
            if fh >= 0 {
                return JSValue.Bool(st.objects[fh].frozen)
            }
            // primitives are frozen by definition
            return JSValue.Bool(true)
        }
        return JSValue.Bool(true)
    }
    if id == NATIVE_OBJECT_VALUES || id == NATIVE_OBJECT_ENTRIES {
        let wantPairs = id == NATIVE_OBJECT_ENTRIES
        let arr = newArray(st)
        if argVals.len() > 0 {
            pushTemp(st, JSValue.Obj(arr))
            // a string enumerates as its characters, keyed by index
            match cloneValue(argVals[0]) {
                JSValue.Str(sv) => {
                    if !isSymbolStr(sv) {
                        var si: i64 = 0
                        let slen = utf16Length(sv)
                        while si < slen {
                            let ch = JSValue.Str(strSlice(sv, si, si + 1))
                            if wantPairs {
                                let spair = newArray(st)
                                pushTemp(st, JSValue.Obj(spair))
                                arrPush(st, spair, JSValue.Str(i64ToStr(si)))
                                arrPush(st, spair, ch)
                                popTemp(st)
                                arrPush(st, arr, JSValue.Obj(spair))
                            } else {
                                arrPush(st, arr, ch)
                            }
                            si = si + 1
                        }
                    }
                }
                _ => {
                }
            }
            match cloneValue(argVals[0]) {
                JSValue.Obj(o) => {
                    if st.objects[o].isArray {
                        var i: i64 = 0
                        let n = arrLen(st, o)
                        while i < n {
                            let v = arrGet(st, o, i)
                            if wantPairs {
                                let pair = newArray(st)
                                pushTemp(st, JSValue.Obj(pair))
                                arrPush(st, pair, JSValue.Str(i64ToStr(i)))
                                arrPush(st, pair, v)
                                popTemp(st)
                                arrPush(st, arr, JSValue.Obj(pair))
                            } else {
                                arrPush(st, arr, v)
                            }
                            i = i + 1
                        }
                    }
                    let order = enumOrder(st, o)
                    var oi: i64 = 0
                    while oi < order.len() {
                        let k = order[oi]
                        oi = oi + 1
                        if !st.objects[o].props[k].enumerable {
                            continue
                        }
                        let key = st.objects[o].props[k].key.clone()
                        let v = cloneValue(st.objects[o].props[k].value)
                        if wantPairs {
                            let pair = newArray(st)
                            pushTemp(st, JSValue.Obj(pair))
                            arrPush(st, pair, JSValue.Str(key))
                            arrPush(st, pair, v)
                            popTemp(st)
                            arrPush(st, arr, JSValue.Obj(pair))
                        } else {
                            arrPush(st, arr, v)
                        }
                    }
                }
                _ => {
                }
            }
            popTemp(st)
        }
        return JSValue.Obj(arr)
    }
    if id == NATIVE_OBJECT_KEYS {
        let arr = newArray(st)
        if argVals.len() > 0 {
            pushTemp(st, JSValue.Obj(arr))
            // A string exposes its character indices; any other primitive has no
            // own keys. Neither has a property bag, and indexing the heap with
            // the -1 that stands for "none" crashed the engine outright.
            match cloneValue(argVals[0]) {
                JSValue.Str(sv) => {
                    if !isSymbolStr(sv) {
                        var si: i64 = 0
                        let slen = utf16Length(sv)
                        while si < slen {
                            arrPush(st, arr, JSValue.Str(i64ToStr(si)))
                            si = si + 1
                        }
                    }
                }
                _ => {
                }
            }
            let keysBag = propertyBagOf(st, argVals[0])
            match JSValue.Obj(keysBag) {
                JSValue.Obj(o) => {
                    if keysBag < 0 {
                        popTemp(st)
                        return JSValue.Obj(arr)
                    }
                    if st.objects[o].isProxy {
                        // ownKeys/getOwnPropertyDescriptor traps decide, not
                        // the proxy object's (empty) own bag
                        let pk = proxyOwnEnumKeys(gProg, st, o)
                        var i: i64 = 0
                        while i < pk.len() {
                            arrPush(st, arr, JSValue.Str(pk[i].clone()))
                            i = i + 1
                        }
                        popTemp(st)
                        return JSValue.Obj(arr)
                    }
                    if st.objects[o].isArray {
                        var i: i64 = 0
                        let n = arrLen(st, o)
                        while i < n {
                            if !arrIsHole(st, o, i) {
                                arrPush(st, arr, JSValue.Str(i64ToStr(i)))
                            }
                            i = i + 1
                        }
                    }
                    let order = enumOrder(st, o)
                    var oi: i64 = 0
                    while oi < order.len() {
                        let k = order[oi]
                        if st.objects[o].props[k].enumerable {
                            arrPush(st, arr, JSValue.Str(st.objects[o].props[k].key.clone()))
                        }
                        oi = oi + 1
                    }
                }
                _ => {
                }
            }
            popTemp(st)
        }
        return JSValue.Obj(arr)
    }
    if id == NATIVE_OBJECT_ASSIGN {
        if argVals.len() == 0 {
            return JSValue.Undefined
        }
        let target = cloneValue(argVals[0])
        let t = propertyBagOf(st, target)
        if t < 0 {
            return target
        }
        var s: i64 = 1
        while s < argVals.len() {
            let srcVal = cloneValue(argVals[s])
            let src = propertyBagOf(st, srcVal)
            if src >= 0 {
                let order = enumOrder(st, src)
                var oi: i64 = 0
                while oi < order.len() {
                    let k = order[oi]
                    oi = oi + 1
                    if st.objects[src].props[k].enumerable {
                        let key = st.objects[src].props[k].key.clone()
                        // invoke a getter rather than copying its unused value slot
                        // (gProg: natives reach user code through the global program)
                        var v = JSValue.Undefined
                        if st.objects[src].props[k].isAccessor {
                            v = getMemberDyn(gProg, src, key, st)
                        } else {
                            v = cloneValue(st.objects[src].props[k].value)
                        }
                        setMember(st, t, key, v)
                    }
                }
                // enumerable elements come across too (assign from an array)
                var e: i64 = 0
                while e < st.objects[src].elems.len() {
                    let ev = cloneValue(st.objects[src].elems[e])
                    setMember(st, t, i64ToStr(e), ev)
                    e = e + 1
                }
            }
            s = s + 1
        }
        return target
    }
    return JSValue.Undefined
}

// The property bag a value carries, or -1. A function's own properties live in
// its statics bag, not in an object slot, so Object.assign has to look there for
// both its target and its sources — prisma's debug module is a function on both
// sides of `Object.assign(fn, otherFn)`.
// The prototype object index for object `h`, or -1 (null). milojs fakes the
// prototype chain — a plain `{}` has proto -1 and inherits Object.prototype
// methods by dispatch — so getPrototypeOf / `__proto__` / `constructor` resolve
// the right singleton by type here rather than reading a real link.
fn protoOfHandle(st: &Interp, h: i64): i64 {
    if h < 0 {
        return -1
    }
    // Object.prototype is the top of the chain; its own proto is null
    if h == st.objectProtoObj {
        return -1
    }
    // an explicit link (user `new F()`, Object.create, setPrototypeOf) wins
    if st.objects[h].proto >= 0 {
        return st.objects[h].proto
    }
    if st.objects[h].isArray && st.arrayProtoObj >= 0 {
        return st.arrayProtoObj
    }
    // functions, errors and plain objects fall back to Object.prototype
    // (Function.prototype / Error.prototype are not distinct singletons here)
    return st.objectProtoObj
}

// The `constructor` for a builtin object, when the (faked) prototype chain has
// none. Returns Undefined for anything without a well-defined builtin
// constructor here, so a real (user) constructor resolved through the chain is
// never overridden — this is only ever consulted as a fallback.
fn builtinConstructorOf(st: &Interp, o: i64): JSValue {
    if o == st.objectProtoObj {
        return JSValue.Native(NATIVE_OBJECT_CTOR)
    }
    if o == st.arrayProtoObj && st.arrayCtorObj >= 0 {
        return JSValue.Obj(st.arrayCtorObj)
    }
    if st.objects[o].isError {
        // the specific constructor named by the error's `name` (TypeError, …)
        let nm = getMember(st, o, "name")
        match nm {
            JSValue.Str(s) => {
                if scopeHasOwn(st, 0, s) {
                    return scopeLookup(st, 0, s)
                }
            }
            _ => {
            }
        }
        if scopeHasOwn(st, 0, "Error") {
            return scopeLookup(st, 0, "Error")
        }
        return JSValue.Undefined
    }
    if st.objects[o].isArray && st.arrayCtorObj >= 0 {
        return JSValue.Obj(st.arrayCtorObj)
    }
    // a genuinely plain object → Object; special builtins without a dedicated
    // constructor here (Map/Set/Date/typed-array/proxy/promise/function…) are
    // left Undefined rather than mis-reported as Object
    if !st.objects[o].isMap && !st.objects[o].isSet && !st.objects[o].isDate && !st.objects[o].isProxy && !st.objects[o].isArrayBuffer && st.objExtras[st.objects[o].extra].taBuf < 0 && !st.objects[o].isGenerator && st.objects[o].promiseState < 0 && !st.objects[o].isFunctionLike && !st.objects[o].isBound {
        return JSValue.Native(NATIVE_OBJECT_CTOR)
    }
    return JSValue.Undefined
}

fn propertyBagOf(st: &mut Interp, v: &JSValue): i64 {
    match v {
        JSValue.Obj(o) => {
            return o
        }
        JSValue.Func(f, env) => {
            return getFuncStatics(st, f, env)
        }
        _ => {
            return -1
        }
    }
}

fn mathNative(id: i64, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    if id == NATIVE_MATH_RANDOM {
        let next = mjNextRandom(st.rngState)
        st.rngState = next
        var bits = next
        if bits < 0 {
            bits = 0 - bits
        }
        let m = bits % 9007199254740992
        return JSValue.Number((m as f64) / 9007199254740992.0)
    }
    if id == NATIVE_MATH_MIN {
        if args.len() == 0 {
            return JSValue.Number(jsInf())
        }
        var m = toNum(args[0])
        var i: i64 = 0
        while i < args.len() {
            let v = toNum(args[i])
            if !(v == v) {
                return JSValue.Number(jsNan())
            }
            if v < m {
                m = v
            }
            i = i + 1
        }
        return JSValue.Number(m)
    }
    if id == NATIVE_MATH_MAX {
        if args.len() == 0 {
            return JSValue.Number(0.0 - jsInf())
        }
        var m = toNum(args[0])
        var i: i64 = 0
        while i < args.len() {
            let v = toNum(args[i])
            if !(v == v) {
                return JSValue.Number(jsNan())
            }
            if v > m {
                m = v
            }
            i = i + 1
        }
        return JSValue.Number(m)
    }
    var x = 0.0
    if args.len() > 0 {
        x = toNum(args[0])
    }
    if id == NATIVE_MATH_FLOOR {
        return JSValue.Number(mjFloor(x))
    }
    if id == NATIVE_MATH_CEIL {
        return JSValue.Number(mjCeil(x))
    }
    if id == NATIVE_MATH_ROUND {
        return JSValue.Number(mjRound(x))
    }
    if id == NATIVE_MATH_TRUNC {
        return JSValue.Number(mjTrunc(x))
    }
    if id == NATIVE_MATH_ABS {
        return JSValue.Number(mjAbs(x))
    }
    if id == NATIVE_MATH_SIGN {
        return JSValue.Number(mjSign(x))
    }
    if id == NATIVE_MATH_EXP {
        return JSValue.Number(mathExp(x))
    }
    if id == NATIVE_MATH_LOG {
        return JSValue.Number(mathLog(x))
    }
    if id == NATIVE_MATH_LOG2 {
        return JSValue.Number(mathLog2(x))
    }
    if id == NATIVE_MATH_LOG10 {
        return JSValue.Number(mathLog10(x))
    }
    if id == NATIVE_MATH_SIN {
        return JSValue.Number(mathSin(x))
    }
    if id == NATIVE_MATH_COS {
        return JSValue.Number(mathCos(x))
    }
    if id == NATIVE_MATH_TAN {
        return JSValue.Number(mathTan(x))
    }
    if id == NATIVE_MATH_ASIN {
        return JSValue.Number(mathAtan2(x, mathSqrt(1.0 - x * x)))
    }
    if id == NATIVE_MATH_ACOS {
        return JSValue.Number(mathAtan2(mathSqrt(1.0 - x * x), x))
    }
    if id == NATIVE_MATH_ATAN {
        return JSValue.Number(mathAtan2(x, 1.0))
    }
    if id == NATIVE_MATH_ATAN2 {
        var y2 = 0.0
        if args.len() > 1 {
            y2 = toNum(args[1])
        }
        return JSValue.Number(mathAtan2(x, y2))
    }
    if id == NATIVE_MATH_SQRT {
        return JSValue.Number(sqrt(x))
    }
    if id == NATIVE_MATH_POW {
        var y = 0.0
        if args.len() > 1 {
            y = toNum(args[1])
        }
        return JSValue.Number(pow(x, y))
    }
    return JSValue.Undefined
}

// x instanceof C: for a user constructor, the object must have been made by it
// (its `ctor` slot matches); for a native Error constructor, the object must be
// an error whose kind matches (Error itself matches any error).
// Compile a pattern and wrap it as a RegExp object (regexId links to the
// compiled program; source/flags/lastIndex are ordinary properties).
fn makeRegex(st: &mut Interp, pattern: string, flags: string): JSValue {
    let re = regexCompile(pattern.clone(), flags.clone())
    let isGlobal = re.flagG
    st.regexes.push(re)
    let id = st.regexes.len() - 1
    let o = newObject(st)
    let _er = ensureExtra(st, o)
    st.objExtras[st.objects[o].extra].regexId = id
    objSet(st, o, "source", JSValue.Str(pattern))
    objSet(st, o, "flags", JSValue.Str(flags))
    objSet(st, o, "global", JSValue.Bool(isGlobal))
    objSet(st, o, "lastIndex", JSValue.Number(0.0))
    return JSValue.Obj(o)
}

// Define `key` on `o` from a descriptor object `d`, applying get/set or value
// AND the enumerable/configurable/writable attributes (each defaulting to false
// when omitted, per Object.defineProperty). Shared by defineProperty,
// defineProperties, and Object.create's second argument — all three previously
// dropped the attributes for accessors, and the latter two for data props too.
fn applyDescriptor(st: &mut Interp, o: i64, key: &string, d: i64) {
    let g = getMember(st, d, "get")
    let sfn = getMember(st, d, "set")
    if isCallable(g) || isCallable(sfn) {
        objDefineAccessor(st, o, key.clone(), g, sfn)
    } else {
        objSet(st, o, key.clone(), getMember(st, d, "value"))
    }
    let at = objOwnIndex(st, o, key)
    if at >= 0 {
        st.objects[o].props[at].enumerable = truthy(getMember(st, d, "enumerable"))
        st.objects[o].props[at].configurable = truthy(getMember(st, d, "configurable"))
        st.objects[o].props[at].writable = truthy(getMember(st, d, "writable"))
    }
}

// Build a property-descriptor object { value, writable | get, set }+enumerable+
// configurable for own property `idx` of `h`. Shared by getOwnPropertyDescriptor
// and getOwnPropertyDescriptors.
fn buildPropDescriptor(st: &mut Interp, h: i64, idx: i64): i64 {
    let isAcc = st.objects[h].props[idx].isAccessor
    let pv = cloneValue(st.objects[h].props[idx].value)
    let pg = cloneValue(st.objects[h].props[idx].getter)
    let ps = cloneValue(st.objects[h].props[idx].setter)
    let d = newObject(st)
    pushTemp(st, JSValue.Obj(d))
    if isAcc {
        objSet(st, d, "get", pg)
        objSet(st, d, "set", ps)
    } else {
        objSet(st, d, "value", pv)
        objSet(st, d, "writable", JSValue.Bool(st.objects[h].props[idx].writable))
    }
    objSet(st, d, "enumerable", JSValue.Bool(st.objects[h].props[idx].enumerable))
    objSet(st, d, "configurable", JSValue.Bool(st.objects[h].props[idx].configurable))
    popTemp(st)
    return d
}

fn regexIdOf(st: &Interp, v: &JSValue): i64 {
    match v {
        JSValue.Obj(o) => {
            return st.objExtras[st.objects[o].extra].regexId
        }
        _ => {
            return -1
        }
    }
}

// [wholeMatch, group1, group2, ...]; a non-participating group is undefined.
// `rid` is the regex handle (-1 when none), used to attach `.groups` for named
// captures (?<name>...).
fn buildMatchArray(st: &mut Interp, s: &string, saves: &Vec<i64>, rid: i64): JSValue {
    let arr = newArray(st)
    pushTemp(st, JSValue.Obj(arr))
    var g: i64 = 0
    let ng = saves.len() / 2
    while g < ng {
        let a = saves[2 * g]
        let b = saves[2 * g + 1]
        if a < 0 || b < 0 {
            arrPush(st, arr, JSValue.Undefined)
        } else {
            arrPush(st, arr, JSValue.Str(strSlice(s, a, b)))
        }
        g = g + 1
    }
    // .index (match start) and .input, which callers like content-type read
    objSet(st, arr, "index", JSValue.Number(saves[0] as f64))
    objSet(st, arr, "input", JSValue.Str(s.clone()))
    // .groups: an object of named-capture substrings, or undefined when the
    // pattern has no (?<name>...) groups (matching JS, where .groups is
    // undefined not {} for an un-named pattern)
    if rid >= 0 && st.regexes[rid].groupNames.len() > 0 {
        let groups = newObject(st)
        var gi: i64 = 0
        while gi < st.regexes[rid].groupNames.len() {
            let nm = st.regexes[rid].groupNames[gi].clone()
            let gnum = st.regexes[rid].groupNums[gi]
            var gv = JSValue.Undefined
            if 2 * gnum + 1 < saves.len() {
                let a = saves[2 * gnum]
                let b = saves[2 * gnum + 1]
                if a >= 0 && b >= 0 {
                    gv = JSValue.Str(strSlice(s, a, b))
                }
            }
            objSet(st, groups, nm, gv)
            gi = gi + 1
        }
        objSet(st, arr, "groups", JSValue.Obj(groups))
    } else {
        objSet(st, arr, "groups", JSValue.Undefined)
    }
    popTemp(st)
    return JSValue.Obj(arr)
}

fn regexMethod(st: &mut Interp, o: i64, name: &string, args: &Vec<JSValue>): JSValue {
    let rid = st.objExtras[st.objects[o].extra].regexId
    var subject = ""
    if args.len() > 0 {
        subject = toStr(args[0])
    }
    if name == "test" {
        let saves = regexExec(st.regexes[rid], subject, 0)
        return JSValue.Bool(saves.len() > 0)
    }
    if name == "exec" {
        // a global (or sticky) regex resumes from lastIndex and advances it, so
        // `while ((m = re.exec(s)))` terminates instead of re-matching forever
        let isG = st.regexes[rid].flagG
        var start: i64 = 0
        if isG {
            start = toNum(objGet(st, o, "lastIndex")) as i64
            if start < 0 || start > subject.len() {
                objSet(st, o, "lastIndex", JSValue.Number(0.0))
                return JSValue.Null
            }
        }
        let saves = regexExec(st.regexes[rid], subject, start)
        if saves.len() == 0 {
            if isG {
                objSet(st, o, "lastIndex", JSValue.Number(0.0))
            }
            return JSValue.Null
        }
        if isG {
            var next = saves[1]
            // a zero-width match must still advance, or the loop stalls
            if next <= start {
                next = start + 1
            }
            objSet(st, o, "lastIndex", JSValue.Number(next as f64))
        }
        return buildMatchArray(st, subject, saves, rid)
    }
    return JSValue.Undefined
}

// Expand $1..$9, $&, $$, and $<name> in a replacement string against a match's
// saves. `re` supplies the named-capture map for $<name> (pass a regex with no
// named groups to disable it).
fn expandRepl(repl: &string, s: &string, saves: &Vec<i64>, re: &Regex): string {
    var out = String.withCapacity(repl.len())
    var i: i64 = 0
    while i < repl.len() {
        let c = repl[i]
        if c == '$' && i + 1 < repl.len() {
            let n = repl[i + 1]
            if n == '$' {
                out.push('$')
                i = i + 2
            } else if n == '&' {
                out = out + strSlice(s, saves[0], saves[1])
                i = i + 2
            } else if n == '<' {
                // $<name>: substitute the named capture, empty when absent
                var j = i + 2
                var nm = String.withCapacity(8)
                while j < repl.len() && repl[j] != '>' {
                    nm.push(repl[j])
                    j = j + 1
                }
                var gnum: i64 = -1
                var k: i64 = 0
                while k < re.groupNames.len() {
                    if re.groupNames[k] == nm {
                        gnum = re.groupNums[k]
                    }
                    k = k + 1
                }
                if gnum >= 0 && 2 * gnum + 1 < saves.len() {
                    let a = saves[2 * gnum]
                    let b = saves[2 * gnum + 1]
                    if a >= 0 && b >= 0 {
                        out = out + strSlice(s, a, b)
                    }
                }
                if j < repl.len() {
                    j = j + 1
                }
                i = j
            } else if n >= '1' && n <= '9' {
                let g = n as i64 - 48
                if 2 * g + 1 < saves.len() {
                    let a = saves[2 * g]
                    let b = saves[2 * g + 1]
                    if a >= 0 && b >= 0 {
                        out = out + strSlice(s, a, b)
                    }
                }
                i = i + 2
            } else {
                out.push(c)
                i = i + 1
            }
        } else {
            out.push(c)
            i = i + 1
        }
    }
    return out
}

fn regexReplace(st: &mut Interp, s: &string, rid: i64, repl: &string): JSValue {
    let global = st.regexes[rid].flagG
    var out = String.withCapacity(s.len())
    var last: i64 = 0
    var searchPos: i64 = 0
    var going = true
    while going {
        let saves = regexExec(st.regexes[rid], s, searchPos)
        if saves.len() == 0 {
            going = false
        } else {
            let mstart = saves[0]
            let mend = saves[1]
            out = out + strSlice(s, last, mstart)
            out = out + expandRepl(repl, s, saves, st.regexes[rid])
            last = mend
            if mend == mstart {
                searchPos = mend + 1
            } else {
                searchPos = mend
            }
            if !global || searchPos > s.len() {
                going = false
            }
        }
    }
    out = out + strSlice(s, last, s.len())
    return JSValue.Str(out)
}

// s.replace(re, fn): the callback receives (match, ...groups, offset, string) and
// its return value is substituted. Without this the function was coerced with
// toStr and the literal text "function" ended up in the output.
fn regexReplaceFn(prog: &Prog, st: &mut Interp, s: &string, rid: i64, fn_: &JSValue): JSValue {
    let global = st.regexes[rid].flagG
    var out = String.withCapacity(s.len())
    var last: i64 = 0
    var searchPos: i64 = 0
    var going = true
    while going && !st.throwing {
        let saves = regexExec(st.regexes[rid], s, searchPos)
        if saves.len() == 0 {
            going = false
        } else {
            let mstart = saves[0]
            let mend = saves[1]
            out = out + strSlice(s, last, mstart)
            var args: Vec<JSValue> = Vec.new()
            args.push(JSValue.Str(strSlice(s, mstart, mend)))
            var g: i64 = 1
            let ng = saves.len() / 2
            while g < ng {
                let a = saves[2 * g]
                let b = saves[2 * g + 1]
                if a < 0 || b < 0 {
                    args.push(JSValue.Undefined)
                } else {
                    args.push(JSValue.Str(strSlice(s, a, b)))
                }
                g = g + 1
            }
            args.push(JSValue.Number(mstart as f64))
            args.push(JSValue.Str(s.clone()))
            let r = callValue(prog, fn_, args, JSValue.Undefined, st)
            out = out + toStr(r)
            last = mend
            if mend == mstart {
                searchPos = mend + 1
            } else {
                searchPos = mend
            }
            if !global || searchPos > s.len() {
                going = false
            }
        }
    }
    out = out + strSlice(s, last, s.len())
    return JSValue.Str(out)
}

// s.split(re) — the separator is whatever the pattern matches. A zero-width
// match advances by one so the split cannot loop forever.
fn regexSplit(st: &mut Interp, s: &string, rid: i64): JSValue {
    let arr = newArray(st)
    pushTemp(st, JSValue.Obj(arr))
    var last: i64 = 0
    var searchPos: i64 = 0
    var going = true
    while going {
        let saves = regexExec(st.regexes[rid], s, searchPos)
        if saves.len() == 0 || searchPos > s.len() {
            going = false
        } else {
            let mstart = saves[0]
            let mend = saves[1]
            if mend == mstart {
                searchPos = mend + 1
            } else {
                arrPush(st, arr, JSValue.Str(strSlice(s, last, mstart)))
                last = mend
                searchPos = mend
            }
        }
    }
    arrPush(st, arr, JSValue.Str(strSlice(s, last, s.len())))
    popTemp(st)
    return JSValue.Obj(arr)
}

// s.match(re): with the g flag, an array of all matched substrings (or null);
// otherwise the first match array (whole + groups) or null.
// Encode a single Unicode code point to UTF-8 (milojs's string encoding).
fn codePointToUtf8(cp: i64): string {
    var out = String.withCapacity(4)
    if cp < 128 {
        out.push(cp as u8)
    } else if cp < 2048 {
        out.push((192 | (cp >> 6)) as u8)
        out.push((128 | (cp & 63)) as u8)
    } else if cp < 65536 {
        out.push((224 | (cp >> 12)) as u8)
        out.push((128 | ((cp >> 6) & 63)) as u8)
        out.push((128 | (cp & 63)) as u8)
    } else {
        out.push((240 | (cp >> 18)) as u8)
        out.push((128 | ((cp >> 12) & 63)) as u8)
        out.push((128 | ((cp >> 6) & 63)) as u8)
        out.push((128 | (cp & 63)) as u8)
    }
    return out
}

fn regexStrMatch(st: &mut Interp, s: &string, rid: i64): JSValue {
    let global = st.regexes[rid].flagG
    if !global {
        let saves = regexExec(st.regexes[rid], s, 0)
        if saves.len() == 0 {
            return JSValue.Null
        }
        return buildMatchArray(st, s, saves, rid)
    }
    let arr = newArray(st)
    pushTemp(st, JSValue.Obj(arr))
    var pos: i64 = 0
    var any = false
    var going = true
    while going {
        let saves = regexExec(st.regexes[rid], s, pos)
        if saves.len() == 0 {
            going = false
        } else {
            any = true
            arrPush(st, arr, JSValue.Str(strSlice(s, saves[0], saves[1])))
            if saves[1] == saves[0] {
                pos = saves[1] + 1
            } else {
                pos = saves[1]
            }
            if pos > s.len() {
                going = false
            }
        }
    }
    popTemp(st)
    if !any {
        return JSValue.Null
    }
    return JSValue.Obj(arr)
}

// str.matchAll(re): every match as a full exec-style array (match text, capture
// groups, .index, .input) — unlike match/g which yields only the match strings.
// Returned as an array, which is iterable for the usual `[...]` / for-of
// consumption. Iterates regardless of the /g flag (lenient vs the spec's throw).
fn regexStrMatchAll(st: &mut Interp, s: &string, rid: i64): JSValue {
    let arr = newArray(st)
    pushTemp(st, JSValue.Obj(arr))
    var pos: i64 = 0
    var going = true
    while going {
        let saves = regexExec(st.regexes[rid], s, pos)
        if saves.len() == 0 {
            going = false
        } else {
            let m = buildMatchArray(st, s, saves, rid)
            arrPush(st, arr, m)
            if saves[1] == saves[0] {
                pos = saves[1] + 1
            } else {
                pos = saves[1]
            }
            if pos > s.len() {
                going = false
            }
        }
    }
    popTemp(st)
    return JSValue.Obj(arr)
}

// Execute a pre-loaded module in a fresh CommonJS scope and cache its exports.
// A module already loading (a require cycle) returns its partial exports, which
// is what Node does.
fn runModule(prog: &Prog, idx: i64, st: &mut Interp): JSValue {
    if st.modState[idx] == 2 {
        return cloneValue(st.modExports[idx])
    }
    if st.modState[idx] == 1 {
        return cloneValue(st.modExports[idx])
    }
    st.modState[idx] = 1
    let path = st.modPaths[idx].clone()
    let dir = dirOf(path)

    let modScope = newScope(st, 0)
    pushActive(st, modScope)
    let moduleObj = newObject(st)
    let exportsObj = newObject(st)
    objSet(st, moduleObj, "exports", JSValue.Obj(exportsObj))
    scopeDefine(st, modScope, "module", JSValue.Obj(moduleObj))
    scopeDefine(st, modScope, "exports", JSValue.Obj(exportsObj))
    scopeDefine(st, modScope, "__filename", JSValue.Str(path.clone()))
    scopeDefine(st, modScope, "__dirname", JSValue.Str(dir.clone()))
    // publish partial exports up front so a cycle sees something
    st.modExports[idx] = JSValue.Obj(exportsObj)

    st.modDirStack.push(dir)
    st.modPathStack.push(st.modPaths[idx].clone())
    let blk = st.modBlocks[idx]
    // a module body is function-like: its vars and function declarations hoist
    // to the module scope
    hoistBlock(prog, blk, st, modScope)
    execBlock(prog, blk, st, modScope)
    let _ = st.modDirStack.pop()
    let _p = st.modPathStack.pop()
    popActive(st)

    // module.exports may have been reassigned wholesale
    let finalExports = getMember(st, moduleObj, "exports")
    st.modExports[idx] = cloneValue(finalExports)
    st.modState[idx] = 2
    return finalExports
}

// require(spec) — resolved against the directory of the module doing the calling.
fn requireModule(prog: &Prog, spec: &string, st: &mut Interp): JSValue {
    var dir = ""
    if st.modDirStack.len() > 0 {
        dir = st.modDirStack[st.modDirStack.len() - 1].clone()
    }
    // A .node file is a shared library, not JS: it never goes through the module
    // pre-loader, so it is dlopened here. prisma reaches its query engine this
    // way (require(<abs>/libquery_engine.node)).
    if hasNodeAddonExt(spec) {
        var addonPath = spec.clone()
        if spec[0] != '/' && dir.len() > 0 {
            addonPath = dir + "/" + spec
        }
        let cached = findNapiAddon(st, addonPath)
        match cached {
            Option.Some(v) => {
                return v
            }
            Option.None => {
            }
        }
        match napiLoadAddon(addonPath) {
            Result.Ok(v) => {
                st.napiAddonPaths.push(addonPath)
                st.napiAddonExports.push(cloneValue(v))
                return v
            }
            Result.Err(e) => {
                st.throwing = true
                st.thrownValue = makeError(st, "Error", e)
                return JSValue.Undefined
            }
        }
    }
    let path = resolveSpec(dir, spec)
    if path.len() == 0 {
        // relative and node_modules specifiers resolve; what lands here is a node
        // builtin (path/fs/http/...) which still needs a shim module
        // node throws MODULE_NOT_FOUND; packages rely on that to probe for
        // optional dependencies with try/catch. Returning undefined instead made
        // the failure surface later as a confusing "undefined is not a function".
        reportUnresolved(st, spec)
        st.throwing = true
        st.thrownValue = makeError(st, "Error", "Cannot find module '" + spec + "'")
        return JSValue.Undefined
        return JSValue.Undefined
    }
    let idx = findModule(st, path)
    if idx < 0 {
        eprint("milojs: module was not pre-loaded: '" + path + "'")
        return JSValue.Undefined
    }
    return runModule(prog, idx, st)
}

fn instanceOf(st: &Interp, val: &JSValue, ctor: &JSValue): bool {
    match val {
        JSValue.Obj(o) => {
            match ctor {
                JSValue.Func(fIdx, _e) => {
                    if st.objects[o].ctor == fIdx {
                        return true
                    }
                    // a subclass instance is also an instance of every base, so
                    // walk the prototype chain: Dog.prototype's proto is
                    // Animal.prototype (linked by instantiateClass)
                    if fIdx < st.funcProtos.len() {
                        let target = st.funcProtos[fIdx]
                        if target >= 0 {
                            var p = st.objects[o].proto
                            while p >= 0 {
                                if p == target {
                                    return true
                                }
                                p = st.objects[p].proto
                            }
                        }
                    }
                    return false
                }
                JSValue.Native(id) => {
                    // every object inherits from Object.prototype
                    if id == NATIVE_OBJECT_CTOR {
                        return true
                    }
                    // the built-in exotic constructors are recognised by the
                    // object's internal kind (Date/Map/Set/RegExp/ArrayBuffer are
                    // Native values, so `x instanceof Date` reaches here)
                    if id == NATIVE_DATE {
                        return st.objects[o].isDate
                    }
                    if id == NATIVE_MAP {
                        return st.objects[o].isMap
                    }
                    if id == NATIVE_SET {
                        return st.objects[o].isSet
                    }
                    if id == NATIVE_REGEXP {
                        return st.objExtras[st.objects[o].extra].regexId >= 0
                    }
                    if id == NATIVE_ARRAYBUFFER {
                        return st.objects[o].isArrayBuffer
                    }
                    // a typed-array view instanceof its exact kind (Uint8Array,
                    // Float64Array, …): a view has taBuf >= 0 and its taKind is
                    // the ctor's offset from the base id
                    if id >= NATIVE_TA_BASE && id <= NATIVE_TA_BASE + TA_U8C {
                        return st.objExtras[st.objects[o].extra].taBuf >= 0 && !st.objects[o].isDataView && st.objExtras[st.objects[o].extra].taKind == (id - NATIVE_TA_BASE)
                    }
                    if !st.objects[o].isError {
                        return false
                    }
                    if id == NATIVE_ERROR {
                        return true
                    }
                    let nm = objGet(st, o, "name")
                    return toStr(nm) == nativeErrorName(id)
                }
                JSValue.Obj(c) => {
                    // Array is an object constructor (JSValue.Obj), not a Native,
                    // so `[] instanceof Array` reaches here — match by the array flag
                    if c == st.arrayCtorObj {
                        return st.objects[o].isArray
                    }
                    // Promise's constructor is an Obj too; a promise is recognised
                    // by its settlement-state slot
                    if st.promiseCtorObj >= 0 && c == st.promiseCtorObj {
                        return st.objects[o].promiseState >= 0
                    }
                    // a constructor object with a .prototype linked into the
                    // object's chain (user functions assigned as constructors)
                    var p = st.objects[o].proto
                    while p >= 0 {
                        if p == c {
                            return true
                        }
                        p = st.objects[p].proto
                    }
                    return false
                }
                _ => {
                    return false
                }
            }
        }
        _ => {
            return false
        }
    }
}

fn setupGlobals(st: &mut Interp) {
    scopeDefine(st, 0, "Error", JSValue.Native(NATIVE_ERROR))
    scopeDefine(st, 0, "TypeError", JSValue.Native(NATIVE_TYPE_ERROR))
    scopeDefine(st, 0, "RangeError", JSValue.Native(NATIVE_RANGE_ERROR))
    scopeDefine(st, 0, "SyntaxError", JSValue.Native(NATIVE_SYNTAX_ERROR))
    scopeDefine(st, 0, "ReferenceError", JSValue.Native(NATIVE_REFERENCE_ERROR))
    // JSON is a plain object whose methods are native functions
    let json = newObject(st)
    objSet(st, json, "stringify", JSValue.Native(NATIVE_JSON_STRINGIFY))
    objSet(st, json, "parse", JSValue.Native(NATIVE_JSON_PARSE))
    scopeDefine(st, 0, "JSON", JSValue.Obj(json))
    // Math likewise: native-fn methods + numeric constants
    let math = newObject(st)
    objSet(st, math, "floor", JSValue.Native(NATIVE_MATH_FLOOR))
    objSet(st, math, "ceil", JSValue.Native(NATIVE_MATH_CEIL))
    objSet(st, math, "round", JSValue.Native(NATIVE_MATH_ROUND))
    objSet(st, math, "trunc", JSValue.Native(NATIVE_MATH_TRUNC))
    objSet(st, math, "abs", JSValue.Native(NATIVE_MATH_ABS))
    objSet(st, math, "sign", JSValue.Native(NATIVE_MATH_SIGN))
    objSet(st, math, "sqrt", JSValue.Native(NATIVE_MATH_SQRT))
    objSet(st, math, "pow", JSValue.Native(NATIVE_MATH_POW))
    objSet(st, math, "min", JSValue.Native(NATIVE_MATH_MIN))
    objSet(st, math, "max", JSValue.Native(NATIVE_MATH_MAX))
    objSet(st, math, "random", JSValue.Native(NATIVE_MATH_RANDOM))
    objSet(st, math, "exp", JSValue.Native(NATIVE_MATH_EXP))
    objSet(st, math, "log", JSValue.Native(NATIVE_MATH_LOG))
    objSet(st, math, "log2", JSValue.Native(NATIVE_MATH_LOG2))
    objSet(st, math, "log10", JSValue.Native(NATIVE_MATH_LOG10))
    objSet(st, math, "sin", JSValue.Native(NATIVE_MATH_SIN))
    objSet(st, math, "cos", JSValue.Native(NATIVE_MATH_COS))
    objSet(st, math, "tan", JSValue.Native(NATIVE_MATH_TAN))
    objSet(st, math, "asin", JSValue.Native(NATIVE_MATH_ASIN))
    objSet(st, math, "acos", JSValue.Native(NATIVE_MATH_ACOS))
    objSet(st, math, "atan", JSValue.Native(NATIVE_MATH_ATAN))
    objSet(st, math, "atan2", JSValue.Native(NATIVE_MATH_ATAN2))
    objSet(st, math, "LN2", JSValue.Number(0.6931471805599453))
    objSet(st, math, "LN10", JSValue.Number(2.302585092994046))
    objSet(st, math, "LOG2E", JSValue.Number(1.4426950408889634))
    objSet(st, math, "LOG10E", JSValue.Number(0.4342944819032518))
    objSet(st, math, "SQRT2", JSValue.Number(1.4142135623730951))
    objSet(st, math, "SQRT1_2", JSValue.Number(0.7071067811865476))
    objSet(st, math, "PI", JSValue.Number(3.141592653589793))
    objSet(st, math, "E", JSValue.Number(2.718281828459045))
    scopeDefine(st, 0, "Math", JSValue.Obj(math))
    scopeDefine(st, 0, "RegExp", JSValue.Native(NATIVE_REGEXP))
    let promiseCtor = newObject(st)
    st.promiseCtorObj = promiseCtor
    objSet(st, promiseCtor, "resolve", JSValue.Native(NATIVE_PROMISE_RESOLVE))
    objSet(st, promiseCtor, "reject", JSValue.Native(NATIVE_PROMISE_REJECT))
    scopeDefine(st, 0, "Promise", JSValue.Obj(promiseCtor))
    // Object's statics live in the property bag that belongs to the native id,
    // so reading `Object.keys` as a value and calling `Object.keys(o)` both go
    // through the same place. A standalone object would only serve the call path.
    let objectCtor = getNativeProps(st, NATIVE_OBJECT_CTOR)
    objSet(st, objectCtor, "defineProperty", JSValue.Native(NATIVE_OBJECT_DEFINEPROPERTY))
    objSet(st, objectCtor, "keys", JSValue.Native(NATIVE_OBJECT_KEYS))
    objSet(st, objectCtor, "assign", JSValue.Native(NATIVE_OBJECT_ASSIGN))
    objSet(st, objectCtor, "values", JSValue.Native(NATIVE_OBJECT_VALUES))
    objSet(st, objectCtor, "entries", JSValue.Native(NATIVE_OBJECT_ENTRIES))
    objSet(st, objectCtor, "freeze", JSValue.Native(NATIVE_OBJECT_FREEZE))
    objSet(st, objectCtor, "isFrozen", JSValue.Native(NATIVE_OBJECT_ISFROZEN))
    objSet(st, objectCtor, "preventExtensions", JSValue.Native(NATIVE_OBJECT_PREVENTEXT))
    objSet(st, objectCtor, "isExtensible", JSValue.Native(NATIVE_OBJECT_ISEXT))
    objSet(st, objectCtor, "seal", JSValue.Native(NATIVE_OBJECT_SEAL))
    objSet(st, objectCtor, "isSealed", JSValue.Native(NATIVE_OBJECT_ISSEALED))
    objSet(st, objectCtor, "create", JSValue.Native(NATIVE_OBJECT_CREATE))
    objSet(st, objectCtor, "getPrototypeOf", JSValue.Native(NATIVE_OBJECT_GETPROTO))
    objSet(st, objectCtor, "setPrototypeOf", JSValue.Native(NATIVE_OBJECT_SETPROTO))
    objSet(st, objectCtor, "getOwnPropertyDescriptor", JSValue.Native(NATIVE_OBJECT_GETOWNPROPDESC))
    objSet(st, objectCtor, "getOwnPropertyDescriptors", JSValue.Native(NATIVE_OBJECT_GETOWNPROPDESCS))
    objSet(st, objectCtor, "defineProperties", JSValue.Native(NATIVE_OBJECT_DEFINEPROPERTIES))
    objSet(st, objectCtor, "getOwnPropertyNames", JSValue.Native(NATIVE_OBJECT_GETOWNPROPNAMES))
    objSet(st, objectCtor, "getOwnPropertySymbols", JSValue.Native(NATIVE_OBJECT_GETOWNPROPSYMBOLS))
    objSet(st, objectCtor, "is", JSValue.Native(NATIVE_OBJECT_IS))
    objSet(st, objectCtor, "hasOwn", JSValue.Native(NATIVE_OBJECT_HASOWN))
    let objectProto = newObject(st)
    objSet(st, objectProto, "hasOwnProperty", makeBoundMethod(st, JSValue.Undefined, "hasOwnProperty"))
    // Object.prototype.toString.call(x) is the standard type-detection idiom
    // bound under a private name, not "toString": dispatching by the plain name
    // sent Object.prototype.toString.call(x) into x's OWN toString (a function
    // printed its source, a regex returned undefined), which broke the
    // `Object.prototype.toString.call(o).slice(8, -1)` type-tag idiom.
    objSet(st, objectProto, "toString", makeBoundMethod(st, JSValue.Undefined, "@@objProtoToString"))
    objSet(st, objectProto, "valueOf", makeBoundMethod(st, JSValue.Undefined, "valueOf"))
    objSet(st, objectProto, "isPrototypeOf", makeBoundMethod(st, JSValue.Undefined, "isPrototypeOf"))
    objSet(st, objectProto, "propertyIsEnumerable", makeBoundMethod(st, JSValue.Undefined, "propertyIsEnumerable"))
    objSet(st, objectCtor, "prototype", JSValue.Obj(objectProto))
    st.objectProtoObj = objectProto
    // Object is itself an object, so it carries the Object.prototype methods.
    // Code borrows them from the constructor — `Object.hasOwnProperty.call(o, k)`
    // is a common way to avoid a shadowed own property — and the native's bag
    // does not inherit, so they are installed explicitly.
    objSet(st, objectCtor, "hasOwnProperty", makeBoundMethod(st, JSValue.Undefined, "hasOwnProperty"))
    objSet(st, objectCtor, "isPrototypeOf", makeBoundMethod(st, JSValue.Undefined, "isPrototypeOf"))
    objSet(st, objectCtor, "propertyIsEnumerable", makeBoundMethod(st, JSValue.Undefined, "propertyIsEnumerable"))
    objSet(st, objectCtor, "toString", makeBoundMethod(st, JSValue.Undefined, "@@objProtoToString"))
    objSet(st, objectCtor, "valueOf", makeBoundMethod(st, JSValue.Undefined, "valueOf"))
    scopeDefine(st, 0, "Object", JSValue.Native(NATIVE_OBJECT_CTOR))
    scopeDefine(st, 0, "Number", JSValue.Native(NATIVE_NUMBER))
    scopeDefine(st, 0, "BigInt", JSValue.Native(NATIVE_BIGINT))
    let stringCtorObj = getNativeProps(st, NATIVE_STRING)
    objSet(st, stringCtorObj, "fromCharCode", JSValue.Native(NATIVE_STRING_FROMCHARCODE))
    objSet(st, stringCtorObj, "fromCodePoint", JSValue.Native(NATIVE_STRING_FROMCODEPOINT))
    objSet(st, stringCtorObj, "raw", JSValue.Native(NATIVE_STRING_RAW))
    // String.prototype methods as bound-method values, so
    // String.prototype.replace.call(str, ...) — the qs module's pattern — works
    let stringProto = newObject(st)
    for sm in strProtoMethodNames() {
        objSet(st, stringProto, sm.clone(), makeBoundMethod(st, JSValue.Undefined, sm.clone()))
    }
    objSet(st, stringCtorObj, "prototype", JSValue.Obj(stringProto))
    st.stringCtorProps = stringCtorObj
    scopeDefine(st, 0, "String", JSValue.Native(NATIVE_STRING))
    scopeDefine(st, 0, "Boolean", JSValue.Native(NATIVE_BOOLEAN))
    scopeDefine(st, 0, "NaN", JSValue.Number(jsNan()))
    scopeDefine(st, 0, "Infinity", JSValue.Number(jsInfinity()))
    scopeDefine(st, 0, "isNaN", JSValue.Native(NATIVE_IS_NAN))
    scopeDefine(st, 0, "gc", JSValue.Native(NATIVE_GC))
    scopeDefine(st, 0, "isFinite", JSValue.Native(NATIVE_IS_FINITE))
    scopeDefine(st, 0, "parseInt", JSValue.Native(NATIVE_PARSE_INT))
    scopeDefine(st, 0, "parseFloat", JSValue.Native(NATIVE_PARSE_FLOAT))
    // The shared iterator prototype. The prelude installs the helper methods
    // (map/filter/take/...) onto this one object; every iterator the engine
    // builds points its proto here, so helpers work on array iterators too.
    let iterProto = newObject(st)
    st.iterProtoObj = iterProto
    scopeDefine(st, 0, "__iteratorProto", JSValue.Obj(iterProto))
    // globalThis: a real object whose properties ARE the global bindings
    let globalObj = newObject(st)
    st.objects[globalObj].isGlobal = true
    scopeDefine(st, 0, "globalThis", JSValue.Obj(globalObj))
    scopeDefine(st, 0, "Symbol", JSValue.Native(NATIVE_SYMBOL))
    let symbolCtorObj = getNativeProps(st, NATIVE_SYMBOL)
    objSet(st, symbolCtorObj, "iterator", JSValue.Str(symIteratorKey()))
    // other well-known symbols — interned keys like @@iterator, counter 0
    objSet(st, symbolCtorObj, "asyncIterator", JSValue.Str("@@sym:Symbol.asyncIterator:0"))
    objSet(st, symbolCtorObj, "toPrimitive", JSValue.Str(symToPrimitiveKey()))
    objSet(st, symbolCtorObj, "toStringTag", JSValue.Str(symToStringTagKey()))
    objSet(st, symbolCtorObj, "hasInstance", JSValue.Str("@@sym:Symbol.hasInstance:0"))
    let dateCtorObj = getNativeProps(st, NATIVE_DATE)
    objSet(st, dateCtorObj, "now", JSValue.Native(NATIVE_DATE_NOW))
    objSet(st, dateCtorObj, "UTC", JSValue.Native(NATIVE_DATE_UTC))
    objSet(st, dateCtorObj, "parse", JSValue.Native(NATIVE_DATE_PARSE))
    // Date.prototype methods as bound-method values, so
    // Date.prototype.toISOString.call(d) — qs's pattern — works
    let dateProto = newObject(st)
    for dm in dateProtoMethodNames() {
        objSet(st, dateProto, dm.clone(), makeBoundMethod(st, JSValue.Undefined, dm.clone()))
    }
    objSet(st, dateCtorObj, "prototype", JSValue.Obj(dateProto))
    st.dateCtorProps = dateCtorObj
    scopeDefine(st, 0, "Date", JSValue.Native(NATIVE_DATE))
    // Function.prototype.{call,apply,bind} are bound-method values: invoking
    // .call on them re-targets to whatever function is passed as the receiver,
    // which is how Function.prototype.apply.call(fn, ...) resolves
    let functionProto = newObject(st)
    objSet(st, functionProto, "call", makeBoundMethod(st, JSValue.Undefined, "call"))
    objSet(st, functionProto, "apply", makeBoundMethod(st, JSValue.Undefined, "apply"))
    objSet(st, functionProto, "bind", makeBoundMethod(st, JSValue.Undefined, "bind"))
    // lodash and friends compare functions by source text via
    // Function.prototype.toString.call(fn)
    objSet(st, functionProto, "toString", makeBoundMethod(st, JSValue.Undefined, "toString"))
    st.objects[functionProto].isFunctionLike = true
    let functionCtor = newObject(st)
    st.objects[functionCtor].isFunctionLike = true
    objSet(st, functionCtor, "prototype", JSValue.Obj(functionProto))
    scopeDefine(st, 0, "Function", JSValue.Obj(functionCtor))
    scopeDefine(st, 0, "setTimeout", JSValue.Native(NATIVE_SET_TIMEOUT))
    scopeDefine(st, 0, "setInterval", JSValue.Native(NATIVE_SET_INTERVAL))
    scopeDefine(st, 0, "clearTimeout", JSValue.Native(NATIVE_CLEAR_TIMER))
    scopeDefine(st, 0, "clearInterval", JSValue.Native(NATIVE_CLEAR_TIMER))
    scopeDefine(st, 0, "clearImmediate", JSValue.Native(NATIVE_CLEAR_TIMER))
    scopeDefine(st, 0, "setImmediate", JSValue.Native(NATIVE_SET_IMMEDIATE))
    scopeDefine(st, 0, "queueMicrotask", JSValue.Native(NATIVE_QUEUE_MICROTASK_JS))
    // The raw "wrap a value in a resolved promise" primitive, exposed under its
    // own name so the prelude can build the public Promise.resolve on top of it.
    // Capturing `Promise.resolve` from JS does not work: reading a method off a
    // native constructor yields a late-bound dispatcher that looks the name up
    // again at call time, so a wrapper calling the captured value re-entered
    // itself forever.
    scopeDefine(st, 0, "__promiseResolveValue", JSValue.Native(NATIVE_PROMISE_RESOLVE))
    scopeDefine(st, 0, "encodeURIComponent", JSValue.Native(NATIVE_ENCODE_URI_COMPONENT))
    scopeDefine(st, 0, "decodeURIComponent", JSValue.Native(NATIVE_DECODE_URI_COMPONENT))
    scopeDefine(st, 0, "encodeURI", JSValue.Native(NATIVE_ENCODE_URI))
    scopeDefine(st, 0, "decodeURI", JSValue.Native(NATIVE_DECODE_URI))
    scopeDefine(st, 0, "ArrayBuffer", JSValue.Native(NATIVE_ARRAYBUFFER))
    scopeDefine(st, 0, "DataView", JSValue.Native(NATIVE_DATAVIEW))
    var tk: i64 = 0
    while tk <= TA_U8C {
        scopeDefine(st, 0, taName(tk), JSValue.Native(NATIVE_TA_BASE + tk))
        tk = tk + 1
    }
    scopeDefine(st, 0, "Map", JSValue.Native(NATIVE_MAP))
    scopeDefine(st, 0, "WeakMap", JSValue.Native(NATIVE_MAP))
    scopeDefine(st, 0, "Set", JSValue.Native(NATIVE_SET))
    scopeDefine(st, 0, "WeakSet", JSValue.Native(NATIVE_SET))
    // Array.prototype.<m> as a bound-method value, so the ES5 idiom
    // Array.prototype.slice.call(arguments) resolves
    let arrayProto = newObject(st)
    objSet(st, arrayProto, "slice", makeBoundMethod(st, JSValue.Undefined, "slice"))
    objSet(st, arrayProto, "map", makeBoundMethod(st, JSValue.Undefined, "map"))
    objSet(st, arrayProto, "filter", makeBoundMethod(st, JSValue.Undefined, "filter"))
    objSet(st, arrayProto, "forEach", makeBoundMethod(st, JSValue.Undefined, "forEach"))
    objSet(st, arrayProto, "indexOf", makeBoundMethod(st, JSValue.Undefined, "indexOf"))
    objSet(st, arrayProto, "join", makeBoundMethod(st, JSValue.Undefined, "join"))
    objSet(st, arrayProto, "push", makeBoundMethod(st, JSValue.Undefined, "push"))
    objSet(st, arrayProto, "concat", makeBoundMethod(st, JSValue.Undefined, "concat"))
    let arrayCtor = newObject(st)
    st.objects[arrayCtor].isFunctionLike = true
    objSet(st, arrayCtor, "prototype", JSValue.Obj(arrayProto))
    objSet(st, arrayCtor, "name", JSValue.Str("Array"))
    st.arrayCtorObj = arrayCtor
    st.arrayProtoObj = arrayProto
    objSet(st, arrayCtor, "isArray", JSValue.Native(NATIVE_ARRAY_ISARRAY))
    objSet(st, arrayCtor, "from", JSValue.Native(NATIVE_ARRAY_FROM))
    scopeDefine(st, 0, "Array", JSValue.Obj(arrayCtor))
    // file natives, named as minibun's runtime expects them
    // raw TCP, used by the http builtin; not part of the JS surface
    scopeDefine(st, 0, "__tcpListen", JSValue.Native(NATIVE_TCP_LISTEN))
    scopeDefine(st, 0, "__tcpAccept", JSValue.Native(NATIVE_TCP_ACCEPT))
    scopeDefine(st, 0, "__tcpRecv", JSValue.Native(NATIVE_TCP_RECV))
    scopeDefine(st, 0, "__tcpSend", JSValue.Native(NATIVE_TCP_SEND))
    scopeDefine(st, 0, "__tcpClose", JSValue.Native(NATIVE_TCP_CLOSE))
    scopeDefine(st, 0, "__httpFetch", JSValue.Native(NATIVE_HTTP_FETCH))
    scopeDefine(st, 0, "__httpRegister", JSValue.Native(NATIVE_HTTP_REGISTER))
    scopeDefine(st, 0, "__httpUnregister", JSValue.Native(NATIVE_HTTP_UNREGISTER))
    scopeDefine(st, 0, "__writeFileSync", JSValue.Native(NATIVE_WRITE_FILE))
    scopeDefine(st, 0, "__readFileSync", JSValue.Native(NATIVE_READ_FILE_SYNC))
    scopeDefine(st, 0, "__mkdirSync", JSValue.Native(NATIVE_MKDIR))
    scopeDefine(st, 0, "__readdirSync", JSValue.Native(NATIVE_READDIR))
    scopeDefine(st, 0, "__unlinkSync", JSValue.Native(NATIVE_UNLINK))
    scopeDefine(st, 0, "__rmdirSync", JSValue.Native(NATIVE_RMDIR))
    scopeDefine(st, 0, "__renameSync", JSValue.Native(NATIVE_RENAME))
    scopeDefine(st, 0, "__isDir", JSValue.Native(NATIVE_IS_DIR))
    scopeDefine(st, 0, "__fileExists", JSValue.Native(NATIVE_FILE_EXISTS))
    scopeDefine(st, 0, "__byteLength", JSValue.Native(NATIVE_BYTE_LENGTH))
    scopeDefine(st, 0, "__napiLoad", JSValue.Native(NATIVE_NAPI_LOAD))
    scopeDefine(st, 0, "__httpFetchAsync", JSValue.Native(NATIVE_HTTP_FETCH_ASYNC))
    let consoleObj = newObject(st)
    objSet(st, consoleObj, "log", JSValue.Native(NATIVE_CONSOLE_LOG))
    objSet(st, consoleObj, "info", JSValue.Native(NATIVE_CONSOLE_LOG))
    objSet(st, consoleObj, "debug", JSValue.Native(NATIVE_CONSOLE_LOG))
    objSet(st, consoleObj, "trace", JSValue.Native(NATIVE_CONSOLE_LOG))
    objSet(st, consoleObj, "dir", JSValue.Native(NATIVE_CONSOLE_LOG))
    objSet(st, consoleObj, "warn", JSValue.Native(NATIVE_CONSOLE_LOG))
    objSet(st, consoleObj, "error", JSValue.Native(NATIVE_CONSOLE_LOG))
    scopeDefine(st, 0, "console", JSValue.Obj(consoleObj))
    scopeDefine(st, 0, "Proxy", JSValue.Native(NATIVE_PROXY))
}

// typeof: never throws, even for an unbound name (scopeLookup returns undefined).
fn typeofStr(v: &JSValue): string {
    match v {
        JSValue.Undefined => {
            return "undefined"
        }
        JSValue.Null => {
            return "object"
        }
        JSValue.Bool(_b) => {
            return "boolean"
        }
        JSValue.Number(_n) => {
            return "number"
        }
        JSValue.Str(_s) => {
            return "string"
        }
        JSValue.BigInt(_s) => {
            return "bigint"
        }
        JSValue.Func(_f, _e) => {
            return "function"
        }
        JSValue.Obj(_o) => {
            return "object"
        }
        JSValue.Native(_id) => {
            return "function"
        }
    }
}

fn isBigIntVal(v: &JSValue): bool {
    match v {
        JSValue.BigInt(_s) => {
            return true
        }
        _ => {
            return false
        }
    }
}

fn isStrVal(v: &JSValue): bool {
    match v {
        JSValue.Str(_s) => {
            return true
        }
        _ => {
            return false
        }
    }
}

// the decimal string of a BigInt, or "" for anything else
fn bigStrOf(v: &JSValue): string {
    match v {
        JSValue.BigInt(s) => {
            return s.clone()
        }
        _ => {
            return ""
        }
    }
}

// Binary operators where at least one operand is a BigInt. Arithmetic requires
// BOTH to be BigInt (JS throws on a mix); comparison and == coerce across types;
// === defers to the value-equality rule; bitwise on BigInt is not implemented and
// throws rather than returning a silently-wrong (double-based) answer.
fn evalBigIntBin(op: &string, va: JSValue, vb: JSValue, st: &mut Interp): JSValue {
    let aBig = isBigIntVal(va)
    let bBig = isBigIntVal(vb)
    // `+` with a string operand concatenates (BigInt stringifies without the `n`)
    if op == "+" && (isStrVal(va) || isStrVal(vb)) {
        return JSValue.Str(toStr(va) + toStr(vb))
    }
    if op == "===" {
        return JSValue.Bool(jsStrictEquals(va, vb))
    }
    if op == "!==" {
        return JSValue.Bool(!jsStrictEquals(va, vb))
    }
    // arithmetic: both operands must be BigInt
    if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" || op == "**" {
        if !(aBig && bBig) {
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", "Cannot mix BigInt and other types, use explicit conversions")
            return JSValue.Undefined
        }
        let sa = bigStrOf(va)
        let sb = bigStrOf(vb)
        if op == "+" {
            return JSValue.BigInt(bnAdd(sa, sb))
        }
        if op == "-" {
            return JSValue.BigInt(bnSub(sa, sb))
        }
        if op == "*" {
            return JSValue.BigInt(bnMul(sa, sb))
        }
        if op == "/" {
            if sb == "0" {
                st.throwing = true
                st.thrownValue = makeError(st, "RangeError", "Division by zero")
                return JSValue.Undefined
            }
            return JSValue.BigInt(bnDiv(sa, sb))
        }
        if op == "%" {
            if sb == "0" {
                st.throwing = true
                st.thrownValue = makeError(st, "RangeError", "Division by zero")
                return JSValue.Undefined
            }
            return JSValue.BigInt(bnMod(sa, sb))
        }
        // op == "**"
        if sb.len() > 0 && sb[0] == '-' {
            st.throwing = true
            st.thrownValue = makeError(st, "RangeError", "Exponent must be non-negative")
            return JSValue.Undefined
        }
        return JSValue.BigInt(bnPow(sa, sb))
    }
    // comparison + loose equality: mixing is allowed. Both BigInt compare exactly;
    // a BigInt vs Number/String comparison goes through f64 (lossy only past 2^53).
    if op == "<" || op == ">" || op == "<=" || op == ">=" || op == "==" || op == "!=" {
        var c: i64 = 0
        if aBig && bBig {
            c = bnCmp(bigStrOf(va), bigStrOf(vb))
        } else {
            let na = toNum(va)
            let nb = toNum(vb)
            if na < nb {
                c = -1
            } else if na > nb {
                c = 1
            } else {
                c = 0
            }
        }
        if op == "<" {
            return JSValue.Bool(c < 0)
        }
        if op == ">" {
            return JSValue.Bool(c > 0)
        }
        if op == "<=" {
            return JSValue.Bool(c <= 0)
        }
        if op == ">=" {
            return JSValue.Bool(c >= 0)
        }
        if op == "==" {
            return JSValue.Bool(c == 0)
        }
        return JSValue.Bool(c != 0)
    }
    // &, |, ^, <<, >> on BigInt. Both operands must be BigInt (like arithmetic).
    if op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>" || op == ">>>" {
        if !(aBig && bBig) {
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", "Cannot mix BigInt and other types, use explicit conversions")
            return JSValue.Undefined
        }
        let sa = bigStrOf(va)
        let sb = bigStrOf(vb)
        if op == "<<" {
            return JSValue.BigInt(bnShl(sa, sb))
        }
        if op == ">>" {
            return JSValue.BigInt(bnShr(sa, sb))
        }
        if op == ">>>" {
            // JS: BigInts are signed, `>>>` has no meaning → TypeError
            st.throwing = true
            st.thrownValue = makeError(st, "TypeError", "BigInts have no unsigned right shift, use >> instead")
            return JSValue.Undefined
        }
        var opc: u8 = '&'
        if op == "|" {
            opc = '|'
        } else if op == "^" {
            opc = '^'
        }
        return JSValue.BigInt(bnBitwise(opc, sa, sb))
    }
    st.throwing = true
    st.thrownValue = makeError(st, "TypeError", "BigInt operation not supported")
    return JSValue.Undefined
}

fn evalExpr(prog: &Prog, idx: i64, st: &mut Interp, scope: i64): JSValue {
    // an exception is unwinding — stop evaluating, produce a placeholder
    if st.throwing {
        return JSValue.Undefined
    }
    // match the arena slot in place — cloning the node (and its string payloads)
    // per visit was the dominant interpreter cost
    match prog.exprs[idx] {
        Expr.Num(n) => {
            return JSValue.Number(n)
        }
        Expr.StrLit(s) => {
            return JSValue.Str(s.clone())
        }
        Expr.BigIntLit(s) => {
            return JSValue.BigInt(bigNormalizeDec(s))
        }
        Expr.BoolLit(b) => {
            return JSValue.Bool(b)
        }
        Expr.NullLit => {
            return JSValue.Null
        }
        Expr.UndefLit => {
            return JSValue.Undefined
        }
        Expr.Ident(name) => {
            match scopeTryLookup(st, scope, name) {
                Option.Some(v) => {
                    return v
                }
                Option.None => {
                    // reading an undeclared identifier is a ReferenceError in JS;
                    // without this a typo just evaluates to undefined and the
                    // failure surfaces somewhere else entirely
                    // `this` is never a ReferenceError — unbound at module top
                    // level it is simply undefined, and CommonJS code reads it
                    // freely
                    if name != "this" {
                        st.throwing = true
                        st.thrownValue = makeError(st, "ReferenceError", name.clone() + " is not defined")
                    }
                    return JSValue.Undefined
                }
            }
        }
        Expr.Bin(op, a, b) => {
            // && and || short-circuit and yield the operand value, JS-style
            if op == "&&" {
                let va = evalExpr(prog, a, st, scope)
                if !truthy(va) {
                    return va
                }
                return evalExpr(prog, b, st, scope)
            }
            if op == "||" {
                let va = evalExpr(prog, a, st, scope)
                if truthy(va) {
                    return va
                }
                return evalExpr(prog, b, st, scope)
            }
            if op == "??" {
                // nullish coalescing: only null/undefined fall through
                let va = evalExpr(prog, a, st, scope)
                match va {
                    JSValue.Null => {
                        return evalExpr(prog, b, st, scope)
                    }
                    JSValue.Undefined => {
                        return evalExpr(prog, b, st, scope)
                    }
                    _ => {
                        return va
                    }
                }
            }
            if op == "in" {
                let kv = evalExpr(prog, a, st, scope)
                let ov = evalExpr(prog, b, st, scope)
                let key = toStr(kv)
                match ov {
                    JSValue.Obj(o) => {
                        if st.objects[o].isProxy {
                            // `key in proxy`: the `has` trap, else `in` the target
                            let trap = proxyTrap(st, o, "has")
                            if isCallableIn(st, trap) {
                                var hargs: Vec<JSValue> = Vec.new()
